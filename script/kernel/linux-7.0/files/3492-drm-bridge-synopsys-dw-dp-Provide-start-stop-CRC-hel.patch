From 17e052daaaa2143cb609f358089d01e7d14c4318 Mon Sep 17 00:00:00 2001
From: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
Date: Mon, 10 Nov 2025 09:46:04 +0200
Subject: [PATCH 080/114] drm/bridge: synopsys: dw-dp: Provide start/stop CRC
 helpers

In order to support frame CRC generation at DisplayPort AUX channel
level, implement and export the dw_dp_{start|stop}_crc() wrappers over
the related drm_dp_*() helpers.

Signed-off-by: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
---
 drivers/gpu/drm/bridge/synopsys/dw-dp.c | 16 ++++++++++++++++
 include/drm/bridge/dw_dp.h              |  5 +++++
 2 files changed, 21 insertions(+)

diff --git a/drivers/gpu/drm/bridge/synopsys/dw-dp.c b/drivers/gpu/drm/bridge/synopsys/dw-dp.c
index 86828db5e6..ac80b95dba 100644
--- a/drivers/gpu/drm/bridge/synopsys/dw-dp.c
+++ b/drivers/gpu/drm/bridge/synopsys/dw-dp.c
@@ -2098,6 +2098,22 @@ struct dw_dp *dw_dp_bind(struct device *dev, struct drm_encoder *encoder,
 }
 EXPORT_SYMBOL_GPL(dw_dp_bind);
 
+int dw_dp_start_crc(struct drm_bridge *bridge,  struct drm_crtc *crtc)
+{
+	struct dw_dp *dp = bridge_to_dp(bridge);
+
+	return drm_dp_start_crc(&dp->aux, crtc);
+}
+EXPORT_SYMBOL_GPL(dw_dp_start_crc);
+
+int dw_dp_stop_crc(struct drm_bridge *bridge)
+{
+	struct dw_dp *dp = bridge_to_dp(bridge);
+
+	return drm_dp_stop_crc(&dp->aux);
+}
+EXPORT_SYMBOL_GPL(dw_dp_stop_crc);
+
 MODULE_AUTHOR("Andy Yan <andyshrk@163.com>");
 MODULE_DESCRIPTION("DW DP Core Library");
 MODULE_LICENSE("GPL");
diff --git a/include/drm/bridge/dw_dp.h b/include/drm/bridge/dw_dp.h
index 25363541e6..a307a21bdb 100644
--- a/include/drm/bridge/dw_dp.h
+++ b/include/drm/bridge/dw_dp.h
@@ -8,6 +8,8 @@
 
 #include <linux/device.h>
 
+struct drm_bridge;
+struct drm_crtc;
 struct drm_encoder;
 struct dw_dp;
 
@@ -24,4 +26,7 @@ struct dw_dp_plat_data {
 
 struct dw_dp *dw_dp_bind(struct device *dev, struct drm_encoder *encoder,
 			 const struct dw_dp_plat_data *plat_data);
+
+int dw_dp_start_crc(struct drm_bridge *bridge,  struct drm_crtc *crtc);
+int dw_dp_stop_crc(struct drm_bridge *bridge);
 #endif /* __DW_DP__ */
-- 
