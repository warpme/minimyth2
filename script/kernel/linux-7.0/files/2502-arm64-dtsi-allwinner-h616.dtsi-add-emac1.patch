diff --speed-large-files --no-dereference --minimal -Naur linux-6.9-rc5/arch/arm64/boot/dts/allwinner/sun50i-h616.dtsi linux-6.9-rc5/arch/arm64/boot/dts/allwinner/sun50i-h616.dtsi
--- linux-6.9-rc5/arch/arm64/boot/dts/allwinner/sun50i-h616.dtsi	2024-04-26 17:26:22.246973123 +0200
+++ linux-6.9-rc5/arch/arm64/boot/dts/allwinner/sun50i-h616.dtsi	2024-04-26 17:25:03.846685460 +0200
@@ -290,6 +290,13 @@
 				drive-strength = <40>;
 			};
 
+			rmii_pins: rmii-pins {
+				pins = "PA0", "PA1", "PA2", "PA3", "PA4",
+				       "PA5", "PA6", "PA7", "PA8", "PA9";
+				function = "emac1";
+				drive-strength = <40>;
+			};
+
 			i2c0_pins: i2c0-pins {
 				pins = "PI6", "PI7";
 				function = "i2c0";
@@ -895,6 +914,27 @@
 				compatible = "snps,dwmac-mdio";
 				#address-cells = <1>;
 				#size-cells = <0>;
+			};
+		};
+		emac1: ethernet@5030000 {
+			compatible = "allwinner,sun50i-h616-emac";
+			reg = <0x05030000 0x10000>;
+			interrupts = <GIC_SPI 15 IRQ_TYPE_LEVEL_HIGH>;
+			interrupt-names = "macirq";
+			resets = <&ccu RST_BUS_EMAC1>;
+			reset-names = "stmmaceth";
+			clocks = <&ccu CLK_BUS_EMAC1>;
+			clock-names = "stmmaceth";
+			syscon = <&syscon 1>;
+			pinctrl-names = "default";
+			pinctrl-0 = <&rmii_pins>;
+			phy-mode = "rmii";
+			status = "disabled";
+
+			mdio1: mdio {
+				compatible = "snps,dwmac-mdio";
+				#address-cells = <1>;
+				#size-cells = <0>;
 			};
 		};
 
--

MiniMyth2

diff --speed-large-files --no-dereference --minimal -Naur linux-7.0.1/arch/arm64/boot/dts/allwinner/sun50i-h616.dtsi linux-7.0.1/arch/arm64/boot/dts/allwinner/sun50i-h616.dtsi
--- linux-7.0.1/arch/arm64/boot/dts/allwinner/sun50i-h616.dtsi	2026-04-28 11:19:19.313462252 +0200
+++ linux-7.0.1/arch/arm64/boot/dts/allwinner/sun50i-h616.dtsi	2026-04-28 10:38:12.461740587 +0200
@@ -434,6 +434,10 @@
 			cpu_speed_grade: cpu-speed-grade@0 {
 				reg = <0x0 2>;
 			};
+
+			ephy_calib: ephy_calib@2c {
