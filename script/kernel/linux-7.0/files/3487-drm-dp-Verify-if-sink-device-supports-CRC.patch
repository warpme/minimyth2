From c15dbf1f902af4e89738ed1c8c2d6a252de67697 Mon Sep 17 00:00:00 2001
From: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
Date: Mon, 10 Nov 2025 10:26:17 +0200
Subject: [PATCH 075/114] drm/dp: Verify if sink device supports CRC

Before attempting to start capturing frame CRCs through DPCD, ensure the
feature is actually supported by the sink.

This is a prerequisite to improve handling of broken hardware not
incrementing the counter when a TEST_CRC related register is updated.

Signed-off-by: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
---
 drivers/gpu/drm/display/drm_dp_helper.c | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/drivers/gpu/drm/display/drm_dp_helper.c b/drivers/gpu/drm/display/drm_dp_helper.c
index a697cc227e..4b252ff533 100644
--- a/drivers/gpu/drm/display/drm_dp_helper.c
+++ b/drivers/gpu/drm/display/drm_dp_helper.c
@@ -2480,6 +2480,13 @@ int drm_dp_start_crc(struct drm_dp_aux *aux, struct drm_crtc *crtc)
 	u8 buf;
 	int ret;
 
+	ret = drm_dp_dpcd_read_byte(aux, DP_TEST_SINK_MISC, &buf);
+	if (ret < 0)
+		return ret;
+
+	if (!(buf & DP_TEST_CRC_SUPPORTED))
+		return -ENOTSUPP;
+
 	ret = drm_dp_dpcd_read_byte(aux, DP_TEST_SINK, &buf);
 	if (ret < 0)
 		return ret;
-- 
