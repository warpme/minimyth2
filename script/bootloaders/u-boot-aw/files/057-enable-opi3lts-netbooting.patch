diff --speed-large-files --no-dereference --minimal -Naur u-boot-2026.04/arch/arm/dts/sun50i-h6-orangepi-3-lts.dts u-boot-2026.04/arch/arm/dts/sun50i-h6-orangepi-3-lts.dts
--- u-boot-2026.04/arch/arm/dts/sun50i-h6-orangepi-3-lts.dts	2026-04-30 12:44:39.247592810 +0200
+++ u-boot-2026.04/arch/arm/dts/sun50i-h6-orangepi-3-lts.dts	2026-04-30 12:42:11.077738947 +0200
@@ -100,11 +100,11 @@
 &emac {
 	pinctrl-names = "default";
 	pinctrl-0 = <&ext_rgmii_pins>;
-	phy-mode = "rgmii";
+	phy-mode = "rgmii-rxid";
 	phy-handle = <&ext_rgmii_phy>;
 	phy-supply = <&reg_gmac_3v3>;
-	allwinner,rx-delay-ps = <200>;
-	allwinner,tx-delay-ps = <300>;
+	allwinner,rx-delay-ps = <0>;
+	allwinner,tx-delay-ps = <700>;
 	status = "okay";
 };
 
@@ -128,10 +128,12 @@
 	ext_rgmii_phy: ethernet-phy@1 {
 		compatible = "ethernet-phy-ieee802.3-c22";
 		reg = <1>;
-
+		motorcomm,keep-pll-enabled;
+		motorcomm,auto-sleep-disabled;
+		motorcomm,clk-out-frequency-hz = <125000000>;
 		reset-gpios = <&pio 3 14 GPIO_ACTIVE_LOW>; /* PD14 */
 		reset-assert-us = <15000>;
-		reset-deassert-us = <40000>;
+		reset-deassert-us = <100000>;
 	};
 };
 
diff --speed-large-files --no-dereference --minimal -Naur u-boot-2026.04/configs/orangepi_3_lts_defconfig u-boot-2026.04/configs/orangepi_3_lts_defconfig
--- u-boot-2026.04/configs/orangepi_3_lts_defconfig	2026-04-30 12:44:39.247651550 +0200
+++ u-boot-2026.04/configs/orangepi_3_lts_defconfig	2026-04-30 12:08:11.108926410 +0200
@@ -17,3 +17,25 @@
 CONFIG_USB_OHCI_HCD=y
 CONFIG_USB_DWC3=y
 # CONFIG_USB_DWC3_GADGET is not set
+CONFIG_NETDEVICES=y
+CONFIG_SUN8I_EMAC=y
+CONFIG_PHY_REALTEK=y
+CONFIG_PHY_MOTORCOMM=y
+CONFIG_PHYLIB=y
+CONFIG_DM_ETH=y
+CONFIG_NET=y
+CONFIG_ARP_TIMEOUT=200
+CONFIG_NET_RETRY_COUNT=5
+CONFIG_PROT_TCP=y
+CONFIG_PROT_UDP=y
+CONFIG_CMD_DHCP=y
+CONFIG_CMD_TFTPBOOT=y
+CONFIG_CMD_WGET=y
+CONFIG_CMD_NFS=y
+CONFIG_CMD_PING=y
+CONFIG_OF_LIBFDT_OVERLAY=y
+CONFIG_LIB_RAND=y
+CONFIG_NET_LWIP=y
+CONFIG_CMD_WGET_LWIP=y
+CONFIG_BOOTCOMMAND="if dhcp ${scriptaddr} /PXEclient/pxelinux.cfg/sun50i-h6-orangepi-3-lts.scr; then source ${scriptaddr}; fi; run distro_bootcmd"
+CONFIG_CMD_MII=y
