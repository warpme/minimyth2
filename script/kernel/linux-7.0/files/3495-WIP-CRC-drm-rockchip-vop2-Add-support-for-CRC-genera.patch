+static int vop2_crtc_validate_crc_source(struct drm_crtc *crtc, const char *name,
+					 enum rockchip_drm_crc_source* source)
+{
+	enum rockchip_drm_crc_source req_src, cap_src_mask = 0, prov_src_mask = 0;
+	struct vop2_video_port *vp = to_vop2_video_port(crtc);
+	const struct vop2_data *vop2_data = vp->vop2->data;
+
+	if (rockchip_drm_parse_crc_source(name, &req_src) < 0) {
+		drm_dbg(crtc->dev, "Unknown CRC source: %s\n", name);
+		return -EINVAL;
+	}
+
+	if (!req_src) {
+		*source = 0;
+		return 0;
+	}
+
+#if IS_REACHABLE(CONFIG_DRM_ANALOGIX_DP)
+	prov_src_mask |= BIT(ROCKCHIP_DRM_CRC_SOURCE_EDP);
+#endif
+#if IS_REACHABLE(CONFIG_ROCKCHIP_DW_DP)
+	prov_src_mask |= BIT(ROCKCHIP_DRM_CRC_SOURCE_DP);
+#endif
+
+	if (prov_src_mask) {
+		//TODO: EP info should be available at driver bind time
+		// otherwise this information is only available if crtc is active
+		int ret = drm_modeset_lock_single_interruptible(&crtc->mutex);
+
+		if (!ret && crtc->state->active) {
+			struct drm_encoder *encoder;
+			struct rockchip_encoder *rkenc;
+
+			drm_for_each_encoder_mask(encoder, crtc->dev,
+						  crtc->state->encoder_mask) {
+				rkenc = to_rockchip_encoder(encoder);
+
+				switch (rkenc->crtc_endpoint_id) {
+				case ROCKCHIP_VOP2_EP_EDP0:
+				case ROCKCHIP_VOP2_EP_EDP1:
+					cap_src_mask = BIT(ROCKCHIP_DRM_CRC_SOURCE_EDP);
+					break;
+				case ROCKCHIP_VOP2_EP_DP0:
+				case ROCKCHIP_VOP2_EP_DP1:
+					cap_src_mask = BIT(ROCKCHIP_DRM_CRC_SOURCE_DP);
+					break;
+				}
+
+				if (cap_src_mask)
+					break;
+			}
+		} else {
+			cap_src_mask = prov_src_mask;
+		}
+
+		if (!ret)
+			drm_modeset_unlock(&crtc->mutex);
+	}
+
+	cap_src_mask &= prov_src_mask;
+	cap_src_mask |= BIT(ROCKCHIP_DRM_CRC_SOURCE_CRTC);
+	cap_src_mask &= vop2_data->crc_source_mask;
+
+	if (req_src == ROCKCHIP_DRM_CRC_SOURCE_AUTO) {
+		req_src = 0;
+		while ((++req_src < ROCKCHIP_DRM_CRC_SOURCE_AUTO) &&
+		       !(cap_src_mask & BIT(req_src)));
+		*source = req_src;
+		return 0;
+	}
+
+	if (!(cap_src_mask & BIT(req_src)))
+		return -EINVAL;
+
+	*source = req_src;
+	return 0;
+}
+
+static int vop2_crtc_set_crc_source(struct drm_crtc *crtc, const char *source)
+{
+	enum rockchip_drm_crc_source crc_source;
+	struct rockchip_crtc_state *vcstate;
+	struct drm_encoder *encoder;
+	int ret;
+
+	ret = vop2_crtc_validate_crc_source(crtc, source, &crc_source);
+	if (ret < 0)
+		return ret;
+
+	vcstate = to_rockchip_crtc_state(crtc->state);
+
+	if (crc_source == ROCKCHIP_DRM_CRC_SOURCE_CRTC ||
+	    (!crc_source && vcstate->crc_source == ROCKCHIP_DRM_CRC_SOURCE_CRTC)) {
+		return vop2_crtc_set_crc_source_crtc(crtc, crc_source);
+	}
+
+	if (crc_source == ROCKCHIP_DRM_CRC_SOURCE_DP ||
+	    (!crc_source && vcstate->crc_source == ROCKCHIP_DRM_CRC_SOURCE_DP)) {
+		drm_for_each_encoder_mask(encoder, crtc->dev, crtc->state->encoder_mask) {
+			drm_for_each_bridge_in_chain_scoped(encoder, bridge) {
+				if (bridge->type == DRM_MODE_CONNECTOR_DisplayPort) {
+					if (crc_source)
+						ret = dw_dp_start_crc(bridge, crtc);
+					else
+						ret = dw_dp_stop_crc(bridge);
+
+					if (!ret)
+						vcstate->crc_source = crc_source;
+
+					return ret;
+				}
+			}
+		}
+	}
+
+	if (crc_source == ROCKCHIP_DRM_CRC_SOURCE_EDP ||
+	    (!crc_source && vcstate->crc_source == ROCKCHIP_DRM_CRC_SOURCE_EDP)) {
+		struct drm_connector_list_iter conn_iter;
+		struct drm_connector *connector;
+
+		drm_connector_list_iter_begin(crtc->dev, &conn_iter);
+		drm_for_each_connector_iter(connector, &conn_iter)
+			if ((crtc->state->connector_mask & drm_connector_mask(connector)) &&
+			    (connector->connector_type == DRM_MODE_CONNECTOR_eDP))
+				break;
+		drm_connector_list_iter_end(&conn_iter);
+
+		if (connector) {
+			if (crc_source)
+				return analogix_dp_start_crc(connector);
+			return analogix_dp_stop_crc(connector);
+		}
+	}
+
+	return -ENODEV;
+}
+
