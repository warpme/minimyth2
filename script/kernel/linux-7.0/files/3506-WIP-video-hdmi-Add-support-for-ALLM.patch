diff --git a/drivers/video/hdmi.c b/drivers/video/hdmi.c
index 45b42f14a7..9ecc68a1b9 100644
--- a/drivers/video/hdmi.c
+++ b/drivers/video/hdmi.c
@@ -684,6 +684,205 @@ ssize_t hdmi_vendor_infoframe_pack(struct hdmi_vendor_infoframe *frame,
