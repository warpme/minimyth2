+static int radxa_svc_log_show(struct seq_file *s, void *unused)
+{
+	struct radxa_svc_glink *svc = s->private;
+	__le32 max_len = cpu_to_le32(RADXA_SVC_MAX_RX_PAYLOAD);
+	char *log;
+	size_t len = RADXA_SVC_MAX_RX_PAYLOAD;
+	size_t text_len;
+	int ret;
+
+	log = kzalloc(RADXA_SVC_MAX_RX_PAYLOAD + 1, GFP_KERNEL);
+	if (!log)
+		return -ENOMEM;
+
+	ret = radxa_svc_request(svc, RADXA_SVC_OP_GET_LOG, &max_len,
+				sizeof(max_len), log, &len);
+	if (ret) {
+		seq_printf(s, "error: %d\n", ret);
+		goto out_free;
+	}
+
+	text_len = strnlen(log, min(len, (size_t)RADXA_SVC_MAX_RX_PAYLOAD));
+	seq_write(s, log, text_len);
+	if (!text_len || log[text_len - 1] != '\n')
+		seq_putc(s, '\n');
+
+out_free:
+	kfree(log);
+	return 0;
+}
