From 18a5217d8bf55c80f7b4361cb473d3e87ed64d5a Mon Sep 17 00:00:00 2001
From: Justin Suess <utilityemal77@gmail.com>
Date: Mon, 29 Jun 2026 17:37:20 -0400
Subject: [PATCH 08/13] arm64: dts: allwinner: a523: add the video-codec
 (Cedrus) node

Add the VE (video engine) node for the A523/H728 using the new
allwinner,sun55i-a523-video-engine compatible.

This is a minimal bring-up: no iommus/allwinner,sram. The syscon lets
sunxi_sram_claim() succeed as a no-op and the IOMMU is in bypass at
reset, so the VE does physical DMA from the CMA pool. The iommus and
ve_sram links can be added once those nodes are wired up.
---
 .../arm64/boot/dts/allwinner/sun55i-a523.dtsi | 19 +++++++++++++++++++
 1 file changed, 19 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
index 770d7f86a0f5..a788faef07d6 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
@@ -330,6 +330,25 @@ hdmi_phy: hdmi-phy@5530000 {
 			#phy-cells = <0>;
 		};
 
+		video-codec@1c0e000 {
+			compatible = "allwinner,sun55i-a523-video-engine";
+			reg = <0x01c0e000 0x2000>;
+			interrupts = <GIC_SPI 120 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&ccu CLK_BUS_VE>, <&ccu CLK_VE>,
+				 <&ccu CLK_MBUS_VE>;
+			clock-names = "ahb", "mod", "ram";
+			resets = <&ccu RST_BUS_VE>;
+			/*
+			 * Minimal bring-up: no iommus/allwinner,sram. The
+			 * syscon@3000000 lets sunxi_sram_claim() succeed as a
+			 * no-op, and the IOMMU is in bypass at reset so the VE
+			 * does physical DMA from the CMA pool. Add
+			 *   iommus = <&iommu 3>;
+			 *   allwinner,sram = <&ve_sram 1>;
+			 * once an IOMMU node + ve_sram region are wired up.
+			 */
+		};
+
 		pio: pinctrl@2000000 {
 			compatible = "allwinner,sun55i-a523-pinctrl";
 			reg = <0x2000000 0x800>;
