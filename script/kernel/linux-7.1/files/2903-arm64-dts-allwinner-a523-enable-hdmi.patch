diff --speed-large-files --no-dereference --minimal -Naur linux-7.1.3/arch/arm64/boot/dts/allwinner/sun55i-a527-cubie-a5e.dts linux-7.1.3/arch/arm64/boot/dts/allwinner/sun55i-a527-cubie-a5e.dts
--- linux-7.1.3/arch/arm64/boot/dts/allwinner/sun55i-a527-cubie-a5e.dts	2026-07-06 17:31:36.469721635 +0200
+++ linux-7.1.3/arch/arm64/boot/dts/allwinner/sun55i-a527-cubie-a5e.dts	2026-07-06 17:07:01.214057393 +0200
@@ -25,6 +25,38 @@
 		stdout-path = "serial0:115200n8";
 	};
 
+	reserved-memory {
+		#address-cells = <2>;
+		#size-cells = <2>;
+		ranges;
+
+		/*
+		 * The display engine's layer DMA master has a limited fetch
+		 * aperture and can only reach low DRAM (it reads the RCQ pool at
+		 * ~0x43000000 but not 0x4b100000). The kernel's default CMA is
+		 * high (~0xf0000000), so scanout fetches zeros (black). Pin CMA
+		 * just above the kernel image (ends ~0x42c70000) and the RCQ
+		 * pool (~0x43000000), below the dtb (~0x49ff6000).
+		 */
+		linux,cma {
+			compatible = "shared-dma-pool";
+			reusable;
+			size = <0x0 0x10000000>;
+			linux,cma-default;
+		};
+	};
+
+	hdmi-connector {
+		compatible = "hdmi-connector";
+		type = "a";
+
+		port {
+			hdmi_con_in: endpoint {
+				remote-endpoint = <&hdmi_out_con>;
+			};
+		};
+	};
+
 	leds {
 		compatible = "gpio-leds";
 
@@ -433,3 +460,17 @@
 	status = "okay";
 };
 
+&de {
+	status = "okay";
+};
+
+&hdmi {
+	status = "okay";
+};
+
+&hdmi_out {
+	hdmi_out_con: endpoint {
+		remote-endpoint = <&hdmi_con_in>;
+	};
+};
+
