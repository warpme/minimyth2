From 39bb0ba2d48d53fed471239a09666dd6a9a183ad Mon Sep 17 00:00:00 2001
From: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
Date: Wed, 18 Mar 2026 01:17:57 +0200
Subject: [PATCH 102/114] phy: hdmi: Add optional FRL TxFFE configuration

The Transmitter Feed Forward Equalizer (TxFFE) selection is an optional
feature in the HDMI 2.1 FRL training protocol.

Add a new ffe_level setting and a set_ffe_level flag that can be used to
adjust the TxFFE level for the current FRL rate, when supported by both
the Source and the Sink.

Note that whenever the FRL rate gets updated, the TxFFE level is
expected to be reset to zero.  Therefore, ffe_level can only be changed
by a subsequent call to phy_configure(), after enabling the related
set_ffe_level flag, while all the other settings in struct
phy_configure_opts_hdmi will be ignored.

Signed-off-by: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
---
 include/linux/phy/phy-hdmi.h | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/include/linux/phy/phy-hdmi.h b/include/linux/phy/phy-hdmi.h
index d4cf4430ee..f1b2639b06 100644
--- a/include/linux/phy/phy-hdmi.h
+++ b/include/linux/phy/phy-hdmi.h
@@ -19,6 +19,10 @@ enum phy_hdmi_mode {
  * @tmds_char_rate: HDMI TMDS Character Rate in Hertz.
  * @frl.rate_per_lane: HDMI FRL Rate per Lane in Gbps.
  * @frl.lanes: HDMI FRL lanes count.
+ * @frl.ffe_level: Transmitter Feed Forward Equalizer Level.
+ *	Optional (defaults to 0), requires set_ffe_level to be changed.
+ * @frl.set_ffe_level: Flag indicating whether or not to reconfigure ffe_level.
+ *	All the other (unrelated) settings are ignored when this is used.
  *
  * This structure is used to represent the configuration state of a HDMI phy.
  */
@@ -29,6 +33,8 @@ struct phy_configure_opts_hdmi {
 		struct {
 			u8 rate_per_lane;
 			u8 lanes;
+			u8 ffe_level;
+			u8 set_ffe_level : 1;
 		} frl;
 	};
 };
