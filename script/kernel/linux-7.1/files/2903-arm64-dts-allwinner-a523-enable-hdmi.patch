diff --speed-large-files --no-dereference --minimal -Naur linux-7.1.3/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts linux-7.1.3/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts
--- linux-7.1.3/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts	2026-07-06 17:31:36.454630935 +0200
+++ linux-7.1.3/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts	2026-07-06 17:07:48.298058515 +0200
@@ -29,6 +29,50 @@
 		stdout-path = "serial0:115200n8";
 	};
 
+	reserved-memory {
+		#address-cells = <2>;
+		#size-cells = <2>;
+		ranges;
+
+		/* 128 KiB reserved for Trusted Firmware-A (BL31). */
+		secmon@48000000 {
+			reg = <0x0 0x48000000 0x0 0x20000>;
+			no-map;
+		};
+
+		/* 256 KiB reserved for the SCP. */
+		secmon@48100000 {
+			reg = <0x0 0x48100000 0x0 0x40000>;
+			no-map;
+		};
+
+		/*
+		 * The display engine's layer DMA master has a limited fetch
+		 * aperture and can only reach low DRAM (it reads the RCQ pool at
+		 * ~0x43000000 but not 0x4b100000). The kernel's default CMA is
+		 * high (~0xf0000000), so scanout fetches zeros (black). Pin CMA
+		 * just above the kernel image (ends ~0x42c70000) and the RCQ
+		 * pool (~0x43000000), below the dtb (~0x49ff6000).
+		 */
+		linux,cma {
+			compatible = "shared-dma-pool";
+			reusable;
+			size = <0x0 0x10000000>;
+			linux,cma-default;
+		};
+	};
+
+	hdmi-connector {
+		compatible = "hdmi-connector";
+		type = "a";
+
+		port {
+			hdmi_con_in: endpoint {
+				remote-endpoint = <&hdmi_out_con>;
+			};
+		};
+	};
+
 	ext_osc32k: ext-osc32k-clk {
 		#clock-cells = <0>;
 		compatible = "fixed-clock";
@@ -481,3 +524,17 @@
 	usb1_vbus-supply = <&reg_usb_vbus>;
 	status = "okay";
 };
+
+&de {
+	status = "okay";
+};
+
+&hdmi {
+	status = "okay";
+};
+
+&hdmi_out {
+	hdmi_out_con: endpoint {
+		remote-endpoint = <&hdmi_con_in>;
+	};
+};
