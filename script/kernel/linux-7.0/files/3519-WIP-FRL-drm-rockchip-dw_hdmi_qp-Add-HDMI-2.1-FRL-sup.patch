 	if (state->output_bpc == 10)
 		val = FIELD_PREP_WM16(RK3576_COLOR_DEPTH_MASK, RK3576_10BPC);
 	else
@@ -485,8 +660,14 @@ static void dw_hdmi_qp_rk3588_enc_init(struct rockchip_hdmi_qp *hdmi,
 				       struct rockchip_crtc_state *state)
 {
 	int color = dw_hdmi_qp_rockchip_bus_fmt_to_reg(state->bus_format);
+	struct dw_hdmi_qp_link_config *link_cfg = &hdmi->link_cfg;
 	u32 val;
 
