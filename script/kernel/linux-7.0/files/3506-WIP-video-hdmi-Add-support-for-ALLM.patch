+/**
+ * drm_connector_attach_allm_enable_property - attach "allm enable" property
+ * @connector: connector to attach the property on.
+ *
+ * This is used to allow the userspace to control the Sink’s Auto Low-Latency
+ * Mode, if supported.
+ *
+ * Returns:
+ * Zero on success, negative errno on failure.
+ */
+int drm_connector_attach_allm_enable_property(struct drm_connector *connector)
+{
+	struct drm_device *dev = connector->dev;
+	struct drm_property *prop;
+
+	if (!connector->allm_enable_property) {
+		prop = drm_property_create_bool(dev, 0, "allm enable");
+		if (!prop)
+			return -ENOMEM;
+
+		connector->allm_enable_property = prop;
+		drm_object_attach_property(&connector->base, prop, 0);
+	}
+
+
+	return 0;
+}
+EXPORT_SYMBOL(drm_connector_attach_allm_enable_property);
