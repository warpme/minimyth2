diff --speed-large-files --no-dereference --minimal -Naur linux-4549871118cf616eecdd2d939f78e3b9e1dddc48/arch/arm64/boot/dts/rockchip/rk3588-orangepi-5-plus.dts linux-4549871118cf616eecdd2d939f78e3b9e1dddc48/arch/arm64/boot/dts/rockchip/rk3588-orangepi-5-plus.dts
--- linux-4549871118cf616eecdd2d939f78e3b9e1dddc48/arch/arm64/boot/dts/rockchip/rk3588-orangepi-5-plus.dts	2026-06-09 15:35:05.759518476 +0200
+++ linux-4549871118cf616eecdd2d939f78e3b9e1dddc48/arch/arm64/boot/dts/rockchip/rk3588-orangepi-5-plus.dts	2026-06-09 15:30:54.763137779 +0200
@@ -15,6 +15,13 @@
 	model = "Xunlong Orange Pi 5 Plus";
 	compatible = "xunlong,orangepi-5-plus", "rockchip,rk3588";
 
+	aliases {
+		mmc0 = &sdmmc;
+		mmc1 = &sdhci;
+		ethernet0 = &rtl_eth0;
+		ethernet1 = &rtl_eth1;
+	};
+
 	hdmi0-con {
 		compatible = "hdmi-connector";
 		type = "a";
@@ -273,6 +280,20 @@
 	reset-gpios = <&gpio4 RK_PA5 GPIO_ACTIVE_HIGH>;
 	vpcie3v3-supply = <&vcc3v3_wf>;
 	status = "okay";
+
+	pcie@0,0 {
+		reg = <0x200000 0 0 0 0>;
+		#address-cells = <3>;
+		#size-cells = <2>;
+		ranges;
+		device_type = "pci";
+		bus-range = <0x20 0x2f>;
+
+		rtl_eth0: ethernet@0,0 {
+			compatible = "pci10ec,8125";
+			reg = <0x210000 0 0 0 0>;
+		};
+	};
 };
 
 /* phy2 - right ethernet port */
@@ -280,6 +301,20 @@
 	reset-gpios = <&gpio3 RK_PB3 GPIO_ACTIVE_HIGH>;
 	vpcie3v3-supply = <&vcc3v3_pcie_eth>;
 	status = "okay";
+
+	pcie@0,0 {
+		reg = <0x400000 0 0 0 0>;
+		#address-cells = <3>;
+		#size-cells = <2>;
+		ranges;
+		device_type = "pci";
+		bus-range = <0x40 0x4f>;
+
+		rtl_eth1: ethernet@0,0 {
+			compatible = "pci10ec,8125";
+			reg = <0x410000 0 0 0 0>;
+		};
+	};
 };
 
 /* phy0 - left ethernet port */
--

MiniMyth2

