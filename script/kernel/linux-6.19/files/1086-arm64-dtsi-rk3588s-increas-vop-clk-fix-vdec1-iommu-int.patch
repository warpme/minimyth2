diff --speed-large-files --no-dereference --minimal -Naur linux-6.19.3/arch/arm64/boot/dts/rockchip/rk3588-base.dtsi linux-6.19.3/arch/arm64/boot/dts/rockchip/rk3588-base.dtsi
