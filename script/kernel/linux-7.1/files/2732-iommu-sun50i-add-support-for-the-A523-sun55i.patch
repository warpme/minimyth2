Patch from MiniMyth2 project

Developed-by: Piotr Oniszczuk <piotr.oniszczuk@gmail.com>
Signed-off-by: Piotr Oniszczuk <piotr.oniszczuk@gmail.com>




From: Justin Suess <utilityemal77@gmail.com>
Date: Sat, 4 Jul 2026 16:17:25 -0400
Subject: [PATCH 12/14] iommu: sun50i: add support for the A523 (sun55i)

The A523 carries the same H6-family IOMMU at 0x2010000 (a v15 revision
of the block). Two things need handling beyond a new compatible:

- The IOMMU's output address space is 32 bits wide while DRAM starts at
  0x40000000, so on 4 GiB boards the top gigabyte of DRAM lies above
  the 32-bit boundary. The interconnect aliases IOMMU-side output
  addresses 0x0 - 0x40000000 (a hole from the IOMMU's point of view, as
  no DRAM lives there) onto that high gigabyte. Fold leaf page
  addresses into the alias window when building PTEs and unfold them
  when resolving, as the vendor pagetable code does for this whole
  IOMMU generation ("iommu phy" vs "cpu phy"), and only reject
  mappings that lie beyond even the alias window.

- The vendor driver ships the A523 with master TLB prefetch disabled,
  citing a display-RCQ-related bug. Without prefetch, every micro-TLB
  miss stalls the DE fetch pipe and 4K scanout underruns to a dead
  screen (1080p survives). Enable prefetch together with the "only
  prefetch valid pages" bits new in this revision, which defuse
  prefetches of unmapped pages - the likely subject of the vendor's
  debugging.

Per-variant match data carries the prefetch configuration; H6/H616 keep
the existing behaviour.
---
 drivers/iommu/sun50i-iommu.c | 86 +++++++++++++++++++++++++++++++-----
 1 file changed, 74 insertions(+), 12 deletions(-)

diff --speed-large-files --no-dereference --minimal -Naur linux-7.1.3/drivers/iommu/sun50i-iommu.c linux-7.1.3/drivers/iommu/sun50i-iommu.c
--- linux-7.1.3/drivers/iommu/sun50i-iommu.c	2026-07-06 13:20:48.235987590 +0200
+++ linux-7.1.3/drivers/iommu/sun50i-iommu.c	2026-07-06 13:20:01.188403528 +0200
@@ -19,6 +19,7 @@
 #include <linux/of_platform.h>
 #include <linux/platform_device.h>
 #include <linux/pm.h>
+#include <linux/property.h>
 #include <linux/pm_runtime.h>
 #include <linux/reset.h>
 #include <linux/sizes.h>
@@ -44,6 +45,12 @@
 #define IOMMU_TLB_ENABLE_REG		0x060
 #define IOMMU_TLB_PREFETCH_REG		0x070
 #define IOMMU_TLB_PREFETCH_MASTER_ENABLE(m)	BIT(m)
+/*
+ * Only prefetch valid pages into the TLB/PTW caches (bits present since
+ * the v14 revision of the IOMMU, e.g. A523; reserved/ignored on older
+ * revisions).
+ */
+#define IOMMU_TLB_PREFETCH_ONLY_VALID		(BIT(16) | BIT(17))
 
 #define IOMMU_TLB_FLUSH_REG		0x080
 #define IOMMU_TLB_FLUSH_PTW_CACHE		BIT(17)
@@ -97,12 +104,18 @@
 
 #define SPAGE_SIZE			4096
 
+struct sun50i_iommu_variant {
+	u32 tlb_prefetch;
+};
+
 struct sun50i_iommu {
 	struct iommu_device iommu;
 
 	/* Lock to modify the IOMMU registers */
 	spinlock_t iommu_lock;
 
+	const struct sun50i_iommu_variant *variant;
+
 	struct device *dev;
 	void __iomem *base;
 	struct reset_control *reset;
@@ -259,14 +272,26 @@
 #define SUN50I_PTE_ACI_MASK		GENMASK(7, 4)
 #define SUN50I_PTE_PAGE_VALID		BIT(1)
 
+/*
+ * The IOMMU's output address space is 32 bits wide, while DRAM starts at
+ * 0x40000000, so on 4 GiB boards the top gigabyte of DRAM lies above the
+ * 32-bit boundary. The interconnect aliases IOMMU-side output addresses
+ * 0x0 - 0x40000000 (a hole from the IOMMU's point of view, as no DRAM
+ * lives there) onto that high gigabyte, so leaf page addresses must be
+ * folded into the alias window when mapping and unfolded when resolving.
+ * The vendor driver applies the same transformation for this whole IOMMU
+ * generation ("iommu phy" vs "cpu phy" in their pagetable code).
+ */
+#define SUN50I_IOMMU_DRAM_BASE		0x40000000UL
+
 static phys_addr_t sun50i_pte_get_page_address(u32 pte)
 {
-	phys_addr_t paddr = pte & SUN50I_PTE_PAGE_ADDRESS_MASK;
+	phys_addr_t page = (phys_addr_t)pte & SUN50I_PTE_PAGE_ADDRESS_MASK;
 
-	if (paddr < PHYS_OFFSET)
-		paddr |= SZ_4G;
+	if (page < SUN50I_IOMMU_DRAM_BASE)
+		page += SZ_4G;
 
-	return paddr;
+	return page;
 }
 
 static enum sun50i_iommu_aci sun50i_get_pte_aci(u32 pte)
@@ -294,6 +319,8 @@
 		aci = SUN50I_IOMMU_ACI_NONE;
 
 	flags |= FIELD_PREP(SUN50I_PTE_ACI_MASK, aci);
+	if (page >= SZ_4G)
+		page -= SZ_4G;
 	page &= SUN50I_PTE_PAGE_ADDRESS_MASK;
 	return page | flags | SUN50I_PTE_PAGE_VALID;
 }
@@ -456,12 +483,7 @@
 
 	iommu_write(iommu, IOMMU_TTB_REG, sun50i_domain->dt_dma);
 	iommu_write(iommu, IOMMU_TLB_PREFETCH_REG,
-		    IOMMU_TLB_PREFETCH_MASTER_ENABLE(0) |
-		    IOMMU_TLB_PREFETCH_MASTER_ENABLE(1) |
-		    IOMMU_TLB_PREFETCH_MASTER_ENABLE(2) |
-		    IOMMU_TLB_PREFETCH_MASTER_ENABLE(3) |
-		    IOMMU_TLB_PREFETCH_MASTER_ENABLE(4) |
-		    IOMMU_TLB_PREFETCH_MASTER_ENABLE(5));
+		    iommu->variant->tlb_prefetch);
 	iommu_write(iommu, IOMMU_BYPASS_REG, 0);
 	iommu_write(iommu, IOMMU_INT_ENABLE_REG, IOMMU_INT_MASK);
 	iommu_write(iommu, IOMMU_DM_AUT_CTRL_REG(SUN50I_IOMMU_ACI_NONE),
@@ -1018,6 +1040,7 @@
 	iommu->domain = &sun50i_iommu_identity_domain;
 	platform_set_drvdata(pdev, iommu);
 	iommu->dev = &pdev->dev;
+	iommu->variant = device_get_match_data(&pdev->dev);
 
 	iommu->pt_pool = kmem_cache_create(dev_name(&pdev->dev),
 					   PT_SIZE, PT_SIZE,
@@ -1080,9 +1103,37 @@
 	return ret;
 }
 
+static const struct sun50i_iommu_variant sun50i_h6_variant = {
+	.tlb_prefetch = IOMMU_TLB_PREFETCH_MASTER_ENABLE(0) |
+			IOMMU_TLB_PREFETCH_MASTER_ENABLE(1) |
+			IOMMU_TLB_PREFETCH_MASTER_ENABLE(2) |
+			IOMMU_TLB_PREFETCH_MASTER_ENABLE(3) |
+			IOMMU_TLB_PREFETCH_MASTER_ENABLE(4) |
+			IOMMU_TLB_PREFETCH_MASTER_ENABLE(5),
+};
+
+/*
+ * The vendor driver ships the A523 with master prefetch disabled, citing a
+ * display-RCQ-related bug. Without prefetch, though, every micro-TLB miss
+ * stalls the DE fetch pipe and 4K scanout underruns to a dead screen (1080p
+ * survives). Enable prefetch together with the "only prefetch valid pages"
+ * bits new in this revision, which defuse prefetches of unmapped pages -
+ * the likely subject of the vendor's debugging.
+ */
+static const struct sun50i_iommu_variant sun55i_a523_variant = {
+	.tlb_prefetch = IOMMU_TLB_PREFETCH_MASTER_ENABLE(0) |
+			IOMMU_TLB_PREFETCH_MASTER_ENABLE(1) |
+			IOMMU_TLB_PREFETCH_MASTER_ENABLE(2) |
+			IOMMU_TLB_PREFETCH_MASTER_ENABLE(3) |
+			IOMMU_TLB_PREFETCH_MASTER_ENABLE(4) |
+			IOMMU_TLB_PREFETCH_MASTER_ENABLE(5) |
+			IOMMU_TLB_PREFETCH_ONLY_VALID,
+};
+
 static const struct of_device_id sun50i_iommu_dt[] = {
-	{ .compatible = "allwinner,sun50i-h6-iommu", },
-	{ .compatible = "allwinner,sun50i-h616-iommu", },
+	{ .compatible = "allwinner,sun50i-h6-iommu", .data = &sun50i_h6_variant },
+	{ .compatible = "allwinner,sun50i-h616-iommu", .data = &sun50i_h6_variant },
+	{ .compatible = "allwinner,sun55i-a523-iommu", .data = &sun55i_a523_variant },
 	{ /* sentinel */ },
 };
 MODULE_DEVICE_TABLE(of, sun50i_iommu_dt);
