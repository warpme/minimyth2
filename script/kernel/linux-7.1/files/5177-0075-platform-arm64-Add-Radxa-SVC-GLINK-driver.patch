+	svc->platform_profile_dev =
+		devm_platform_profile_register(svc->dev, "radxa_svc_glink",
+					       svc,
+					       &radxa_svc_platform_profile_ops);
+
+	return PTR_ERR_OR_ZERO(svc->platform_profile_dev);
+}
