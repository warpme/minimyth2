@@ -468,8 +639,12 @@ static void dw_hdmi_qp_rk3576_enc_init(struct rockchip_hdmi_qp *hdmi,
 				       struct rockchip_crtc_state *state)
 {
 	int color = dw_hdmi_qp_rockchip_bus_fmt_to_reg(state->bus_format);
