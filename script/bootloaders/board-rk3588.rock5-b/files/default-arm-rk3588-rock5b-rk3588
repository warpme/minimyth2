DEFAULT MiniMyth2
MENU TITLE Boot Menu
PROMPT 0
TIMEOUT 0

LABEL MiniMyth2
  LINUX /nfs-arm64-minimyth2-master-15.1.0.r214/boot/Image
  FDT   /nfs-arm64-minimyth2-master-15.1.0.r214/boot/dtbs/rockchip/rk3588-rock-5b.dtb

  # to overwrite edid add: drm.edid_firmware=edid/s2-tek.bin
  # to force hdmi instead of dvi add: video=HDMI-A-1:e

  # mount nfsroot with DHCP
  APPEND root=/dev/nfs nfsroot=192.168.1.254:/var/tftpboot/PXEclient/nfs-arm64-minimyth2-master-15.1.0.r214/rootfs,v3 ip=dhcp earlycon=uart8250,mmio32,0xfeb50000 console=ttyS2,1500000n8 debug

  # static ip (works only when uboot acquired ip is the same like declared static ip)
  # APPEND root=/dev/nfs nfsroot=192.168.1.254:/var/tftpboot/PXEclient/nfs-arm64-minimyth2-master-15.1.0.r214/rootfs,v3 ip=192.168.1.163:192.168.1.254:192.168.1.254:255.255.255.0:myth-frontend-56b0f018b5e0:eth0:off earlycon=uart8250,mmio32,0xfeb50000 console=ttyS2,1500000n8 debug
