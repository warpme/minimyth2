+static ssize_t radxa_svc_pwm_apply_write(struct file *file,
+					 const char __user *buf,
+					 size_t count, loff_t *ppos)
+{
+	struct radxa_svc_glink *svc = file->private_data;
+	struct radxa_svc_pwm_info_resp info = {};
+	struct radxa_svc_pwm_apply_req req;
+	char input[64];
+	u32 supported_mask;
+	u32 max_period_ns;
+	u32 min_period_ns;
+	size_t len;
+	u32 channel;
+	u32 enable;
+	u32 period_ns;
+	u32 duty_ns;
+	int ret;
+
+	len = min(count, sizeof(input) - 1);
+	if (copy_from_user(input, buf, len))
+		return -EFAULT;
+
+	input[len] = '\0';
+	if (sscanf(input, "%u %u %u %u", &channel, &enable, &period_ns,
+		   &duty_ns) != 4)
+		return -EINVAL;
+
+	if (enable > 1 || duty_ns > period_ns)
+		return -EINVAL;
+
+	ret = radxa_svc_pwm_get_info(svc, &info);
+	if (ret)
+		return ret;
+
+	supported_mask = le32_to_cpu(info.supported_mask);
+	min_period_ns = le32_to_cpu(info.min_period_ns);
+	max_period_ns = le32_to_cpu(info.max_period_ns);
+	if (channel >= 32 || !(supported_mask & BIT(channel)))
+		return -EINVAL;
+
+	if (period_ns < min_period_ns || period_ns > max_period_ns)
+		return -EINVAL;
+
+	req.channel = cpu_to_le32(channel);
+	req.enable = cpu_to_le32(enable);
+	req.period_ns = cpu_to_le32(period_ns);
+	req.duty_ns = cpu_to_le32(duty_ns);
+
+	ret = radxa_svc_request(svc, RADXA_SVC_OP_PWM_APPLY, &req,
+				sizeof(req), NULL, NULL);
+	if (ret)
+		return ret;
+
+	WRITE_ONCE(svc->pwm_channel, channel);
+
+	return count;
+}
