+#define RADXA_SVC_RO_FOPS(_name)						\
+static const struct file_operations radxa_svc_##_name##_fops = {		\
+	.owner = THIS_MODULE,							\
+	.open = radxa_svc_##_name##_open,					\
+	.read = seq_read,							\
