Developed-by: Piotr Oniszczuk <piotr.oniszczuk@gmail.com>
Signed-off-by: Piotr Oniszczuk <piotr.oniszczuk@gmail.com>



diff --speed-large-files --no-dereference --minimal -Naur linux-7.0-rc1/arch/arm64/boot/dts/broadcom/bcm2712.dtsi linux-7.0-rc1/arch/arm64/boot/dts/broadcom/bcm2712.dtsi
--- linux-7.0-rc1/arch/arm64/boot/dts/broadcom/bcm2712.dtsi	2026-02-22 22:18:59.000000000 +0100
+++ linux-7.0-rc1/arch/arm64/boot/dts/broadcom/bcm2712.dtsi	2026-03-04 14:48:18.109292819 +0100
@@ -646,6 +766,38 @@
 			msi-ranges = <&gicv2 GIC_SPI 247 IRQ_TYPE_EDGE_RISING 8>;
 			brcm,msi-offset = <8>;
 		};
+
+		v3d: v3d@2000000 {
+			#address-cells = <2>;
+			#size-cells = <2>;
+			compatible = "brcm,2712-v3d";
+			reg = <0x10 0x02000000  0x0 0x4000>,
+			      <0x10 0x02008000  0x0 0x6000>,
+			      <0x10 0x02030800  0x0 0x0700>;
+			reg-names = "hub", "core0", "sms";
+
+			power-domains = <&pm BCM2835_POWER_DOMAIN_GRAFX_V3D>;
+			resets = <&pm BCM2835_RESET_V3D>;
+			clocks = <&firmware_clocks 5>;
+			clocks-names = "v3d";
+			interrupts = <GIC_SPI 250 IRQ_TYPE_LEVEL_HIGH>,
+				     <GIC_SPI 249 IRQ_TYPE_LEVEL_HIGH>;
+			status = "okay";
+		};
+
+		rpivid: codec@800000 {
+			compatible = "raspberrypi,rpivid-vid-decoder";
+			reg = <0x10 0x00800000  0x0 0x10000>, /* HEVC */
+			      <0x10 0x00840000  0x0 0x1000>;  /* INTC */
+			reg-names = "hevc","intc";
+
+			interrupts = <GIC_SPI 98 IRQ_TYPE_LEVEL_HIGH>;
+
+			clocks = <&firmware_clocks 11>;
+			clock-names = "hevc";
+			//iommus = <&iommu2>;
+			status = "okay";
+		};
 	};
 
 	timer {
--

MiniMyth2

