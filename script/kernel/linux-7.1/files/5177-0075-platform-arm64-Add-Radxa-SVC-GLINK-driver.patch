+static int radxa_svc_ping_show(struct seq_file *s, void *unused)
+{
+	struct radxa_svc_glink *svc = s->private;
+	struct radxa_svc_ping_resp resp = {};
+	size_t len = sizeof(resp);
+	int ret;
+
+	ret = radxa_svc_request(svc, RADXA_SVC_OP_PING, NULL, 0, &resp, &len);
+	if (ret) {
+		seq_printf(s, "error: %d\n", ret);
+		return 0;
+	}
+
+	if (len < sizeof(resp) || le32_to_cpu(resp.pong) != RADXA_SVC_PONG) {
+		seq_puts(s, "error: invalid pong\n");
+		return 0;
+	}
+
+	seq_printf(s, "pong: ok\nversion: %u.%u\n",
+		   le16_to_cpu(resp.major), le16_to_cpu(resp.minor));
+
+	return 0;
+}
