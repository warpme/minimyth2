From abb58c6b6b9f223c02826bec93ee48977880ec88 Mon Sep 17 00:00:00 2001
From: Jiali Chen <chenjiali@radxa.com>
Date: Mon, 27 Apr 2026 18:10:44 +0800
Subject: [PATCH 235/309] firmware: qcom: scm: Allow QSEECOM for Radxa CM-Q64

Add "radxa,cm-q64" as compatible device for QSEECOM

This is required to get access to efivars and uefi boot loader support.

Signed-off-by: Jiali Chen <chenjiali@radxa.com>
---
 drivers/firmware/qcom/qcom_scm.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/drivers/firmware/qcom/qcom_scm.c b/drivers/firmware/qcom/qcom_scm.c
index d944d67b4..b53d9b7eb 100644
--- a/drivers/firmware/qcom/qcom_scm.c
+++ b/drivers/firmware/qcom/qcom_scm.c
@@ -2338,6 +2338,7 @@ static const struct of_device_id qcom_scm_qseecom_allowlist[] __maybe_unused = {
 	{ .compatible = "qcom,x1e80100-crd" },
 	{ .compatible = "qcom,x1e80100-qcp" },
 	{ .compatible = "qcom,x1p42100-crd" },
+	{ .compatible = "radxa,cm-q64" },
 	{ .compatible = "radxa,dragon-q6a" },
 	{ .compatible = "radxa,dragon-q8b" },
 	{ }
@@ -2604,6 +2605,7 @@ EXPORT_SYMBOL_GPL(qcom_scm_storage_send_cmd);
  */
 static const struct of_device_id qcom_scm_storage_allowlist[] = {
 	{ .compatible = "radxa,dragon-q6a" },
+	{ .compatible = "radxa,cm-q64" },
 	{ .compatible = "radxa,dragon-q8b" },
 	{ }
 };
