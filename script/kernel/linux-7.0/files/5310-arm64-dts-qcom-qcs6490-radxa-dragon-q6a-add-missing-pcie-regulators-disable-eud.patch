diff --speed-large-files --no-dereference --minimal -Naur linux-7.0.10/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dtsi linux-7.0.10/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dtsi
--- linux-7.0.10/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dtsi	2026-05-27 18:50:23.405426364 +0200
+++ linux-7.0.10/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dtsi	2026-05-27 18:44:40.069877008 +0200
@@ -574,6 +574,8 @@
 };
 
 &pcie0 {
+	vdda-supply = <&vreg_l1c_1p8>;
+	vddpe-3v3-supply = <&vreg_bob_3p296>;
 	perst-gpios = <&tlmm 87 GPIO_ACTIVE_LOW>;
 	wake-gpios = <&tlmm 89 GPIO_ACTIVE_HIGH>;
 
@@ -591,6 +593,8 @@
 };
 
 &pcie1 {
+	vdda-supply = <&vreg_l1c_1p8>;
+	vddpe-3v3-supply = <&vreg_bob_3p296>;
 	perst-gpios = <&tlmm 2 GPIO_ACTIVE_LOW>;
 	wake-gpios = <&tlmm 3 GPIO_ACTIVE_HIGH>;
 
@@ -618,6 +622,11 @@
 	status = "okay";
 };
 
+/* Disable EUD as it conflicts with USB operation */
+&eud {
+	status = "disabled";
+};
+
 &pm7325_gpios {
 	pm7325_adc_default: adc-default-state {
 		pins = "gpio2";
