From 1a317aea7d0e7bd433753b598d353b674521c01e Mon Sep 17 00:00:00 2001
From: Justin Suess <utilityemal77@gmail.com>
Date: Sat, 4 Jul 2026 16:17:24 -0400
Subject: [PATCH 10/14] drm/sun4i: sun8i_hdmi_phy: demote Inno PHY register
 dumps to dev_dbg

The bring-up register dumps and MPLL parameter prints are debugging
aids; stop emitting them at info level on every PHY init.
---
 drivers/gpu/drm/sun4i/sun8i_hdmi_phy.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/drivers/gpu/drm/sun4i/sun8i_hdmi_phy.c b/drivers/gpu/drm/sun4i/sun8i_hdmi_phy.c
index 606bd34b64d6..638a42c4ce19 100644
--- a/drivers/gpu/drm/sun4i/sun8i_hdmi_phy.c
+++ b/drivers/gpu/drm/sun4i/sun8i_hdmi_phy.c
@@ -897,7 +897,7 @@ static void sun55i_a523_inno_dump(struct sun8i_hdmi_phy *phy, const char *when)
 	fra = inno_rd32(phy, INNO_PLL_FRA);
 	dr0 = inno_rd32(phy, INNO_DR0);
 	rxs = inno_rd32(phy, INNO_RXSEN);
-	dev_info(phy->dev,
+	dev_dbg(phy->dev,
 		 "inno %s: ctl0=%08x pll0=%08x pll1=%08x pll2=%08x pll3=%08x fra=%08x dr0=%08x rxsen=%08x\n",
 		 when, ctl0, pll0, pll1, pll2, pll3, fra, dr0, rxs);
 }
@@ -1029,7 +1029,7 @@ static int sun55i_a523_hdmi_phy_init(struct dw_hdmi *hdmi, void *data,
 		dev_warn(phy->dev, "Inno PHY rxsense lock timeout\n");
 
 	sun55i_a523_inno_dump(phy, "post-rxsense");
-	dev_info(phy->dev, "inno: tmds=%ukHz mpll prepll_div=%08x clkdiv=%08x postpll=%08x\n",
+	dev_dbg(phy->dev, "inno: tmds=%ukHz mpll prepll_div=%08x clkdiv=%08x postpll=%08x\n",
 		 tmds_khz, mpll->prepll_div, mpll->prepll_clk_div, mpll->postpll);
 
 	sun55i_a523_inno_mpll_config(phy, mpll);
-- 
2.54.0

