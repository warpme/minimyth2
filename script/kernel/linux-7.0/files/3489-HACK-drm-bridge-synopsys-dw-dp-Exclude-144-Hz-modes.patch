From 317b2e0c5a1d9bf8cb5de8c26c587ae619ad5e76 Mon Sep 17 00:00:00 2001
From: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
Date: Sun, 9 Nov 2025 22:16:47 +0200
Subject: [PATCH 077/114] [HACK] drm/bridge: synopsys: dw-dp: Exclude 144 Hz
 modes

Display modes having 144 Hz vertical refresh rate do not seem to work on
ROCK 5B when making use of the USB-C DP AltMode, most likely because of
some clock related issues.

Filter out these modes for now.

Signed-off-by: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
---
 drivers/gpu/drm/bridge/synopsys/dw-dp.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/drivers/gpu/drm/bridge/synopsys/dw-dp.c b/drivers/gpu/drm/bridge/synopsys/dw-dp.c
index e7bef9150f..21d34e1fb1 100644
--- a/drivers/gpu/drm/bridge/synopsys/dw-dp.c
+++ b/drivers/gpu/drm/bridge/synopsys/dw-dp.c
@@ -1592,6 +1592,9 @@ static enum drm_mode_status dw_dp_bridge_mode_valid(struct drm_bridge *bridge,
 	if (!dw_dp_bandwidth_ok(dp, mode, min_bpp, link->lanes, link->rate))
 		return MODE_CLOCK_HIGH;
 
+	if (drm_mode_vrefresh(mode) == 144)
+		return MODE_BAD;
+
 	return MODE_OK;
 }
 
