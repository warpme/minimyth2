diff --speed-large-files --no-dereference --minimal -Naur linux-7.0-rc3/arch/arm64/boot/dts/rockchip/rk3399-base.dtsi linux-7.0-rc3/arch/arm64/boot/dts/rockchip/rk3399-base.dtsi
--- linux-7.0-rc3/arch/arm64/boot/dts/rockchip/rk3399-base.dtsi	2026-03-13 11:27:02.091415626 +0100
+++ linux-7.0-rc3/arch/arm64/boot/dts/rockchip/rk3399-base.dtsi	2026-03-13 11:22:49.889783817 +0100
@@ -544,7 +544,7 @@
 		status = "disabled";
 
 		usbdrd_dwc3_0: usb@fe800000 {
-			compatible = "snps,dwc3";
+			compatible = "snps,dwc3", "snps,dwc3-simple";
 			reg = <0x0 0xfe800000 0x0 0x100000>;
 			interrupts = <GIC_SPI 105 IRQ_TYPE_LEVEL_HIGH 0>;
 			clocks = <&cru SCLK_USB3OTG0_REF>, <&cru ACLK_USB3OTG0>,
@@ -580,7 +580,7 @@
 		status = "disabled";
 
 		usbdrd_dwc3_1: usb@fe900000 {
-			compatible = "snps,dwc3";
+			compatible = "snps,dwc3", "snps,dwc3-simple";
 			reg = <0x0 0xfe900000 0x0 0x100000>;
 			interrupts = <GIC_SPI 110 IRQ_TYPE_LEVEL_HIGH 0>;
 			clocks = <&cru SCLK_USB3OTG1_REF>, <&cru ACLK_USB3OTG1>,
