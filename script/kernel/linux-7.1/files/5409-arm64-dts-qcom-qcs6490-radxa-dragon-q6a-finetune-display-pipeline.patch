diff --speed-large-files --no-dereference --minimal -Naur linux-7.0.10/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dtsi linux-7.0.10/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dtsi
--- linux-7.0.10/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dtsi	2026-05-27 18:29:25.779710860 +0200
+++ linux-7.0.10/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dtsi	2026-05-27 18:10:17.728620368 +0200
@@ -920,6 +920,12 @@
 		bias-pull-up;
 	};
 
+	dp_hot_plug_det: dp-hot-plug-det-state {
+		pins = "gpio47";
+		function = "dp_hot";
+		bias-disable;
+	};
+
 	sd_cd: sd-cd-state {
 		pins = "gpio91";
 		function = "gpio";
@@ -1133,3 +1139,35 @@
 	bias-pull-up;
 	drive-strength = <10>;
 };
+
+&mdss_dsi {
+	status = "disabled";
+};
+
+&mdss_dsi_phy {
+	status = "disabled";
+};
+
+&mdss_edp {
+	status = "disabled";
+};
+
+&mdss_edp_phy {
+	status = "disabled";
+};
+
+&gpucc {
+	status = "okay";
+};
+
+&gmu {
+	status = "okay";
+};
+
+&dispcc {
+	status = "okay";
+};
+
+&mdss {
+	status = "okay";
+};
