From 45e5cbdc9178bf2f08ff7dad7adf3717aa947e31 Mon Sep 17 00:00:00 2001
From: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
Date: Tue, 17 Mar 2026 22:42:11 +0200
Subject: [PATCH 113/114] [WIP-FRL] drm/bridge: dw-hdmi-qp: Drop audio TMDS EoT
 markers

Make use of the ARRAY_SIZE() macro when iterating the audio TMDS tables
which allows getting rid of their last entry serving as a marker.

Signed-off-by: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
---
 drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c | 10 ++--------
 1 file changed, 2 insertions(+), 8 deletions(-)

diff --git a/drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c b/drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c
index df027e41ea..5c4759c9a4 100644
--- a/drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c
+++ b/drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c
@@ -121,9 +121,6 @@ static const struct dw_hdmi_audio_tmds_n {
 	/* For 297 MHz+ HDMI spec have some other rule for setting N */
 	{ .tmds = 297000000, .n_32k = 3073,  .n_44k1 = 4704,  .n_48k = 5120, },
 	{ .tmds = 594000000, .n_32k = 3073,  .n_44k1 = 9408,  .n_48k = 10240,},
-
-	/* End of table */
-	{ .tmds = 0,         .n_32k = 0,     .n_44k1 = 0,     .n_48k = 0,    },
 };
 
 /*
@@ -142,9 +139,6 @@ static const struct dw_hdmi_audio_tmds_cts {
 	{ .tmds = 54000000,  .cts_32k = 54000,  .cts_44k1 = 60000,  .cts_48k = 54000,  },
 	{ .tmds = 74250000,  .cts_32k = 74250,  .cts_44k1 = 82500,  .cts_48k = 74250,  },
 	{ .tmds = 148500000, .cts_32k = 148500, .cts_44k1 = 165000, .cts_48k = 148500, },
-
-	/* End of table */
-	{ .tmds = 0,         .cts_32k = 0,      .cts_44k1 = 0,      .cts_48k = 0,      },
 };
 
 struct dw_hdmi_qp_i2c {
@@ -297,7 +291,7 @@ static int dw_hdmi_qp_match_tmds_n_table(struct dw_hdmi_qp *hdmi,
 	const struct dw_hdmi_audio_tmds_n *tmds_n = NULL;
 	int i;
 
-	for (i = 0; common_tmds_n_table[i].tmds != 0; i++) {
+	for (i = 0; i < ARRAY_SIZE(common_tmds_n_table); i++) {
 		if (pixel_clk == common_tmds_n_table[i].tmds) {
 			tmds_n = &common_tmds_n_table[i];
 			break;
@@ -397,7 +391,7 @@ static unsigned int dw_hdmi_qp_find_cts(struct dw_hdmi_qp *hdmi, unsigned long p
 	const struct dw_hdmi_audio_tmds_cts *tmds_cts = NULL;
 	int i;
 
-	for (i = 0; common_tmds_cts_table[i].tmds != 0; i++) {
+	for (i = 0; i < ARRAY_SIZE(common_tmds_cts_table); i++) {
 		if (pixel_clk == common_tmds_cts_table[i].tmds) {
 			tmds_cts = &common_tmds_cts_table[i];
 			break;
-- 
2.53.0

