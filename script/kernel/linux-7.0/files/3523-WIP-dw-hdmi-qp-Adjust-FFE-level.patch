 		usleep_range(400, 500);
@@ -974,25 +975,20 @@ static int dw_hdmi_qp_flt_lts3(struct dw_hdmi_qp *hdmi)
 				dev_dbg(hdmi->dev, "lts3: enter test mode\n");
 				hdmi->flt_no_timeout = true;
 			}
-		}
 
-		if (!(val & SCDC_CONFIG_0)) {
-			if (val & SCDC_SOURCE_TEST_UPDATE) {
-				/* Clear SOURCE_TEST_UPDATE flag */
-				ret = drm_scdc_writeb(hdmi->bridge.ddc, SCDC_UPDATE_0, val);
-				if (ret) {
-					dev_err(hdmi->dev, "lts3: SCDC write failed\n");
-					return LTSL;
-				}
