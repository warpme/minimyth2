+	seq_printf(s, "fault_count: %u\n", le32_to_cpu(resp.fault_count));
+	seq_printf(s, "last_status: %d\n", last_status);
+	if (len >= sizeof(resp)) {
+		seq_printf(s, "control_mode: %u\n",
