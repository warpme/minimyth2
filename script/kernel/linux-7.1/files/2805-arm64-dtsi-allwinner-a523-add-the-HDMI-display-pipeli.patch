From 4f6bc8c5b47a775e7067dc6eded9704a4b9a8739 Mon Sep 17 00:00:00 2001
From: Justin Suess <utilityemal77@gmail.com>
Date: Mon, 29 Jun 2026 17:36:55 -0400
Subject: [PATCH 05/14] arm64: dts: allwinner: a523: add the HDMI display
 pipeline

Add the DE33 display pipeline for the A523/H728: the display-engine
node, the DE33 bus (display clocks + mixer0), TCON-TOP, TCON-TV0, the
DW-HDMI controller and the Inno HDMI PHY, plus the DE SRAM section in the
system-control block.

Most nodes reuse the H6/H616 drivers via compatible fallbacks; only the
A523 HDMI controller, HDMI PHY and the new CLK_HDMI TMDS clock are
A523-specific. The pipeline is left disabled here and enabled per-board.
---
 .../arm64/boot/dts/allwinner/sun55i-a523.dtsi | 211 ++++++++++++++++++
 1 file changed, 211 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
index ca6a16807049..770d7f86a0f5 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
@@ -3,6 +3,9 @@
 
 #include <dt-bindings/interrupt-controller/arm-gic.h>
 #include <dt-bindings/clock/sun6i-rtc.h>
+#include <dt-bindings/clock/sun8i-de2.h>
+#include <dt-bindings/clock/sun8i-tcon-top.h>
+#include <dt-bindings/reset/sun8i-de2.h>
 #include <dt-bindings/clock/sun55i-a523-ccu.h>
 #include <dt-bindings/clock/sun55i-a523-mcu-ccu.h>
 #include <dt-bindings/clock/sun55i-a523-r-ccu.h>
@@ -17,6 +20,12 @@ / {
 	#address-cells = <2>;
 	#size-cells = <2>;
 
+	de: display-engine {
+		compatible = "allwinner,sun50i-h6-display-engine";
+		allwinner,pipelines = <&mixer0>;
+		status = "disabled";
+	};
+
 	cpus {
 		#address-cells = <1>;
 		#size-cells = <0>;
@@ -126,6 +135,201 @@ gpu: gpu@1800000 {
 			status = "disabled";
 		};
 
+		/*
+		 * Display pipeline (DE33 -> TCON-TOP -> TCON-TV -> DW-HDMI ->
+		 * Inno HDMI PHY). Addresses from the vendor DTB; HDMI PHY split
+		 * (controller@5520000 + phy@5530000) and the DE SRAM region are
+		 * best-guesses pending hardware verification. Most nodes reuse
+		 * the H6/H616 drivers via compatible fallbacks; only CLK_HDMI
+		 * (TMDS) and the hdmi-phy variant were added for the A523.
+		 */
+		bus@5000000 {
+			compatible = "allwinner,sun50i-h616-de33",
+				     "allwinner,sun50i-a64-de2";
+			reg = <0x5000000 0x400000>;
+			allwinner,sram = <&de_sram 1>;
+			#address-cells = <1>;
+			#size-cells = <1>;
+			ranges = <0 0x5000000 0x400000>;
+
+			display_clocks: clock@8000 {
+				compatible = "allwinner,sun50i-h616-de33-clk";
+				reg = <0x8000 0x100>;
+				clocks = <&ccu CLK_DE>, <&ccu CLK_BUS_DE>;
+				clock-names = "mod", "bus";
+				resets = <&ccu RST_BUS_DE>;
+				power-domains = <&pck600 PD_DE>;
+				#clock-cells = <1>;
+				#reset-cells = <1>;
+			};
+
+			mixer0: mixer@100000 {
+				compatible = "allwinner,sun55i-a523-de33-mixer-0";
+				reg = <0x100000 0x100000>,
+				      <0x8100 0x40>,
+				      <0x280000 0x20000>,
+				      <0x8000 0x60>;
+				reg-names = "engine", "top", "display", "detop";
+				clocks = <&display_clocks CLK_BUS_MIXER0>,
+					 <&display_clocks CLK_MIXER0>;
+				clock-names = "bus", "mod";
+				resets = <&display_clocks RST_MIXER0>;
+				power-domains = <&pck600 PD_DE>;
+
+				ports {
+					#address-cells = <1>;
+					#size-cells = <0>;
+
+					mixer0_out: port@1 {
+						reg = <1>;
+
+						mixer0_out_tcon_top_mixer0: endpoint {
+							remote-endpoint = <&tcon_top_mixer0_in_mixer0>;
+						};
+					};
+				};
+			};
+		};
+
+		tcon_top: tcon-top@5500000 {
+			compatible = "allwinner,sun50i-h6-tcon-top";
+			reg = <0x5500000 0x1000>;
+			clocks = <&ccu CLK_BUS_DISPLAY0_TOP>,
+				 <&ccu CLK_TCON_TV0>;
+			clock-names = "bus", "tcon-tv0";
+			clock-output-names = "tcon-top-tv0";
+			resets = <&ccu RST_BUS_DISPLAY0_TOP>;
+			#clock-cells = <1>;
+
+			ports {
+				#address-cells = <1>;
+				#size-cells = <0>;
+
+				tcon_top_mixer0_in: port@0 {
+					#address-cells = <1>;
+					#size-cells = <0>;
+					reg = <0>;
+
+					tcon_top_mixer0_in_mixer0: endpoint@0 {
+						reg = <0>;
+						remote-endpoint = <&mixer0_out_tcon_top_mixer0>;
+					};
+				};
+
+				tcon_top_mixer0_out: port@1 {
+					#address-cells = <1>;
+					#size-cells = <0>;
+					reg = <1>;
+
+					tcon_top_mixer0_out_tcon_tv0: endpoint@2 {
+						reg = <2>;
+						remote-endpoint = <&tcon_tv0_in_tcon_top_mixer0>;
+					};
+				};
+
+				tcon_top_hdmi_in: port@4 {
+					#address-cells = <1>;
+					#size-cells = <0>;
+					reg = <4>;
+
+					tcon_top_hdmi_in_tcon_tv0: endpoint@0 {
+						reg = <0>;
+						remote-endpoint = <&tcon_tv0_out_tcon_top>;
+					};
+				};
+
+				tcon_top_hdmi_out: port@5 {
+					reg = <5>;
+
+					tcon_top_hdmi_out_hdmi: endpoint {
+						remote-endpoint = <&hdmi_in_tcon_top>;
+					};
+				};
+			};
+		};
+
+		tcon_tv0: lcd-controller@5503000 {
+			compatible = "allwinner,sun50i-h6-tcon-tv",
+				     "allwinner,sun8i-r40-tcon-tv";
+			reg = <0x5503000 0x1000>;
+			interrupts = <GIC_SPI 91 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&ccu CLK_BUS_TCON_TV0>,
+				 <&tcon_top CLK_TCON_TOP_TV0>;
+			clock-names = "ahb", "tcon-ch1";
+			resets = <&ccu RST_BUS_TCON_TV0>;
+			reset-names = "lcd";
+
+			ports {
+				#address-cells = <1>;
+				#size-cells = <0>;
+
+				tcon_tv0_in: port@0 {
+					reg = <0>;
+
+					tcon_tv0_in_tcon_top_mixer0: endpoint {
+						remote-endpoint = <&tcon_top_mixer0_out_tcon_tv0>;
+					};
+				};
+
+				tcon_tv0_out: port@1 {
+					#address-cells = <1>;
+					#size-cells = <0>;
+					reg = <1>;
+
+					tcon_tv0_out_tcon_top: endpoint@1 {
+						reg = <1>;
+						remote-endpoint = <&tcon_top_hdmi_in_tcon_tv0>;
+					};
+				};
+			};
+		};
+
+		hdmi: hdmi@5520000 {
+			compatible = "allwinner,sun55i-a523-dw-hdmi",
+				     "allwinner,sun50i-h6-dw-hdmi";
+			reg = <0x5520000 0x10000>;
+			reg-io-width = <1>;
+			interrupts = <GIC_SPI 93 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&ccu CLK_BUS_HDMI>, <&ccu CLK_HDMI_24M>,
+				 <&ccu CLK_HDMI>, <&ccu CLK_HDMI_CEC>;
+			clock-names = "iahb", "isfr", "tmds", "cec";
+			resets = <&ccu RST_BUS_HDMI_MAIN>;
+			reset-names = "ctrl";
+			power-domains = <&pck600 PD_VO0>;
+			phys = <&hdmi_phy>;
+			phy-names = "phy";
+			status = "disabled";
+
+			ports {
+				#address-cells = <1>;
+				#size-cells = <0>;
+
+				hdmi_in: port@0 {
+					reg = <0>;
+
+					hdmi_in_tcon_top: endpoint {
+						remote-endpoint = <&tcon_top_hdmi_out_hdmi>;
+					};
+				};
+
+				hdmi_out: port@1 {
+					reg = <1>;
+				};
+			};
+		};
+
+		hdmi_phy: hdmi-phy@5530000 {
+			compatible = "allwinner,sun55i-a523-hdmi-phy",
+				     "allwinner,sun50i-h616-hdmi-phy";
+			reg = <0x5530000 0x10000>;
+			clocks = <&ccu CLK_BUS_HDMI>, <&ccu CLK_HDMI_24M>;
+			clock-names = "bus", "mod";
+			resets = <&ccu RST_BUS_HDMI_SUB>;
+			reset-names = "phy";
+			power-domains = <&pck600 PD_VO0>;
+			#phy-cells = <0>;
+		};
+
 		pio: pinctrl@2000000 {
 			compatible = "allwinner,sun55i-a523-pinctrl";
 			reg = <0x2000000 0x800>;
@@ -565,6 +769,13 @@ syscon: syscon@3000000 {
 			#address-cells = <1>;
 			#size-cells = <1>;
 			ranges;
+
+			/* DE (display engine) SRAM region claimed by the DE33 bus */
+			de_sram: sram-section@0 {
+				compatible = "allwinner,sun50i-h616-sram-c",
+					     "allwinner,sun50i-a64-sram-c";
+				reg = <0x0000 0x1e000>;
+			};
 		};
 
 		dma: dma-controller@3002000 {
-- 
2.54.0

