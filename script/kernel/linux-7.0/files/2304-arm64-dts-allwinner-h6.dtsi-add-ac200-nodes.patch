@@ -319,6 +329,10 @@
 			cpu_speed_grade: cpu-speed-grade@1c {
 				reg = <0x1c 0x4>;
 			};
+
+			ephy_calib: ephy_calib@2c {
+				reg = <0x2c 0x2>;
+			};
 		};
 
 		timer@3009000 {
@@ -373,6 +387,13 @@
 				drive-strength = <40>;
 			};
 
