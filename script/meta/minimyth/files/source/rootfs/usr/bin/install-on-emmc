#!/bin/sh

# Script is part of MiniMyth2/MiniArch project.
#
# Developed-by: Piotr Oniszczuk <piotr.oniszczuk@gmail.com>
# Signed-off-by: Piotr Oniszczuk <piotr.oniszczuk@gmail.com>

# Script works following commands:
#
#  install: will install from SDcard or eMMC to UFS/USB or NVME
#
#  erase: will erase target by 'dd' zeros to first 1G of target
#
#  erasespi: will erase SPI device
#
#  bootloader: will install bootloader files to target
#
#  spibootloader: will install SPI variant of bootloader to SPI device
#


# area at target device begininng filled with zeros to make it erased. In MBytes.
erase_areas_size=1024

swap_size="4096"

# script log file
log_file="/var/log/install-on-emmc.log"

#-----------------------------










































ver=7.0

command=$1

working_dir="/mnt/.install-on-emmc"

boot_src="${working_dir}/src-BOOT"
root_src="${working_dir}/src-ROOT"
boot_dst="${working_dir}/dst-BOOT"
root_dst="${working_dir}/dst-ROOT"

req_bin_list="\
  awk \
  blkid \
  blockdev \
  cp \
  dd \
  echo \
  flashcp \
  lsblk \
  mkdir \
  mount \
  mtdinfo \
  mkfs.ext2 \
  mkfs.vfat \
  mkswap \
  partprobe \
  touch \
  tr \
  sed \
  sfdisk \
  sleep \
  sync \
"

trap "_exit_" 0 1 2 3 9 15

_exit_() {
    log "Exit cleanups ..."
    clean_working_env
}

log() {
    echo >&2 "`date '+%H:%M:%S'`: $*" >> ${log_file}
}

msg() {
    log "$*"
    echo "==> $*"
}

error() {
    log "$*"
    echo "$*"
    echo " "
    echo "Please provide content of ${log_file} to developer ..."
    echo "Now exiting ..."
    echo " "
    echo " "
    echo " Press any key to see log ..."
    read $sel
    echo "-------------- Here is content of install-on-emmc.log -------"
    cat ${log_file}
    echo "-------------- End content of install-on-emmc.log -----------"
    exit 1
}

do_cmd() {
    log "Executing $*"

    "$@" >> ${log_file} 2>&1

    if [ $? -ne 0 ] ; then
        if [ "${do_cmd_ignore_errors}" = "yes" ] ; then
            echo " "
            msg "Executing "$@" failed ..."
            do_cmd_ignore_errors="no"
        else
            echo " "
            error "Executing "$@" failed ..."
        fi
    fi
}

check_return_code() {
    if [ $? -ne 0 ] ; then
        echo " "
        error "Executing above command failed ..."
    fi
}

confirm() {

    echo " "
    echo "Please confirm $1 by pressing 'y'"
    echo "or press Enter (or any other key) to exit ..."
    echo " "

    read sel

    if [ "$sel" = "y" ] || [ "$sel" = "Y" ] ; then
        return
    else
        _exit_

        echo " "
        echo "Exiting stript (by user no-confirm)"
        echo " "
        exit 0
    fi
}

clean_working_env() {
    log "clean working enviroment ..."
    umount_all_partitions
    rmdir -p ${src-BOOT} ${src-ROOT} ${dst-BOOT} ${dst-ROOT} 2>/dev/null
    do_cmd lsblk
    do_cmd blkid
    do_cmd mount
    log "clean working enviroment done!"
}

check_prereq() {
    for bin in ${req_bin_list} ; do
        which ${bin} >/dev/null 2>&1
        if [ $? -eq 0 ] ; then
            log "  found ${bin} Good ..."
        else
            error "failed to find '$bin' binary. Pls install '$bin' by appropriate package!"
        fi
    done
    log "all checks done ..."
}

part_prefix() {
    if [[ ${1} =~ "mmcblk" ]] || [[ ${1} =~ "nvme" ]] ; then
        echo "p"
    else
        echo""
    fi
}

mount_partition() {
    # first param: dev e.g. mmcblk1
    # second param: part no e.g. 1, 2, 3
    # thirt param: dir to mount

    local dev=$1
    local part_num=$2
    local dir=$3

    if [ "$(mount -v | grep -c ${dir})" = "0" ]; then
        log "Mounting ${dev},part${part_num} at [${dir}] ..."
        local prefix=$(part_prefix ${dev})
        do_cmd mkdir -p ${dir}
        do_cmd mount ${dev}${prefix}${part_num} ${dir}
    else
        log "${dev},part${part_num} already mounted on [${dir}] ..."
    fi
}

umount_partition() {
    local part=$1
    if [ "$(mount -v | grep -c ${part})" = "0" ]; then
        log "Partition ${part} is not mounted ..."
        return 0
    else
        while [ "$(mount -v | grep -c ${part})" != "0" ]; do
            log "Unmounting [${part}] ..."
            umount -q ${part}
            if [ "$(mount -v | grep -c ${part})" = "0" ]; then
                log "Partition ${part} unmounted ..."
                break
            fi
            sleep 1
        done
    fi
}

partition_2part_mbr_then_format() {

    local disk=$1
    local prefix

    prefix=$(part_prefix $1)

    umount_partition ${disk}${prefix}1
    umount_partition ${disk}${prefix}2

    msg "Partitioning ${target_dev_name} (${disk}) with 3 MBR partitions ..."

    sfdisk "${disk}" >> ${log_file} 2>&1 <<EOF
label: dos
32768,512M,c,-
,$(( $(blockdev --getsize64 ${disk}) / 1024 - ((${swap_size} + 512) * 1024) ))KiB,83,-
1081344,,82,-
EOF
    check_return_code

    sleep 1

    msg "Partprobing ${disk} ..."
    do_cmd partprobe ${disk}

    msg "Formating partition 1 (FAT32) ..."
    if [ ${target_dev} = ${emmc_dev} ] ; then
        #for eMMC label as 'BOOT' as MiniMyth2 mounts this part by label
        do_cmd mkfs.vfat -F 32 -n BOOT ${disk}${prefix}1
    else
        do_cmd mkfs.vfat -F 32 -n BOOT-${target_dev_name} ${disk}${prefix}1
    fi

    msg "Formating partition 2 (EXT2) ..."
    do_cmd mkfs.ext2 -L ROOT-${target_dev_name} ${disk}${prefix}2

    msg "Formating partition 3 (SWAP) ..."
    do_cmd mkswap -L SWAP-${target_dev_name} ${disk}${prefix}3

    log "Formated ${disk} layout ..."
    do_cmd lsblk ${disk}
}

is_booted_from() {
    if [ "${boot_dev}" = "${1}" ] ; then
        if [ "${skip_check_is_booted_from}" = "yes" ] ; then
           return 1
        else
           return 0
        fi
    else
        return 1
    fi
}

what_platform() {

    if [ ! -e /sys/firmware/devicetree/base/compatible ] ; then
        error "No [/sys/firmware/devicetree/base/compatible] sysfs dir to identify Your platfrom ..."
    fi

    platform=$(tr -d '\0' < /sys/firmware/devicetree/base/compatible 2>/dev/null)
    log "platform string: ${platform}"
    echo "Ooo...you are running ${platform}"

    if [[ ${platform} =~ "allwinner" ]] ; then
        echo "Allwinner detected...Good!"
        platform_type="allwinner"

    elif [[ "${platform}" =~ "rk3328" ]] ; then
        echo "Rockchip 3328 detected..Good!"
        platform_type="rk3328"

    elif [[ "${platform}" =~ "rk3399" ]] ; then
        echo "Rockchip 3399 detected...Good!"
        platform_type="rk3399"

    elif [[ "${platform}" =~ "rk3528" ]] ; then
        echo "Rockchip 3528 detected..Good!"
        platform_type="rk3528"

    elif [[ "${platform}" =~ "sbc-with-5-partitions-layout" ]] ; then
        echo "Rockchip 3566/3568 (alt part.scheme) detected...Good!"
        platform_type="rk3568alt"

    elif [[ "${platform}" =~ "rk356" ]] ; then
        echo "Rockchip 3566/3568 detected...Good!"
        platform_type="rk3568"

    elif [[ "${platform}" =~ "rk3576" ]] ; then
        echo "Rockchip 3576 detected...Good!"
        platform_type="rk3576"

    elif [[ "${platform}" =~ "rk3588" ]] ; then
        echo "Rockchip 3588 detected...Good!"
        platform_type="rk3588"

    elif [[ "${platform}" =~ "amlogic" ]] ; then
        echo "Rpi detected... Bad... as it is unsupported!"
        platform_type="unsupported"

    elif [[ "${platform}" =~ "raspberrypi" ]] ; then
        echo "Rpi detected... Bad... as it is unsupported!"
        platform_type="unsupported"

    else
        echo "Unknown platform ..."
        platform_type="unsupported"
    fi
}

mount_source_partitions() {
    mount_partition /dev/${source_dev} 1 ${boot_src}
    mount_partition /dev/${source_dev} 2 ${root_src}
}

umount_all_partitions() {
    umount_partition ${boot_src}
    umount_partition ${root_src}
    umount_partition ${boot_dst}
    umount_partition ${root_dst}
}

copy_rootfs_use_rsync() {
    local source_dir="${1}"
    local target_dir="${2}"

    do_cmd rsync -a -x -v -A -X \
    --exclude='/dev/' \
    --exclude='/proc/' \
    --exclude='/sys/' \
    --exclude='/tmp/' \
    --exclude='/run/' \
    --exclude='/mnt/' \
    --exclude='/media/*' \
    --exclude='/lost+found' \
    ${source_dir} ${target_dir}
}

copy_rootfs_use_cp() {
    local source_dir="${1}"
    local target_dir="${2}"

    if [ -e "${source_dir}/rootfs-ro" ] ; then
        msg "Copying rootfs in MiniMyth2 variant ..."
        log "copy rootfs from [${source_dir}] to [${target_dir}] in MiniMyth2 variant ..."
        do_cmd cp -af ${source_dir}/* ${target_dir}/
        do_cmd sync
    else
        msg "Copying rootfs in MiniArch variant ..."
        log "copy rootfs from [${source_dir}] to [${target_dir}] in MiniArch variant ..."
        do_cmd cp -af ${source_dir}/bin* ${target_dir}/
        # boot
        # dev
        do_cmd cp -af ${source_dir}/etc* ${target_dir}/
        do_cmd cp -af ${source_dir}/home* ${target_dir}/
        do_cmd cp -af ${source_dir}/lib* ${target_dir}/
        # mnt
        do_cmd cp -af ${source_dir}/opt* ${target_dir}/
        # proc
        do_cmd cp -af ${source_dir}/root* ${target_dir}/
        # run
        do_cmd cp -af ${source_dir}/sbin* ${target_dir}/
        do_cmd cp -af ${source_dir}/srv* ${target_dir}/
        # sys
        # tmp
        do_cmd cp -af ${source_dir}/usr* ${target_dir}/
        #ignoring cp errors on /var as there are some files where perm can't be changed
        #and 'cp -af' reports error on them
        cp -af ${source_dir}/var* ${target_dir}/ 2>/dev/null
        do_cmd sync
    fi
}

copy_sdcard_to_1part_gpt_disk() {

    mount_source_partitions

    mount_partition /dev/${target_dev} 1 ${root_dst}

    do_cmd lsblk

    copy_rootfs_use_cp ${root_src} ${root_dst}

    msg "Copying boot data to target disk ..."
    do_cmd mkdir -p ${root_dst}/boot
    do_cmd cp -af ${boot_src}/* ${root_dst}/boot/
    do_cmd sync
}

copy_sdcard_to_2part_mbr_disk() {

    mount_source_partitions

    mount_partition /dev/${target_dev} 1 ${boot_dst}
    mount_partition /dev/${target_dev} 2 ${root_dst}

    do_cmd lsblk

    copy_rootfs_use_cp ${root_src} ${root_dst}

    msg "Copying boot data to target disk ..."
    do_cmd cp -af ${boot_src}/* ${boot_dst}/
    do_cmd sync
}

copy_sdcard_to_3part_gpt_disk() {

    mount_source_partitions

    mount_partition /dev/${target_dev} 3 ${root_dst}

    do_cmd lsblk

    copy_rootfs_use_cp ${root_src} ${root_dst}

    msg "Copying boot data to target disk ..."
    do_cmd mkdir -p ${root_dst}/boot
    do_cmd cp -af ${boot_src}/* ${root_dst}/boot/
    do_cmd sync
}

update_extlinux_conf() {

    local dev=$2
    local part_num=$3
    local prefix=$(part_prefix ${dev})

    msg "Updating extlinux.conf with root=${dev}${prefix}${part_num} ..."
    log "Updating root= in extlinux.conf on [${1}] to ${dev}${prefix}${part_num} ..."
    do_cmd sed \
    -e "s|mmcblk[0-9]p[0-9]|${dev}${prefix}${part_num}|g" \
    -e "s|sd[a-z][0-9]|${dev}${prefix}${part_num}|g" \
    -e "s|nvme[0-9]n[0-9]p[0-9]|${dev}${prefix}${part_num}|g" \
    -i ${1}/extlinux/extlinux.conf
}

erase_target() {

    dev=${1}

    msg "Erasing ${dev} ..."
    do_cmd dd if=/dev/zero of=/dev/${dev} bs=1M count=${erase_areas_size} conv=fsync
}

erase_bootloader() {

    msg "Erasing bootloader ..."
    do_cmd dd if=/dev/zero of=/tmp/file_with_zeros count=2048 conv=fsync

    write_target_bootX 0 "/tmp/file_with_zeros"
    write_target_bootX 1 "/tmp/file_with_zeros"

    do_cmd rm -f /tmp/file_with_zeros

    do_cmd sync
}

write_target_bootX() {

    # 1 param: bootX id
    # 2 param: blob to write

    if [ -e "/sys/block/${target_dev}boot$1" ] ; then

        msg "Executing echo 0 > /sys/block/${target_dev}boot$1/force_ro"
        do_cmd echo 0 > /sys/block/${target_dev}boot$1/force_ro

        write_target=/dev/${target_dev}boot$1

    else
        msg "  no eMMC ${target_dev}boot$1 part found. Skiping ..."
        return 1
    fi

    msg "Zeroing ${write_target} ..."
    dd if=/dev/zero of=${write_target} count=2048 conv=fsync 2>/dev/null

    msg "Writing $2 to ${write_target} ..."
    dd if=$2 of=${write_target} conv=fsync 2>/dev/null
}

write_bootloader_to_target_rockchip() {

    idbloader_blob="/boot/bootloader/idbloader.img"
    uboot_blob="/boot/bootloader/u-boot.itb"

    if [ -e "${idbloader_blob}" ] ; then
        msg "Will use idbloader from [/boot/bootloader/] ..."
    else
        msg "No idbloader in [/boot/bootloader]. Will retrieve it from ${source_dev} ..."
        do_cmd mkdir -p /boot/bootloader/
        do_cmd dd if=/dev/${source_dev} of=${idbloader_blob} count=4031 skip=64
    fi

    if [ -e "${uboot_blob}" ] ; then
        msg "Will use u-boot from [/boot/bootloader/] ..."
    else
        msg "No u-boot in [/boot/bootloader]. Will retrieve it from ${source_dev} ..."
        do_cmd mkdir -p /boot/bootloader/
        do_cmd dd if=/dev/${source_dev} of=${uboot_blob} count=8191 skip=16384
    fi

    write_target_bootX 0 ${idbloader_blob}
    write_target_bootX 1 ${idbloader_blob}

    msg "Writing idbloader.img to ${target_dev} ..."
    do_cmd dd if=${idbloader_blob} of=/dev/${target_dev} seek=64 conv=notrunc

    msg "Writing u-boot.itb to ${target_dev} ..."
    do_cmd dd if=${uboot_blob} of=/dev/${target_dev} seek=16384 conv=notrunc

    do_cmd sync
}

write4096_bootloader_to_target() {

    idbloader_blob="/boot/bootloader/idbloader.img"
    uboot_blob="/boot/bootloader/u-boot.itb"

    if [ -e "${idbloader_blob}" ] ; then
        msg "Will use idbloader from [/boot/bootloader/] ..."
    else
        msg "No idbloader in [/boot/bootloader]. Will copy from ${source_dev} ..."
        do_cmd mkdir -p /boot/bootloader/
        do_cmd dd if=/dev/${source_dev} of=${idbloader_blob} bs=4k skip=8 count=256
    fi

    if [ -e "${uboot_blob}" ] ; then
        msg "Will use u-boot from [/boot/bootloader/] ..."
    else
        msg "No u-boot in [/boot/bootloader]. Will copy from ${source_dev} ..."
        do_cmd mkdir -p /boot/bootloader/
        do_cmd dd if=/dev/${source_dev} of=${uboot_blob} bs=4k skip=2048 count=512
    fi

    msg "Writing idbloader.img to boot0 ..."
    write_target_bootX 0 ${idbloader_blob}
    msg "Writing idbloader.img to boot1 ..."
    write_target_bootX 1 ${idbloader_blob}

    msg "Installing idbloader ..."
    do_cmd dd if=${idbloader_blob} of=/dev/${target_dev} bs=4k seek=8 conv=notrunc

    msg "Installing u-boot ..."
    do_cmd dd if=${uboot_blob} of=/dev/${target_dev} bs=4k seek=2048 conv=notrunc

    do_cmd sync
}

write_bootloader_to_target_allwinner() {

    uboot_blob="/boot/bootloader/u-boot-sunxi-with-spl.bin"

    if [ -e "${uboot_blob}" ] ; then
        msg "Will use u-boot from [/boot/bootloader/] ..."
    else
        msg "No u-boot in [/boot/bootloader]. Will retrieve it from ${source_dev} ..."
        do_cmd mkdir -p /boot/bootloader/
        do_cmd dd if=/dev/${source_dev} of=${uboot_blob} count=4096 skip=16
    fi

    write_target_bootX 0 ${uboot_blob}
    write_target_bootX 1 ${uboot_blob}

    msg "Writing u-boot to ${target_dev} ..."
    do_cmd dd if=${uboot_blob} of=/dev/${target_dev} seek=16 conv=notrunc

    do_cmd sync
}

write_bootloader_to_spi_target() {

    if [ "$platform_type" = "rk3399" ] ; then
        # this is for rockchip 3399
        write_bootloader_to_spi_target_rockchip

    elif [ "$platform_type" = "rk3568" ] ; then
        # this is for rockchip 356x
        write_bootloader_to_spi_target_rockchip

    elif [ "$platform_type" = "rk3576" ] ; then
        # this is for rockchip 3576
        write_bootloader_to_spi_target_rockchip

    elif [ "$platform_type" = "rk3588" ] ; then
        # this is for rockchip 3588
        write_bootloader_to_spi_target_rockchip

    else
        # this is for usupported
        msg "write_bootloader_to_spi_target: unsupported platform ..."
    fi
}

write_bootloader_to_spi_target_rockchip() {

    spi_uboot_blob="/boot/bootloader/u-boot-rockchip-spi.bin"

    if [ -e "${spi_uboot_blob}" ] ; then
        msg "Will use u-boot-rockchip-spi.bin from [/boot/bootloader/] ..."
        if [ -e "/dev/mtd0" ]; then
            msg "Writing u-boot-rockchip-spi.bin to /dev/mtd0 ..."
            flashcp -v ${spi_uboot_blob} /dev/mtd0
            check_return_code
        else
            msg "No /dev/mtd0 present. Skipping write spi u-boot ..."
        fi
    else
        msg "No u-boot-spi found in [/boot/bootloader] Skipping write spi u-boot ..."
    fi
}

write_bootloader_to_target() {

    if [ "$platform_type" = "allwinner" ] ; then
        write_bootloader_to_target_allwinner

    elif [ "$platform_type" = "rk3328" ] ; then
        # this is for rockchip 3328
        write_bootloader_to_target_rockchip

    elif [ "$platform_type" = "rk3399" ] ; then
        # this is for rockchip 3399
        write_bootloader_to_target_rockchip

    elif [ "$platform_type" = "rk3528" ] ; then
        # this is for rockchip 3528
        write_bootloader_to_target_rockchip

    elif [ "$platform_type" = "rk3568" ] ; then
        # this is for rockchip 356x
        write_bootloader_to_target_rockchip

    elif [ "$platform_type" = "rk3576" ] ; then
        # this is for rockchip 3576
        write_bootloader_to_target_rockchip

    elif [ "$platform_type" = "rk3588" ] ; then
        # this is for rockchip 3588
        write_bootloader_to_target_rockchip

    else
        # this is for usupported
        msg "write_bootloader_to_target: unsupported platform ..."
    fi
}

is_present() {
    if [ "${1}" != "N/A" ] ;  then
        return 0
    else
        return 1
    fi
}

is_present_and_not_booted_from() {
    if is_present ${1} && ! is_booted_from ${1} ; then
        return 0
    else
        return 1
    fi
}

check_presence_and_select_target() {
    target_dev=""
    target_dev_name="N/A"

    if [ ${devices_in_system} -lt 2 ] ; then
        #single device case
            if is_present_and_not_booted_from ${emmc_dev} ; then
                target_dev=${emmc_dev}
                target_dev_name="eMMC"
            elif is_present_and_not_booted_from ${ufs_dev} ; then
                target_dev=${ufs_dev}
                target_dev_name="UFS"
            elif is_present_and_not_booted_from ${usb_dev} ; then
                target_dev=${usb_dev}
                target_dev_name="USB"
            elif is_present_and_not_booted_from ${nvme_dev} ; then
                target_dev=${nvme_dev}
                target_dev_name="NVME"
            else
                echo " "
                echo "No suitable target to install found!"
                echo "Exiting ..."
                echo " "
                exit 1
            fi
        echo "==> Found target device: ${target_dev_name} (${target_dev})"
        echo " "
    else
        #more than 1 device. selection needed
        echo " " 
        echo "Multiple target candidates identified."
        echo "Please select target to operate on:"
        echo " "
        if is_present_and_not_booted_from ${emmc_dev} ; then
            echo "(e): eMMC module"
        fi
        if is_present_and_not_booted_from ${ufs_dev} ; then
            echo "(f): UFS module"
        fi
        if is_present_and_not_booted_from ${usb_dev} ; then
            echo "(u): USB key"
        fi
        if is_present_and_not_booted_from ${nvme_dev} ; then
            echo "(n): NVME disk"
        fi

        read sel

        if  [ "${sel}" = "e" ] ; then
            target_dev=${emmc_dev}
            target_dev_name="eMMC"
        elif [ "${sel}" = "f" ] ; then
            target_dev=${ufs_dev}
            target_dev_name="UFS"
        elif [ "${sel}" = "u" ] ; then
            target_dev=${usb_dev}
            target_dev_name="USB"
        elif [ "${sel}" = "n" ] ; then
            target_dev=${nvme_dev}
            target_dev_name="NVME"
        else
            echo " "
            echo "Wrong selection! Exiting ..."
            echo " "
            exit 1
        fi
        echo "==> Selectd target device: ${target_dev_name} (${target_dev})"
        echo " "
    fi
}

check_presence_and_select_source() {
    source_dev=""
    source_dev_name="N/A"
    if is_present ${sdcard_dev} && [ "${target_dev}" != ${sdcard_dev} ] && is_present ${emmc_dev} && [ "${target_dev}" != ${emmc_dev} ]; then
        #more than 1 device. selection needed
        echo " " 
        echo "Multiple source candidates identified."
        echo "Please select source to install from:"
        echo " "

        if is_present ${sdcard_dev} ; then
            echo "(s): SD card"
        fi
        if is_present ${emmc_dev} ; then
            echo "(e): eMMC module"
        fi

        read sel

        if  [ "${sel}" = "e" ] ; then
            source_dev=${emmc_dev}
            source_dev_name="eMMC"
        elif [ "${sel}" = "s" ] ; then
            source_dev=${sdcard_dev}
            source_dev_name="SDcard"
        else
            echo " "
            echo "Wrong selection! Exiting ..."
            echo " "
            exit 1
        fi

        echo "==> Selectd source device: ${source_dev_name} (${source_dev})"
        echo " "
    else
        #single device
        if is_present ${sdcard_dev} && [ "${target_dev}" != ${sdcard_dev} ] ; then
            source_dev=${sdcard_dev}
            if is_booted_from ${sdcard_dev} ; then 
                source_dev_name="SDcard (booted from)"
            else
                source_dev_name="SDcard"
            fi
        elif is_present ${emmc_dev} && [ "${target_dev}" != ${emmc_dev} ] ; then
            source_dev=${emmc_dev}
            if is_booted_from ${emmc_dev} ; then 
                source_dev_name="eMMC (booted from)"
            else
                source_dev_name="eMMC"
            fi
        else
            echo " "
            echo "No SDcard nor eMMC as source found!"
            echo "To install to eMMC, UFS, USB or NVME script requires system on SDcard (or eMMC) as source."
            echo "Exiting ..."
            echo " "
            exit 1
        fi

        echo "==> Found source device: ${source_dev_name} (${source_dev})"
        echo " "

    fi
}

rm -f ${log_file}

check_prereq

boot_dev=$(mount | grep -e '/initrd\s' | awk '{print $1}' | sed 's/\/dev\///g' | sed 's/[0123456789]$//g' | sed 's/p//g' )
if [ "${boot_dev}" = "" ]; then
    boot_dev=$(mount | grep -e 'on\s/\s' | awk '{print $1}' | sed 's/\/dev\///g' | sed 's/[0123456789]$//g' | sed 's/p//g' )
fi

spi_dev="N/A"
spi_devices=$(mtdinfo | grep Count | sed -e 's/[^0-9]//g')
if [ "$spi_devices" = "1" ] ; then
    spi_dev=$(mtdinfo | grep Present | sed -e 's/.*:\s*//g')
elif [ "$spi_devices" -gt "1" ] ; then
    echo "Your system has more than 1 spi devide. This is unsupported by this script ..."
fi

devices_in_system=0

sdcard_dev="N/A"
for TYPE in /sys/class/block/mmcblk*/device/type; do
    if grep -q "SD" "${TYPE}" 2>/dev/null ; then
        sdcard_dev="$(echo "${TYPE}" | awk -F/ '{print $5}')"
        devices_in_system=$((${devices_in_system} + 1))
        break
    fi
done

emmc_dev="N/A"
for TYPE in /sys/class/block/mmcblk*/device/type; do
    if grep -q "MMC" "${TYPE}" 2>/dev/null ; then
        emmc_dev="$(echo "${TYPE}" | awk -F/ '{print $5}')"
        devices_in_system=$((${devices_in_system} + 1))
        break
    fi
done

ufs_dev="N/A"
usb_dev="N/A"
for device in /sys/class/block/sd*/device/type; do
    device_path=$(readlink -f $device)
    if [[ "$device_path" == *"usb"* ]]; then
        if [ "${usb_dev}" = "N/A" ] ; then
            usb_dev=$(echo ${device} | cut -d'/' -f5)
            devices_in_system=$((${devices_in_system} + 1))
        fi
    elif [[ "$device_path" == *"ufs"* ]]; then
        if [ "${ufs_dev}" = "N/A" ] ; then
            ufs_dev=$(echo ${device} | cut -d'/' -f5)
            devices_in_system=$((${devices_in_system} + 1))
        fi
    elif [[ "$device_path" == *"nvme"* ]]; then
        if [ "${nvme_dev}" = "N/A" ] ; then
            nvme_dev=$(echo ${device} | cut -d'/' -f5)
            devices_in_system=$((${devices_in_system} + 1))
        fi
    fi
done

nvme_dev="N/A"
for device in /sys/class/block/nvme*/device/state; do
    device_path=$(readlink -f $device)
    if [[ "$device_path" == *"nvme"* ]]; then
        if [ "${nvme_dev}" = "N/A" ] ; then
            nvme_dev=$(echo ${device} | cut -d'/' -f5)
            devices_in_system=$((${devices_in_system} + 1))
        fi
    fi
done

echo " "
echo "--- MiniMyth2 to eMMC/UFS/USB/NVME installer v$ver (c)Piotr Oniszczuk ---"
echo " "

what_platform
# exit for anything (amlogic, rpi) as unsupported (yet)
if [ "${platform_type}" = "unsupported" ] ; then
    echo " "
    echo "Unsupported (yet) platform! Exiting ..."
    echo " "
    exit 1
fi

boot_dev_name="Unknown"
if [[ ${boot_dev} =~ ${sdcard_dev} ]] ; then
    boot_dev_name="SD card"
fi
if [[ ${boot_dev} =~ ${emmc_dev} ]] ; then
    boot_dev_name="eMMC module"
fi
if [[ ${boot_dev} =~ ${ufs_dev} ]] ; then
    boot_dev_name="UFS module"
fi
if [[ ${boot_dev} =~ ${usb_dev} ]] ; then
    boot_dev_name="USB key"
fi
if [[ ${boot_dev} =~ ${nvme_dev} ]] ; then
    boot_dev_name="NVME disk"
fi

echo " "
echo "Platform             : ${platform}"
echo "Board/device         : ${platform_type}"
echo " " 
echo "SDcard device        : ${sdcard_dev}"
echo "eMMC device          : ${emmc_dev}"
echo "UFS device           : ${ufs_dev}"
echo "USB device           : ${usb_dev}"
echo "NVME device          : ${nvme_dev}"
echo "Devices in system    : ${devices_in_system}"
echo "SPI device           : ${spi_dev}"
echo "System booted from   : ${boot_dev_name} (${boot_dev})"

if [ "${boot_dev}" = "" ]; then
    echo " "
    echo "Can't determine boot device! Exiting ..."
    echo " "
    exit 1
fi

if [ "${command}" = "erase" ] ; then

    skip_check_is_booted_from="yes"
    check_presence_and_select_target
    skip_check_is_booted_from="no"

    clean_working_env

    msg "Erasing ${target_dev_name} (${target_dev}) ..."

    confirm "Please, confirm to erase"
    confirm "ARE YOU SURE to erase ${target_dev} content?"

    erase_target ${target_dev}

    if is_present ${sdcard_dev} && [ ${target_dev} != ${sdcard_dev} ] ; then

        erase_bootloader

        # changing back root= to SDcard device
        msg "Restoring root= in exlinux.conf back to ${sdcard_dev},part2 ..."
        umount_partition ${boot_src}
        mount_partition /dev/${sdcard_dev} 1 ${boot_src}
        update_extlinux_conf ${boot_src} ${sdcard_dev} 2
        umount_partition ${boot_src}
    fi

    if is_present ${emmc_dev} && [ ${target_dev} != ${emmc_dev} ] ; then

        erase_bootloader

        # changing back root= to eMMC device
        msg "Restoring root= in exlinux.conf back to ${emmc_dev},part2 ..."
        umount_partition ${boot_src}
        mount_partition /dev/${emmc_dev} 1 ${boot_src}
        update_extlinux_conf ${boot_src} ${emmc_dev} 2
        umount_partition ${boot_src}
    fi

    sync

    echo " "
    echo "Done ..."
    echo " "
    exit 0

elif [ "${command}" = "erasespi" ] ; then

    if [ "${spi_dev}" = "N/A" ] ; then
        echo "It looks Your system don't have any SPI device ..."
        echo "Script will exit now!"
        echo " " 
        exit 0
    fi

    msg "Erasing ${spi_dev} ..."

    confirm "to erase SPI"
    confirm "ARE YOU SURE to erase ${spi_dev} content?"

    flash_erase /dev/${spi_dev} 0 0

    sync

    echo " "
    echo "Done ..."
    echo " "
    exit 0

elif [ "${command}" = "bootloader" ] ; then

    check_presence_and_select_target

    check_presence_and_select_source

    if [ ${target_dev} != ${emmc_dev} ] ; then
        echo "Writing bootloader is supported only for eMMC target ..."
        echo "Current target is ${target_dev_name} (${target_dev})"
        echo " "
        echo "Exiting!"
        echo " "
        exit 1
    fi

    confirm "to install/update bootloader on ${target_dev_name} (${target_dev})"

    msg "Writing bootloader to ${target_dev_name} (${target_dev}) ..."

    write_bootloader_to_target

    sync

    echo " "
    echo "Done ..."
    echo " "
    exit 0

elif [ "${command}" = "spibootloader" ] ; then

    check_presence_and_select_source

    confirm "to install/update SPI bootloader from ${source_dev_name} (${source_dev})"

    write_bootloader_to_spi_target

    sync

    echo " "
    echo "Done ..."
    echo " "
    exit 0

elif [ "${command}" = "install" ] ; then

    check_presence_and_select_target

    check_presence_and_select_source

    clean_working_env

    echo "If You are installing to UFS, USB or NVME - you must have working bootloader on SPI or SDCard or eMMC."
    echo "This is required due SoC BootROM limitations ..."
    confirm "Do You have working bootloader on device SPI or SDCard or eMMC?"

    confirm "ARE YOU SURE to DESTROY ALL content on ${target_dev_name} (${target_dev}) device?"

    msg "Installing from ${source_dev_name} -> ${target_dev_name} (${source_dev}->${target_dev}) ..."

    partition_2part_mbr_then_format /dev/${target_dev}

    copy_sdcard_to_2part_mbr_disk
    msg "Copying to ${target_dev_name} done ..."

    if [ "${target_dev}" = "${emmc_dev}" ] ; then
        # target is eMMC
        msg "Writing bootloader to eMMC ..."
        write_bootloader_to_target

        update_extlinux_conf ${boot_dst} ${target_dev} 2

    else
        #target is USB or NVME or UFS. Modify root=  on boot device (which is SDcard or eMMC)
        update_extlinux_conf ${boot_src} ${target_dev} 2

    fi

    sync

    umount_all_partitions

    echo " "
    echo "It looks system was successfuly installed on ${target_dev_name} (${target_dev}) :-)"
    echo "You can now poweroff, remove SDcard (if install was to eMMC) and then poweron again. System should boot from ${target_dev_name} ..."
    echo " "
    echo "So...happy booting :-)"
    echo " "
    exit 0

else
    echo " "
    echo "Run script with command: erase|erasespi|bootloader|spibootloader|install"
    echo " "

    exit 0
fi

exit 0

# MiniMyth2
