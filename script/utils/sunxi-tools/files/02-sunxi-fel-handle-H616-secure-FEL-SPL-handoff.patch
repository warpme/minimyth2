diff --git a/thunks/fel-secure-svc.inc.S b/thunks/fel-secure-svc.inc.S
new file mode 100644
index 0000000000..5b62aaf7a0
--- /dev/null
+++ b/thunks/fel-secure-svc.inc.S
@@ -0,0 +1,43 @@
+SAVED_SP	.req	r10
+SAVED_LR	.req	r11
+
+.set	SUNXI_GICC_BASE,	0x03022000
+.set	SUNXI_GICD_BASE,	0x03021000
+
+.macro	switch_to_secure_svc
+	sync_before_branch
+	mov	SAVED_SP,  sp
+	mov	SAVED_LR,  lr
+	.word	0xe1600070			/* smc	#0 */
+	mov	TMP1,      #0
+	mcr	p15, 0, TMP1, c1, c1, 0		/* SCR = secure */
+	mcr	p15, 0, TMP1, c12, c0, 1	/* MVBAR = 0 */
+	bl	setup_secure_gic
+
+	.word	0xe123f30a			/* msr	SP_svc, SAVED_SP */
+	.word	0xe122f30b			/* msr	LR_svc, SAVED_LR */
+	.word	0xf57ff06f			/* isb */
+	mrs	TMP1,      cpsr
+	bic	TMP1,      TMP1, #0x1f
+	orr	TMP1,      TMP1, #0x13
+	msr	cpsr_fc,   TMP1			/* switch to secure-SVC mode */
+.endm
+
+.macro	emit_secure_svc_helpers
+setup_secure_gic:
+	/* Set the secure GIC view expected by secure-SVC FEL execution. */
+	ldr	TMP1,      gicc_ctlr
+	mov	TMP2,      #0xf
+	str	TMP2,      [TMP1]
+	mov	TMP2,      #0xf8
+	str	TMP2,      [TMP1, #4]
+	ldr	TMP1,      gicd_ctlr
+	mov	TMP2,      #3
+	str	TMP2,      [TMP1]
+	bx	lr
+
+gicc_ctlr:
+	.word	SUNXI_GICC_BASE
+gicd_ctlr:
+	.word	SUNXI_GICD_BASE
+.endm
