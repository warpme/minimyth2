From 6e46508f03ab20485edbff02aeb85923256f397e Mon Sep 17 00:00:00 2001
From: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
Date: Mon, 10 Nov 2025 09:33:55 +0200
Subject: [PATCH 079/114] drm/bridge: synopsys: dw-dp: Simplify
 dw_dp_bandwidth_ok() return

Drop the rather superfluous condition check and simply return the result
of the logical expression evaluation.

Signed-off-by: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
---
 drivers/gpu/drm/bridge/synopsys/dw-dp.c | 4 +---
 1 file changed, 1 insertion(+), 3 deletions(-)

diff --git a/drivers/gpu/drm/bridge/synopsys/dw-dp.c b/drivers/gpu/drm/bridge/synopsys/dw-dp.c
index 428f10ccec..86828db5e6 100644
--- a/drivers/gpu/drm/bridge/synopsys/dw-dp.c
+++ b/drivers/gpu/drm/bridge/synopsys/dw-dp.c
@@ -466,10 +466,8 @@ static bool dw_dp_bandwidth_ok(struct dw_dp *dp,
 
 	req_bw = mode->clock * bpp / 8;
 	max_bw = lanes * rate;
-	if (req_bw > max_bw)
-		return false;
 
-	return true;
+	return req_bw <= max_bw;
 }
 
 static bool dw_dp_hpd_detect(struct dw_dp *dp)
