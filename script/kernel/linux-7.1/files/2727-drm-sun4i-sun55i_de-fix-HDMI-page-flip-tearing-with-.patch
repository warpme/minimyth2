+/*
+ * Pick the coefficient phase-set offset (in table entries) for a given
+ * horizontal/vertical step (de_vsu_calc_fir_coef). step is in
+ * SUN55I_VSU_STEP_FRAC_BITS fixed point (1.0 == 1 << 19).
+ */
+static inline u32 sun55i_vsu8_coef_index(u32 step)
+{
+	u32 ratio = step >> (SUN55I_VSU_PHASE_FRAC_BITS - 3);
+	u32 int_part = ratio >> 3;
+	u32 frac = ratio & 0x7;
+	u32 ofst;
+
+	if (int_part == 0)
+		ofst = SUN55I_VSU_ZOOM0_SIZE;
+	else if (int_part == 1)
+		ofst = SUN55I_VSU_ZOOM0_SIZE + frac;
+	else if (int_part == 2)
+		ofst = SUN55I_VSU_ZOOM0_SIZE + SUN55I_VSU_ZOOM1_SIZE + (frac >> 1);
+	else if (int_part == 3)
+		ofst = SUN55I_VSU_ZOOM0_SIZE + SUN55I_VSU_ZOOM1_SIZE +
+		       SUN55I_VSU_ZOOM2_SIZE;
+	else if (int_part == 4)
+		ofst = SUN55I_VSU_ZOOM0_SIZE + SUN55I_VSU_ZOOM1_SIZE +
+		       SUN55I_VSU_ZOOM2_SIZE + SUN55I_VSU_ZOOM3_SIZE;
+	else
+		ofst = SUN55I_VSU_ZOOM0_SIZE + SUN55I_VSU_ZOOM1_SIZE +
+		       SUN55I_VSU_ZOOM2_SIZE + SUN55I_VSU_ZOOM3_SIZE +
+		       SUN55I_VSU_ZOOM4_SIZE;
+
+	return ofst * SUN55I_VSU_PHASE_NUM;
+}
