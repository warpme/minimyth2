From 59d9ef8e98a1cbc6975ebea3071fd80f6ccd4153 Mon Sep 17 00:00:00 2001
From: Jernej Skrabec <jernej.skrabec@gmail.com>
Date: Sun, 21 Jun 2026 21:54:43 +0200
Subject: [PATCH 18/20] media: cedrus: vc1: INTENCOMP, I-frame self-ref, ts=0
 fixes

Three related fixes:
1. Always enable INTENCOMP for interlaced-field IC P-frames
   matching vendor behaviour.
2. Force self-reference for I-frame second fields when ffmpeg
   sends a stale forward_ref_ts.
3. Treat forward_ref_ts=0 / backward_ref_ts=0 as no reference.

Co-Authored-By: Claude <noreply@anthropic.com>
---
 drivers/staging/media/sunxi/cedrus/cedrus_vc1.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/staging/media/sunxi/cedrus/cedrus_vc1.c b/drivers/staging/media/sunxi/cedrus/cedrus_vc1.c
index ce40552c7..915b35880 100644
--- a/drivers/staging/media/sunxi/cedrus/cedrus_vc1.c
+++ b/drivers/staging/media/sunxi/cedrus/cedrus_vc1.c
@@ -272,7 +272,7 @@ static int cedrus_vc1_setup(struct cedrus_ctx *ctx, struct cedrus_run *run)
 	else if (picture->fcm == VC1_FCM_INTERLACED_FRAME)
 		flag = !!(picture->flags & V4L2_VC1_PICTURE_LAYER_FLAG_INTCOMP);
 	else if (picture->mvmode == VC1_MVMODE_INTENSITY_COMP)
-		flag = picture->intcompfield != 2;
+		flag = true;
 	else
 		flag = false;
 
