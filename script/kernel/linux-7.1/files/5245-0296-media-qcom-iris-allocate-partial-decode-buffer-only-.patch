From 5d3934d3d6bc61118cdf54018dcbf6006bd89b59 Mon Sep 17 00:00:00 2001
From: Xilin Wu <sophon@radxa.com>
Date: Sun, 7 Jun 2026 15:15:53 +0800
Subject: [PATCH 296/309] media: qcom: iris: allocate partial decode buffer
 only for AV1

The partial decode buffer is used for AV1 IBC data. Iris currently
calculates a partial buffer size for every decoder codec, which causes the
host to allocate and queue HFI_BUFFER_PARTIAL_DATA even for codecs such as
HEVC. Firmware rejects that buffer type and reports unsupported buffer
messages.

Match the downstream behavior by returning a non-zero partial buffer size
only for AV1. Other decoder codecs keep the buffer type in the internal
table, but get a zero-sized buffer and therefore do not allocate or queue
it.

Signed-off-by: Xilin Wu <sophon@radxa.com>
---
 drivers/media/platform/qcom/iris/iris_vpu_buffer.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/drivers/media/platform/qcom/iris/iris_vpu_buffer.c b/drivers/media/platform/qcom/iris/iris_vpu_buffer.c
index d0612b112..c7a10f9d1 100644
--- a/drivers/media/platform/qcom/iris/iris_vpu_buffer.c
+++ b/drivers/media/platform/qcom/iris/iris_vpu_buffer.c
@@ -1016,6 +1016,9 @@ static u32 iris_vpu_dec_partial_size(struct iris_inst *inst)
 	u32 height = f->fmt.pix_mp.height;
 	u32 width = f->fmt.pix_mp.width;
 
+	if (inst->codec != V4L2_PIX_FMT_AV1)
+		return 0;
+
 	return hfi_buffer_ibc_av1d(width, height);
 }
 
