
part /efi    --source bootimg-partition  --ondisk mmcblk --fstype=vfat --label BOOT --active --offset 65536s --size 384
part /       --source rootfs             --ondisk mmcblk --fstype=ext4 --label ROOT          --align 1024    --extra-space 1024
part                                     --ondisk mmcblk --fstype=swap --label SWAP          --align 1024    --size 1536
bootloader --ptable gpt
