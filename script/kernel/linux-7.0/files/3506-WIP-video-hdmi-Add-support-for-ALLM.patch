 EXPORT_SYMBOL(hdmi_vendor_infoframe_pack);
 
+/**
+ * hdmi_forum_vendor_infoframe_init() - initialize a HF-VSIF
+ * @frame: HDMI Forum Vendor InfoFrame
+ *
+ * Returns 0 on success or a negative error code on failure.
+ */
+int hdmi_forum_vendor_infoframe_init(struct hdmi_forum_vendor_infoframe *frame)
+{
+	memset(frame, 0, sizeof(*frame));
+
+	frame->type = HDMI_INFOFRAME_TYPE_VENDOR;
+	frame->version = 1;
+
+	frame->oui = HDMI_FORUM_IEEE_OUI;
+	frame->hf_vsif_ver = 1;
+
+	frame->s3d_f_struct = HDMI_3D_STRUCTURE_INVALID;
+	frame->length = HDMI_FORUM_VENDOR_INFOFRAME_SIZE;
+
+	return 0;
+}
+EXPORT_SYMBOL(hdmi_forum_vendor_infoframe_init);
+
+static size_t hdmi_forum_vendor_infoframe_length(const struct hdmi_forum_vendor_infoframe *frame)
+{
+	size_t length = HDMI_FORUM_VENDOR_INFOFRAME_SIZE;
+
+	if (!frame->s3d_valid)
+		return length;
+
+	length++;
+
+	/* For side by side (half) we also need to provide 3D_Ext_Data */
+	if (frame->s3d_f_struct >= HDMI_3D_STRUCTURE_SIDE_BY_SIDE_HALF)
+		length++;
+
+	if (frame->s3d_addinfo_present)
+		length++;
+
+	if (frame->s3d_dispdata_present)
+		length += frame->s3d_dispdata_length + 1;
+
+	if (frame->s3d_metadata_present)
+		length += frame->s3d_metadata_length + 1;
+
+	return length;
+}
+
+static int hdmi_forum_vendor_infoframe_check_only(const struct hdmi_forum_vendor_infoframe *frame)
+{
+	if (frame->type != HDMI_INFOFRAME_TYPE_VENDOR ||
+	    frame->version != 1 ||
+	    frame->oui != HDMI_FORUM_IEEE_OUI ||
+	    frame->hf_vsif_ver != 1)
+		return -EINVAL;
+
+	if (frame->s3d_valid) {
+		if (frame->s3d_f_struct == HDMI_3D_STRUCTURE_INVALID)
+			return -EINVAL;
+		if (frame->s3d_dispdata_present && !frame->s3d_dispdata_length)
+			return -EINVAL;
+		if (frame->s3d_metadata_present && !frame->s3d_metadata_length)
+			return -EINVAL;
+	}
+
+	if (frame->length != hdmi_forum_vendor_infoframe_length(frame) ||
+	    frame->length > HDMI_MAX_INFOFRAME_SIZE)
+		return -EINVAL;
+
+	return 0;
+}
+
+/**
+ * hdmi_forum_vendor_infoframe_check() - check a HF-VSIF
+ * @frame: HDMI Forum Vendor InfoFrame
+ *
+ * Validates that the infoframe is consistent and updates derived fields
+ * (eg. length) based on other fields.
+ *
+ * Returns 0 on success or a negative error code on failure.
+ */
+int hdmi_forum_vendor_infoframe_check(struct hdmi_forum_vendor_infoframe *frame)
+{
+	frame->length = hdmi_forum_vendor_infoframe_length(frame);
+
+	return hdmi_forum_vendor_infoframe_check_only(frame);
+}
+EXPORT_SYMBOL(hdmi_forum_vendor_infoframe_check);
+
+/**
+ * hdmi_forum_vendor_infoframe_pack_only() - write a HF-VSIF to binary buffer
+ * @frame: HDMI Forum Vendor InfoFrame
+ * @buffer: destination buffer
+ * @size: size of buffer
+ *
+ * Packs the information contained in the @frame structure into a binary
+ * representation that can be written into the corresponding controller
+ * registers. Also computes the checksum as required by section 5.3.5 of
+ * the HDMI 1.4 specification.
+ *
+ * Returns the number of bytes packed into the binary buffer or a negative
+ * error code on failure.
+ */
+ssize_t hdmi_forum_vendor_infoframe_pack_only(const struct hdmi_forum_vendor_infoframe *frame,
+					      void *buffer, size_t size)
+{
+	u8 *ptr = buffer;
+	size_t length;
+	int ret;
+
+	ret = hdmi_forum_vendor_infoframe_check_only(frame);
+	if (ret)
+		return ret;
+
+	length = HDMI_INFOFRAME_HEADER_SIZE + frame->length;
+
+	if (size < length)
+		return -ENOSPC;
+
+	memset(buffer, 0, size);
+
+	ptr[0] = frame->type;
+	ptr[1] = frame->version;
+	ptr[2] = frame->length;
+	ptr[3] = 0; /* checksum */
+
+	/* HDMI Forum OUI */
+	ptr[4] = 0xd8;
+	ptr[5] = 0x5d;
+	ptr[6] = 0xc4;
+
+	ptr[7] = frame->hf_vsif_ver;
+
+	ptr[8] = ((frame->ccbpc & 0xf) << 4) | (frame->allm << 1) | frame->s3d_valid;
+
+	if (frame->s3d_valid) {
+		ptr[9] = ((frame->s3d_f_struct & 0xf) << 4) |
+			 (frame->s3d_addinfo_present << 3) |
+			 (frame->s3d_dispdata_present << 2) |
+			 (frame->s3d_metadata_present << 1);
+
+		ptr += 10;
+		if (frame->s3d_f_struct >= HDMI_3D_STRUCTURE_SIDE_BY_SIDE_HALF)
+			*ptr++ = (frame->s3d_f_ext_data & 0xf) << 4;
+
+		if (frame->s3d_addinfo_present)
+			*ptr++ = (frame->s3d_dualview << 4) |
+				 ((frame->s3d_view_depend & 0x2) << 2) |
+				 (frame->s3d_pref_2d_view & 0x2);
+
+		if (frame->s3d_dispdata_present) {
+			*ptr++ = ((frame->s3d_dispdata_version & 0x7) << 5) |
+				 (frame->s3d_dispdata_length & 0x1f);
+			memcpy(ptr, frame->s3d_data, frame->s3d_dispdata_length);
+			ptr += frame->s3d_dispdata_length;
+		}
+
+		if (frame->s3d_metadata_present) {
+			*ptr++ = ((frame->s3d_metadata_type & 0x7) << 5) |
+				 (frame->s3d_metadata_length & 0x1f);
+			memcpy(ptr, frame->s3d_data, frame->s3d_metadata_length);
+		}
+	}
+
+	hdmi_infoframe_set_checksum(buffer, length);
+
+	return length;
+}
+EXPORT_SYMBOL(hdmi_forum_vendor_infoframe_pack_only);
+
+/**
+ * hdmi_forum_vendor_infoframe_pack() - check a HF-VSIF and write it to binary buffer
+ * @frame: HDMI Forum Vendor infoframe
+ * @buffer: destination buffer
+ * @size: size of buffer
+ *
+ * Validates that the infoframe is consistent and updates derived fields
+ * (eg. length) based on other fields, after which it packs the information
+ * contained in the @frame structure into a binary representation that
+ * can be written into the corresponding controller registers. This function
+ * also computes the checksum as required by section 5.3.5 of the HDMI 1.4
+ * specification.
+ *
+ * Returns the number of bytes packed into the binary buffer or a negative
+ * error code on failure.
+ */
+ssize_t hdmi_forum_vendor_infoframe_pack(struct hdmi_forum_vendor_infoframe *frame,
+					 void *buffer, size_t size)
+{
+	int ret;
+
+	ret = hdmi_forum_vendor_infoframe_check(frame);
+	if (ret)
+		return ret;
+
+	return hdmi_forum_vendor_infoframe_pack_only(frame, buffer, size);
+}
+EXPORT_SYMBOL(hdmi_forum_vendor_infoframe_pack);
+
