+static int radxa_svc_platform_profile_probe(void *drvdata,
+					    unsigned long *choices)
+{
+	set_bit(PLATFORM_PROFILE_QUIET, choices);
+	set_bit(PLATFORM_PROFILE_PERFORMANCE, choices);
+
+	return 0;
+}
+
+static int radxa_svc_platform_profile_get(struct device *dev,
+					  enum platform_profile_option *profile)
+{
+	struct radxa_svc_glink *svc = dev_get_drvdata(dev);
+	struct radxa_svc_fan_control_resp control = {};
+	u32 svc_profile;
+	int ret;
+
+	if (svc->caps & RADXA_SVC_CAP_FANCTL_CTRL) {
+		ret = radxa_svc_fan_get_control(svc, &control);
+		if (ret)
+			return ret;
+
+		if (le32_to_cpu(control.control_mode) !=
+		    RADXA_SVC_FAN_CONTROL_AUTO) {
+			*profile = PLATFORM_PROFILE_CUSTOM;
+			return 0;
+		}
+	}
+
+	ret = radxa_svc_get_profile(svc, &svc_profile);
+	if (ret)
+		return ret;
+
+	switch (svc_profile) {
+	case RADXA_SVC_PROFILE_QUIET:
+		*profile = PLATFORM_PROFILE_QUIET;
+		return 0;
+	case RADXA_SVC_PROFILE_PERFORMANCE:
+		*profile = PLATFORM_PROFILE_PERFORMANCE;
+		return 0;
+	default:
+		return -EIO;
+	}
+}
+
+static int radxa_svc_platform_profile_set(struct device *dev,
+					  enum platform_profile_option profile)
+{
+	struct radxa_svc_glink *svc = dev_get_drvdata(dev);
+	struct radxa_svc_fan_control_resp control = {};
+	u32 manual_pwm = 0;
+	u32 svc_profile;
+	int ret;
+
+	switch (profile) {
+	case PLATFORM_PROFILE_QUIET:
+		svc_profile = RADXA_SVC_PROFILE_QUIET;
+		break;
+	case PLATFORM_PROFILE_PERFORMANCE:
+		svc_profile = RADXA_SVC_PROFILE_PERFORMANCE;
+		break;
+	default:
+		return -EOPNOTSUPP;
+	}
+
+	if (svc->caps & RADXA_SVC_CAP_FANCTL_CTRL) {
+		ret = radxa_svc_fan_get_control(svc, &control);
+		if (ret)
+			return ret;
+
+		manual_pwm = le32_to_cpu(control.manual_pwm);
+		ret = radxa_svc_fan_set_control(svc,
+						RADXA_SVC_FAN_CONTROL_AUTO,
+						manual_pwm);
+		if (ret)
+			return ret;
+	}
+
+	return radxa_svc_set_profile(svc, svc_profile);
+}
+
+static const struct platform_profile_ops radxa_svc_platform_profile_ops = {
+	.probe = radxa_svc_platform_profile_probe,
+	.profile_get = radxa_svc_platform_profile_get,
+	.profile_set = radxa_svc_platform_profile_set,
+};
