+static umode_t radxa_svc_hwmon_is_visible(const void *data,
+					  enum hwmon_sensor_types type,
+					  u32 attr, int channel)
+{
+	const struct radxa_svc_glink *svc = data;
+
+	if (type != hwmon_pwm || channel)
+		return 0;
+
+	switch (attr) {
+	case hwmon_pwm_input:
+	case hwmon_pwm_enable:
+		return svc->caps & RADXA_SVC_CAP_FANCTL_CTRL ? 0644 : 0444;
+	default:
+		return 0;
+	}
+}
+
+static int radxa_svc_hwmon_read(struct device *dev,
+				enum hwmon_sensor_types type, u32 attr,
+				int channel, long *val)
+{
+	struct radxa_svc_glink *svc = dev_get_drvdata(dev);
+	struct radxa_svc_fan_control_resp control = {};
+	struct radxa_svc_fan_state_resp state = {};
+	u32 duty_ns;
+	u32 period_ns;
+	int ret;
+
+	if (type != hwmon_pwm || channel)
+		return -EOPNOTSUPP;
+
+	switch (attr) {
+	case hwmon_pwm_input:
+		ret = radxa_svc_fan_get_state(svc, &state, NULL);
+		if (ret)
+			return ret;
+
+		period_ns = le32_to_cpu(state.pwm_period_ns);
+		duty_ns = le32_to_cpu(state.current_duty_ns);
+		if (!period_ns)
+			return -ENODATA;
+
+		*val = radxa_svc_fan_duty_to_pwm(period_ns, duty_ns);
+		return 0;
+	case hwmon_pwm_enable:
+		if (!(svc->caps & RADXA_SVC_CAP_FANCTL_CTRL)) {
+			*val = RADXA_SVC_FAN_CONTROL_AUTO;
+			return 0;
+		}
+
+		ret = radxa_svc_fan_get_control(svc, &control);
+		if (ret)
+			return ret;
+
+		*val = le32_to_cpu(control.control_mode);
+		return 0;
+	default:
+		return -EOPNOTSUPP;
+	}
+}
+
+static int radxa_svc_hwmon_write(struct device *dev,
+				 enum hwmon_sensor_types type, u32 attr,
+				 int channel, long val)
+{
+	struct radxa_svc_glink *svc = dev_get_drvdata(dev);
+	struct radxa_svc_fan_control_resp control = {};
+	struct radxa_svc_fan_state_resp state = {};
+	u32 duty_ns;
+	u32 manual_pwm;
+	u32 period_ns;
+	int ret;
+
+	if (type != hwmon_pwm || channel)
+		return -EOPNOTSUPP;
+
+	if (!(svc->caps & RADXA_SVC_CAP_FANCTL_CTRL))
+		return -EOPNOTSUPP;
+
+	switch (attr) {
+	case hwmon_pwm_input:
+		if (val < 0 || val > RADXA_SVC_FAN_PWM_MAX)
+			return -EINVAL;
+
+		ret = radxa_svc_fan_get_control(svc, &control);
+		if (ret)
+			return ret;
+
+		if (le32_to_cpu(control.control_mode) !=
+		    RADXA_SVC_FAN_CONTROL_MANUAL)
+			return -EINVAL;
+
+		return radxa_svc_fan_set_control(svc,
+						 RADXA_SVC_FAN_CONTROL_MANUAL,
+						 val);
+	case hwmon_pwm_enable:
+		if (val < RADXA_SVC_FAN_CONTROL_FULL_SPEED ||
+		    val > RADXA_SVC_FAN_CONTROL_AUTO)
+			return -EINVAL;
+
+		if (val == RADXA_SVC_FAN_CONTROL_FULL_SPEED) {
+			ret = radxa_svc_fan_set_control(svc, val,
+							RADXA_SVC_FAN_PWM_MAX);
+			if (!ret)
+				radxa_svc_platform_profile_notify(svc);
+
+			return ret;
+		}
+
+		if (val == RADXA_SVC_FAN_CONTROL_MANUAL) {
+			ret = radxa_svc_fan_get_state(svc, &state, NULL);
+			if (ret)
+				return ret;
+
+			period_ns = le32_to_cpu(state.pwm_period_ns);
+			duty_ns = le32_to_cpu(state.current_duty_ns);
+			manual_pwm = radxa_svc_fan_duty_to_pwm(period_ns,
+							       duty_ns);
+
+			ret = radxa_svc_fan_set_control(svc, val, manual_pwm);
+			if (!ret)
+				radxa_svc_platform_profile_notify(svc);
+
+			return ret;
+		}
+
+		ret = radxa_svc_fan_get_control(svc, &control);
+		if (ret)
+			return ret;
+
+		ret = radxa_svc_fan_set_control(svc, val,
+						le32_to_cpu(control.manual_pwm));
+		if (!ret)
+			radxa_svc_platform_profile_notify(svc);
+
+		return ret;
+	default:
+		return -EOPNOTSUPP;
+	}
+}
