diff --speed-large-files --no-dereference --minimal -Naur linux-6.19.3/arch/arm64/boot/dts/rockchip/rk3588-rock-5b-5bp-5t.dtsi linux-6.19.3/arch/arm64/boot/dts/rockchip/rk3588-rock-5b-5bp-5t.dtsi
--- linux-6.19.3/arch/arm64/boot/dts/rockchip/rk3588-rock-5b-5bp-5t.dtsi	2026-02-19 16:33:27.000000000 +0100
+++ linux-6.19.3/arch/arm64/boot/dts/rockchip/rk3588-rock-5b-5bp-5t.dtsi	2026-02-23 16:48:19.631883865 +0100
@@ -10,8 +10,8 @@
 
 / {
 	aliases {
-		mmc0 = &sdhci;
-		mmc1 = &sdmmc;
+		mmc0 = &sdmmc;
+		mmc1 = &sdhci;
 		mmc2 = &sdio;
 	};
 
@@ -49,6 +49,12 @@
 		#cooling-cells = <2>;
 	};
 
+	usbc_vin6_1 {
+		compatible = "iio-hwmon";
+		io-channels = <&saradc 0 &saradc 1 &saradc 2 &saradc 3 &saradc 4 &saradc 5 &saradc 6 &saradc 7>;
+		status = "okay";
+	};
+
 	rfkill-bt {
 		compatible = "rfkill-gpio";
 		label = "rfkill-m2-bt";
@@ -590,8 +618,10 @@
 	no-sdio;
 	no-sd;
 	non-removable;
-	mmc-hs400-1_8v;
-	mmc-hs400-enhanced-strobe;
+	max-frequency = <150000000>;
+	mmc-hs200-1_8v;
+	vmmc-supply = <&vcc_3v3_s3>;
+	vqmmc-supply = <&vcc_1v8_s3>;
 	status = "okay";
 };
 
diff --speed-large-files --no-dereference --minimal -Naur linux-6.19.3/arch/arm64/boot/dts/rockchip/rk3588-rock-5b.dtsi linux-6.19.3/arch/arm64/boot/dts/rockchip/rk3588-rock-5b.dtsi
--- linux-6.19.3/arch/arm64/boot/dts/rockchip/rk3588-rock-5b.dtsi	2026-02-19 16:33:27.000000000 +0100
+++ linux-6.19.3/arch/arm64/boot/dts/rockchip/rk3588-rock-5b.dtsi	2026-02-23 14:19:25.309383224 +0100
@@ -28,10 +28,10 @@
 		pinctrl-0 = <&led_rgb_b>;
 
 		led_rgb_b {
-			function = LED_FUNCTION_STATUS;
+			function = LED_FUNCTION_DISK_ACTIVITY;
 			color = <LED_COLOR_ID_BLUE>;
 			gpios = <&gpio0 RK_PB7 GPIO_ACTIVE_HIGH>;
-			linux,default-trigger = "heartbeat";
+			linux,default-trigger = "disk-activity";
 		};
 	};
 

