+	/* 	drm_for_each_encoder_mask(encoder, crtc->dev, crtc->state->encoder_mask) { */
+	/* 		dev_dbg(crtc->dev->dev, "** encoder name=%s type=%d\n", */
+	/* 			encoder->name, encoder->encoder_type); */
+	/* 		drm_for_each_bridge_in_chain(encoder, bridge) */
+	/* 			dev_dbg(crtc->dev->dev, "  - bridge type=%d\n", bridge->type); */
+	/* 	} */
+	/**/
+	/* 	dev_dbg(crtc->dev->dev, "** iter connectors\n"); */
+	/* 	drm_connector_list_iter_begin(crtc->dev, &conn_iter); */
+	/* 	drm_for_each_connector_iter(connector, &conn_iter) */
+	/* 		if (crtc->state->connector_mask & drm_connector_mask(connector)) */
+	/* 			dev_dbg(crtc->dev->dev, " - connector name=%s type=%d\n", */
+	/* 				connector->name, connector->connector_type); */
+	/* 	drm_connector_list_iter_end(&conn_iter); */
+	/* } */
+
+	ret = vop2_crtc_validate_crc_source(crtc, source, &crc_source);
+	if (ret < 0)
+		return ret;
+
+	switch (crc_source) {
+	case ROCKCHIP_DRM_CRC_SOURCE_NONE:
+	case ROCKCHIP_DRM_CRC_SOURCE_AUTO:
+		break;
+	case ROCKCHIP_DRM_CRC_SOURCE_CRTC:
+		*values_cnt = 1;
+		break;
+	case ROCKCHIP_DRM_CRC_SOURCE_DP:
+	case ROCKCHIP_DRM_CRC_SOURCE_EDP:
+		*values_cnt = 3;
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	return 0;
+}
