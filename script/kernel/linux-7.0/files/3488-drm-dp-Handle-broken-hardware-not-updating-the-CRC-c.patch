From 0aa7ab48865d04cf79bde9a41d28f711da8cb70a Mon Sep 17 00:00:00 2001
From: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
Date: Mon, 10 Nov 2025 10:55:02 +0200
Subject: [PATCH 076/114] drm/dp: Handle broken hardware not updating the CRC
 counter

Detect broken hardware not incrementing the CRC counter when a TEST_CRC
related register is updated.  This requires waiting for additional
vblanks before relying on the values stored in the TEST_CRC-related
registers.

Signed-off-by: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
---
 drivers/gpu/drm/display/drm_dp_helper.c | 40 ++++++++++++++++++++-----
 include/drm/display/drm_dp_helper.h     |  5 ++++
 2 files changed, 37 insertions(+), 8 deletions(-)

diff --git a/drivers/gpu/drm/display/drm_dp_helper.c b/drivers/gpu/drm/display/drm_dp_helper.c
index 4b252ff533..dac51e2a58 100644
--- a/drivers/gpu/drm/display/drm_dp_helper.c
+++ b/drivers/gpu/drm/display/drm_dp_helper.c
@@ -2267,15 +2267,20 @@ static int drm_dp_aux_get_crc(struct drm_dp_aux *aux, u8 *crc)
 
 	WARN_ON(!(buf & DP_TEST_SINK_START));
 
-	ret = drm_dp_dpcd_read_byte(aux, DP_TEST_SINK_MISC, &buf);
-	if (ret < 0)
-		return ret;
+	if (!aux->crc_count_broken) {
+		ret = drm_dp_dpcd_read_byte(aux, DP_TEST_SINK_MISC, &buf);
+		if (ret < 0)
+			return ret;
 
-	count = buf & DP_TEST_COUNT_MASK;
-	if (count == aux->crc_count)
-		return -EAGAIN; /* No CRC yet */
+		count = buf & DP_TEST_COUNT_MASK;
+		if (!count && !aux->crc_count)
+			return -ENOENT;
 
-	aux->crc_count = count;
+		if (count == aux->crc_count)
+			return -EAGAIN; /* No CRC yet */
+
+		aux->crc_count = count;
+	}
 
 	/*
 	 * At DP_TEST_CRC_R_CR, there's 6 bytes containing CRC data, 2 bytes
@@ -2291,7 +2296,7 @@ static void drm_dp_aux_crc_work(struct work_struct *work)
 	struct drm_crtc *crtc;
 	u8 crc_bytes[6];
 	uint32_t crcs[3];
-	int ret;
+	int ret, tries = 0;
 
 	if (WARN_ON(!aux->crtc))
 		return;
@@ -2299,10 +2304,29 @@ static void drm_dp_aux_crc_work(struct work_struct *work)
 	crtc = aux->crtc;
 	while (crtc->crc.opened) {
 		drm_crtc_wait_one_vblank(crtc);
+
+		/* Wait for additional vblanks on broken hardware */
+		if (aux->crc_count_broken)
+			for (int i = 0; i < 5 && crtc->crc.opened; i++)
+				drm_crtc_wait_one_vblank(crtc);
+
 		if (!crtc->crc.opened)
 			break;
 
 		ret = drm_dp_aux_get_crc(aux, crc_bytes);
+
+		/* Verify if CRC counter is functional */
+		if (ret == -ENOENT) {
+			if (++tries < 4)
+				continue;
+
+			aux->crc_count_broken = true;
+			//TODO: switch to drm_dbg
+			dev_warn(aux->drm_dev->dev, "%s: CRC counter is broken\n", aux->name);
+
+			ret = drm_dp_aux_get_crc(aux, crc_bytes);
+		}
+
 		if (ret == -EAGAIN) {
 			usleep_range(1000, 2000);
 			ret = drm_dp_aux_get_crc(aux, crc_bytes);
diff --git a/include/drm/display/drm_dp_helper.h b/include/drm/display/drm_dp_helper.h
index 1d0acd58f4..68a95881ba 100644
--- a/include/drm/display/drm_dp_helper.h
+++ b/include/drm/display/drm_dp_helper.h
@@ -431,6 +431,11 @@ struct drm_dp_aux {
 	 */
 	u8 crc_count;
 
+	/**
+	 * @crc_count_broken: crc_count not supported by (broken) hardware
+	 */
+	bool crc_count_broken;
+
 	/**
 	 * @transfer: transfers a message representing a single AUX
 	 * transaction.
-- 
2.53.0

