From e46fb485e8f392ec2869c5f0ecfb188d06590008 Mon Sep 17 00:00:00 2001
From: Justin Suess <utilityemal77@gmail.com>
Date: Sat, 4 Jul 2026 16:17:24 -0400
Subject: [PATCH 09/14] drm/sun4i: sun55i_de: bypass the VSU for unscaled
 layers

This channel's (UCH0) scaler line buffer is only 2560 pixels wide
(de352_feat scale_line_buffer_rgb), so running an "unscaled" layer
through the VSU with a unity step corrupts every line of a 3840-wide
layer beyond pixel 2560 - the static right third of the screen at 4K
(live-verified: VSU_CTL=1 broken, VSU_CTL=0 perfect).

Bypass the VSU entirely (ctl.en=0) when src == dst; the channel then
passes pixels through untouched and the line buffer is not used. Actual
scaling of layers wider than the line buffer would need the overlay
coarse down-sampler or a different channel; still not handled here.
---
 drivers/gpu/drm/sun4i/sun55i_de.c | 21 ++++++++++++++++-----
 1 file changed, 16 insertions(+), 5 deletions(-)

diff --git a/drivers/gpu/drm/sun4i/sun55i_de.c b/drivers/gpu/drm/sun4i/sun55i_de.c
index 5f26c1d7b10d..1dc3758fa977 100644
--- a/drivers/gpu/drm/sun4i/sun55i_de.c
+++ b/drivers/gpu/drm/sun4i/sun55i_de.c
@@ -639,14 +639,19 @@ static u32 sun55i_de_vsu_step(u32 src, u32 dst)
 /*
  * Stage the VSU8 scaler to resample the @src_w x @src_h overlay output up/down
  * to the on-screen @dst_w x @dst_h the blender expects (de_vsu8_set_para +
- * de_vsu_calc_lay_scale_para for an RGB layer). The channel datapath always
- * runs through the VSU, so this is also what makes an "unscaled" 1:1 layer
- * correct: src==dst yields a unity step and the centre-tap phase set.
+ * de_vsu_calc_lay_scale_para for an RGB layer).
+ *
+ * A 1:1 layer must BYPASS the VSU (ctl.en=0), not run a unity step through it:
+ * this channel's (UCH0) scaler line buffer is only 2560 px wide (de352_feat
+ * scale_line_buffer_rgb), so an enabled VSU corrupts every line of a 3840-wide
+ * layer beyond px 2560 (the "static right third" at 4K; live-verified
+ * VSU_CTL=1 -> broken, VSU_CTL=0 -> perfect). Bypassed, the channel passes
+ * pixels through untouched and the line buffer is not used.
  *
  * For RGB the chroma parameters equal the luma ones. Phase is left at 0 (whole-
  * pixel crop origin); the hardware accumulates per-output sub-pixel phase from
- * the step. Extreme downscale beyond the VSU line buffer would need the overlay
- * coarse down-sampler too; not handled here.
+ * the step. Actual scaling of layers wider than the line buffer needs the
+ * overlay coarse down-sampler / a different channel; not handled here.
  */
 static void sun55i_de_vsu_setup(struct sun8i_mixer *mixer,
 				u32 src_w, u32 src_h, u32 dst_w, u32 dst_h)
@@ -665,6 +670,12 @@ static void sun55i_de_vsu_setup(struct sun8i_mixer *mixer,
 	yp   = de_blk(mixer, SUN55I_DE_BLK_VSU_YPARA);
 	cp   = de_blk(mixer, SUN55I_DE_BLK_VSU_CPARA);
 
+	if (src_w == dst_w && src_h == dst_h) {
+		/* 1:1: bypass the scaler entirely (see comment above) */
+		de_blk_write(ctl, 0, 0);
+		return;
+	}
+
 	/* ctl.en=1; scale_mode stays 0 (RGB) from the zeroed shadow */
 	de_blk_write(ctl, 0, SUN55I_VSU_CTL_EN);
 
