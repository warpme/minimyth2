+/**
+ * drm_hdmi_forum_vendor_infoframe_from_display_mode() - fill an HF-VSIF with
+ * data from a DRM display mode
+ * @frame: HDMI Forum Vendor InfoFrame
+ * @connector: the connector
+ * @mode: DRM display mode
+ *
+ * TODO: update comment: HDMI 2.1 spec provides list of features that require
+ * transmission of the HF-VSIF, however we only consider ALLM for now.
+ *
+ * Return: 0 on success or a negative error code on failure.
+ */
+int
+drm_hdmi_forum_vendor_infoframe_from_display_mode(struct hdmi_forum_vendor_infoframe *frame,
+						  const struct drm_connector *connector,
+						  const struct drm_display_mode *mode)
+{
+	bool has_hdmi_infoframe = connector ?
+		connector->display_info.has_hdmi_infoframe : false;
+	int err;
+
+	if (!frame || !mode || !has_hdmi_infoframe)
+		return -EINVAL;
+
+	err = hdmi_forum_vendor_infoframe_init(frame);
+	if (err < 0)
+		return err;
+
+	//TODO: handle HDMI VIC as part of AVI infoframe?!
+	frame->s3d_f_struct = s3d_structure_from_display_mode(mode);
+	frame->s3d_valid = (frame->s3d_f_struct != HDMI_3D_STRUCTURE_INVALID);
+
+	return 0;
+}
+EXPORT_SYMBOL(drm_hdmi_forum_vendor_infoframe_from_display_mode);
