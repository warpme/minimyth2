From 26f558dcb0a106bbca69e90af9fc0b92c239d918 Mon Sep 17 00:00:00 2001
From: Xilin Wu <sophon@radxa.com>
Date: Tue, 12 May 2026 23:03:43 +0800
Subject: [PATCH 142/309] drm/msm/dp: Keep branch sink count in sync

msm_dp_panel_read_sink_caps() reads the downstream sink count for branch
devices, but only updates link->sink_count when the count is zero. Keep
the cached sink count in sync for non-zero values as well, and propagate
read errors instead of treating them like a disconnected downstream sink.

This avoids leaving stale sink_count state behind after a branch device
reports a changed downstream connection state.

Fixes: b7ba5db9c863 ("drm/msm/dp: Use drm_dp_read_sink_count() helper")
Signed-off-by: Xilin Wu <sophon@radxa.com>
---
 drivers/gpu/drm/msm/dp/dp_panel.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/drivers/gpu/drm/msm/dp/dp_panel.c b/drivers/gpu/drm/msm/dp/dp_panel.c
index 4b0946d43..04bb91970 100644
--- a/drivers/gpu/drm/msm/dp/dp_panel.c
+++ b/drivers/gpu/drm/msm/dp/dp_panel.c
@@ -273,8 +273,11 @@ int msm_dp_panel_read_sink_caps(struct msm_dp_panel *msm_dp_panel,
 
 	if (drm_dp_is_branch(msm_dp_panel->dpcd)) {
 		count = drm_dp_read_sink_count(panel->aux);
+		if (count < 0)
+			return count;
+
+		panel->link->sink_count = count;
 		if (!count) {
-			panel->link->sink_count = 0;
 			msm_dp_panel_clear_sink_caps(msm_dp_panel, connector, panel->aux);
 			return -ENOTCONN;
 		}
