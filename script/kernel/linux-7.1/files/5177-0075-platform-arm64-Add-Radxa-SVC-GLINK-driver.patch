+static ssize_t radxa_svc_profile_write(struct file *file, const char __user *buf,
+				       size_t count, loff_t *ppos)
+{
+	struct seq_file *s = file->private_data;
+	struct radxa_svc_glink *svc = s->private;
+	char input[32];
