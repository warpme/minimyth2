From 793e733be3553a149ec53d90ed7ccbd3c3eab493 Mon Sep 17 00:00:00 2001
From: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
Date: Thu, 3 Jul 2025 12:42:38 +0300
Subject: [PATCH 109/114] [WIP-FRL] drm/bridge: dw-hdmi-qp: Add HDMI 2.1 FRL
 support

Implement the link training state machine required to support HDMI 2.1
FRL display modes.

This has been verified up to 4K@160Hz, although the actual refresh rate
(as indicated by the display) seems to not exceed 130Hz.  Note the
RK3588 TRM only mentions the 4K@120Hz and 8K@60Hz modes as being
supported by the HDMI TX Controller, hence it's not entirely clear what
is the actual hardware limitation.

Signed-off-by: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
---
 drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c | 596 ++++++++++++++++++-
 drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.h |   1 +
 include/drm/bridge/dw_hdmi_qp.h              |  11 +
 3 files changed, 582 insertions(+), 26 deletions(-)

diff --git a/drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c b/drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c
index 79cb042a15..b533b5d800 100644
--- a/drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c
+++ b/drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c
@@ -44,10 +44,27 @@
 
 #define HDMI14_MAX_TMDSCLK	340000000
 #define HDMI20_MAX_TMDSRATE	600000000
+#define HDMI21_MAX_SUPPRATE	4800000000
 
 #define SCDC_MIN_SOURCE_VERSION	0x1
 #define SCRAMB_POLL_DELAY_MS	5000
 
+/*
+ * Recommended N and Expected CTS Values in FRL Mode.
+ */
+static const struct dw_hdmi_qp_audio_frl_n {
+	unsigned int r_bit;
+	unsigned int n_32k;
+	unsigned int n_44k1;
+	unsigned int n_48k;
+} common_frl_n_table[] = {
+	{ .r_bit = 3,  .n_32k = 4224, .n_44k1 = 5292, .n_48k = 5760, },
+	{ .r_bit = 6,  .n_32k = 4032, .n_44k1 = 5292, .n_48k = 6048, },
+	{ .r_bit = 8,  .n_32k = 4032, .n_44k1 = 3969, .n_48k = 6048, },
+	{ .r_bit = 10, .n_32k = 3456, .n_44k1 = 3969, .n_48k = 5184, },
+	{ .r_bit = 12, .n_32k = 3072, .n_44k1 = 3969, .n_48k = 4752, },
+};
+
 /*
  * Unless otherwise noted, entries in this table are 100% optimization.
  * Values can be obtained from dw_hdmi_qp_compute_n() but that function is
@@ -175,10 +192,14 @@ struct dw_hdmi_qp {
 	struct delayed_work scramb_work;
 	bool scramb_enabled;
 
+	struct work_struct flt_work;
+	bool flt_no_timeout;
+
 	struct regmap *regm;
 	int main_irq;
 
-	unsigned long tmds_char_rate;
+	//TODO: store tmds_char_rate in struct dw_hdmi_qp_link_config
+	unsigned long long tmds_char_rate;
 	bool no_hpd;
 };
 
@@ -226,6 +247,49 @@ static void dw_hdmi_qp_set_cts_n(struct dw_hdmi_qp *hdmi, unsigned int cts,
 		       AUDPKT_ACR_CONTROL1);
 }
 
+static int dw_hdmi_qp_match_frl_n_table(struct dw_hdmi_qp *hdmi,
+					unsigned long r_bit,
+					unsigned long freq)
+{
+	const struct dw_hdmi_qp_audio_frl_n *frl_n = NULL;
+	int i, n;
+
+	for (i = 0; ARRAY_SIZE(common_frl_n_table); i++) {
+		if (r_bit == common_frl_n_table[i].r_bit) {
+			frl_n = &common_frl_n_table[i];
+			break;
+		}
+	}
+
+	if (!frl_n) {
+		dev_err(hdmi->dev, "Unexpected FRL Rbit: %lu Gbps\n", r_bit);
+		return 0;
+	}
+
+	switch (freq) {
+	case 32000:
+	case 64000:
+	case 128000:
+		n = (freq / 32000) * frl_n->n_32k;
+		break;
+	case 44100:
+	case 88200:
+	case 176400:
+		n = (freq / 44100) * frl_n->n_44k1;
+		break;
+	case 48000:
+	case 96000:
+	case 192000:
+		n = (freq / 48000) * frl_n->n_48k;
+		break;
+	default:
+		dev_err(hdmi->dev, "Unexpected FRL freq: %lu Hz\n", freq);
+		n = 0;
+	}
+
+	return n;
+}
+
 static int dw_hdmi_qp_match_tmds_n_table(struct dw_hdmi_qp *hdmi,
 					 unsigned long pixel_clk,
 					 unsigned long freq)
@@ -307,6 +371,15 @@ static unsigned int dw_hdmi_qp_compute_n(struct dw_hdmi_qp *hdmi,
 static unsigned int dw_hdmi_qp_find_n(struct dw_hdmi_qp *hdmi, unsigned long pixel_clk,
 				      unsigned long sample_rate)
 {
+	if (hdmi->phy.ops->get_link_cfg) {
+		const struct dw_hdmi_qp_link_config *link_cfg;
+		link_cfg = hdmi->phy.ops->get_link_cfg(hdmi, hdmi->phy.data);
+		if (link_cfg->frl_enabled)
+			return dw_hdmi_qp_match_frl_n_table(hdmi,
+							    link_cfg->frl_rate_per_lane,
+							    sample_rate);;
+	}
+
 	int n = dw_hdmi_qp_match_tmds_n_table(hdmi, pixel_clk, sample_rate);
 
 	if (n > 0)
@@ -760,6 +833,428 @@ static struct i2c_adapter *dw_hdmi_qp_i2c_adapter(struct dw_hdmi_qp *hdmi)
 	return adap;
 }
 
+static int dw_hdmi_qp_frl_rate_to_scdc(unsigned long frl_rate)
+{
+	switch (frl_rate) {
+	case 48:
+		return SCDC_FRL_RATE_12GBPS_4LANE;
+	case 40:
+		return SCDC_FRL_RATE_10GBPS_4LANE;
+	case 32:
+		return SCDC_FRL_RATE_8GBPS_4LANE;
+	case 24:
+		return SCDC_FRL_RATE_6GBPS_4LANE;
+	case 18:
+		return SCDC_FRL_RATE_6GBPS_3LANE;
+	case 9:
+		return SCDC_FRL_RATE_3GBPS_3LANE;
+	}
+
+	return 0;
+}
+
+static int dw_hdmi_qp_frl_scdc_to_rate(u8 frl_scdc)
+{
+	switch (frl_scdc) {
+	case SCDC_FRL_RATE_12GBPS_4LANE:
+		return 48;
+	case SCDC_FRL_RATE_10GBPS_4LANE:
+		return 40;
+	case SCDC_FRL_RATE_8GBPS_4LANE:
+		return 32;
+	case SCDC_FRL_RATE_6GBPS_4LANE:
+		return 24;
+	case SCDC_FRL_RATE_6GBPS_3LANE:
+		return 18;
+	case SCDC_FRL_RATE_3GBPS_3LANE:
+		return 9;
+	}
+
+	return 0;
+}
+
+enum dw_hdmi_qp_flt_state {
+	LTS1,	/* Read EDID */
+	LTS2,	/* Prepare for FRL */
+	LTS3,	/* Training in progress */
+	LTS4,	/* Update FRL rate */
+	LTSP,	/* Training passed */
+	LTSL,	/* Exit FRL mode */
+};
+
+/* FRL training max ffe level: 0..3 */
+#define MAX_FFE_LEVEL	0
+
+static bool dw_hdmi_qp_is_disabled(struct dw_hdmi_qp *hdmi)
+{
+	return hdmi->phy.ops->read_hpd(hdmi, hdmi->phy.data) == connector_status_disconnected;
+}
+
+/* Check sink version and FLT no-timeout mode. */
+static int dw_hdmi_qp_flt_lts1(struct dw_hdmi_qp *hdmi)
+{
+	u8 val = 0;
+
+	if (!hdmi->tmds_char_rate) {
+		dev_err(hdmi->dev, "lts1: hdmi dclk is disabled\n");
+		return LTSL;
+	}
+
+	dw_hdmi_qp_mod(hdmi, AVP_DATAPATH_VIDEO_SWDISABLE,
+		       AVP_DATAPATH_VIDEO_SWDISABLE, GLOBAL_SWDISABLE);
+
+	/* Reset AVP data path */
+	dw_hdmi_qp_write(hdmi, AVP_DATAPATH_SWINIT_P, GLOBAL_SWRESET_REQUEST);
+
+	drm_scdc_readb(hdmi->bridge.ddc, SCDC_SINK_VERSION, &val);
+	if (!val) {
+		dev_err(hdmi->dev, "lts1: SCDC sink version is zero\n");
+		return LTSL;
+	}
+
+	drm_scdc_writeb(hdmi->bridge.ddc, SCDC_SOURCE_VERSION, 1);
+
+	drm_scdc_readb(hdmi->bridge.ddc, SCDC_SOURCE_TEST_CONFIG, &val);
+	hdmi->flt_no_timeout = !!(val & SCDC_FLT_NO_TIMEOUT);
+
+	return LTS2;
+}
+
+/*
+ * Check if sink is ready to training.
+ * Set source output frl rate & max ffe level.
+ */
+static int dw_hdmi_qp_flt_lts2(struct dw_hdmi_qp *hdmi, unsigned long rate)
+{
+	u8 scdc_rate = dw_hdmi_qp_frl_rate_to_scdc(rate);
+	u8 val = 0;
+	int i;
+
+	for (i = 0; i < 20; i++) {
+		drm_scdc_readb(hdmi->bridge.ddc, SCDC_STATUS_FLAGS_0, &val);
+		if (val & SCDC_FLT_READY)
+			break;
+		msleep(20);
+	}
+
+	if (i == 20) {
+		dev_err(hdmi->dev, "lts2: sink flt isn't ready (SCDC_STATUS_FLAGS_0=0x%x)\n", val);
+		return LTSL;
+	}
+
+	val = MAX_FFE_LEVEL << 4 | scdc_rate;
+	drm_scdc_writeb(hdmi->bridge.ddc, SCDC_CONFIG_1, val);
+	drm_scdc_writeb(hdmi->bridge.ddc, SCDC_CONFIG_0, 0);
+
+	return LTS3;
+}
+
+static void dw_hdmi_qp_set_ltp(struct dw_hdmi_qp *hdmi, u32 value, bool flt_no_timeout)
+{
+	/* Support hfr1-10, send old ltp when all lane is 3 */
+	if (!flt_no_timeout && value == 0x3333f)
+		value = dw_hdmi_qp_read(hdmi, FLT_CONFIG1);
+
+	dw_hdmi_qp_write(hdmi, value, FLT_CONFIG1);
+}
+
+/*
+ * Conduct link training for the specified frl rate.
+ * Send sink request ltp or change ffe level.
+ */
+static int dw_hdmi_qp_flt_lts3(struct dw_hdmi_qp *hdmi, unsigned long rate)
+{
+	u8 val;
+	int i = 0, ret = 0;
+	u8 src_test_cfg = 0;
+	u32 value;
+	u8 ffe_lv = 0;
+
+	/* Set max 2s timeout */
+	i = 4000;
+	while (i-- > 0 || hdmi->flt_no_timeout) {
+		if (dw_hdmi_qp_is_disabled(hdmi)) {
+			dev_dbg(hdmi->dev, "lts3: hdmi dclk is disabled, stop flt\n");
+			break;
+		}
+
+		/* source should poll update flag every 2ms or less */
+		usleep_range(400, 500);
+
+		drm_scdc_readb(hdmi->bridge.ddc, SCDC_UPDATE_0, &val);
+
+		if (val & SCDC_SOURCE_TEST_UPDATE) {
+			/* Quit test mode */
+			drm_scdc_readb(hdmi->bridge.ddc, SCDC_SOURCE_TEST_CONFIG, &src_test_cfg);
+
+			if (hdmi->flt_no_timeout && !(src_test_cfg & SCDC_FLT_NO_TIMEOUT)) {
+				dev_dbg(hdmi->dev, "lts3: exit test mode\n");
+				hdmi->flt_no_timeout = false;
+			} else if (!hdmi->flt_no_timeout && (src_test_cfg & SCDC_FLT_NO_TIMEOUT)) {
+				dev_dbg(hdmi->dev, "lts3: enter test mode\n");
+				hdmi->flt_no_timeout = true;
+			}
+		}
+
+		if (!(val & SCDC_CONFIG_0)) {
+			/* Clear SOURCE_TEST_UPDATE flag */
+			if (val & SCDC_SOURCE_TEST_UPDATE)
+				drm_scdc_writeb(hdmi->bridge.ddc, SCDC_UPDATE_0, val);
+			continue;
+		}
+
+		if (val & SCDC_FLT_UPDATE) {
+			u8 reg_val, ln0, ln1, ln2, ln3;
+
+			drm_scdc_readb(hdmi->bridge.ddc, SCDC_STATUS_FLAGS_1, &reg_val);
+			ln0 = reg_val & 0xf;
+			ln1 = (reg_val >> 4) & 0xf;
+
+			drm_scdc_readb(hdmi->bridge.ddc, SCDC_STATUS_FLAGS_2, &reg_val);
+			ln2 = reg_val & 0xf;
+			ln3 = (reg_val >> 4) & 0xf;
+
+			dev_dbg(hdmi->dev, "lts3: ln0=0x%x ln1=0x%x ln0x%x ln3=0x%x\n",
+				ln0, ln1, ln2, ln3);
+
+			if (!ln0 && !ln1 && !ln2 && !ln3) {
+				dev_dbg(hdmi->dev, "lts3: flt completed, go to ltsp\n");
+				if (hdmi->tmds_char_rate) {
+					dw_hdmi_qp_write(hdmi, 0, FLT_CONFIG1);
+					ret = LTSP;
+				} else {
+					dev_err(hdmi->dev, "lts3: hdmi dclk is disabled, goto ltsp\n");
+					ret = LTSL;
+				}
+			} else if ((ln0 == 0xf) || (ln1 == 0xf) || (ln2 == 0xf) || (ln3 == 0xf)) {
+				dev_dbg(hdmi->dev, "lts3: goto lts4\n");
+				ret = LTS4;
+			} else if ((ln0 == 0xe) || (ln1 == 0xe) || (ln2 == 0xe) || (ln3 == 0xe)) {
+				if (ffe_lv < 3) {
+					++ffe_lv;
+					dev_dbg(hdmi->dev, "lts3: set ffe=%d\n", ffe_lv);
+					//TODO: set_ffe()
+					/* hdmi->phy.ops->set_ffe(hdmi, hdmi->phy.data, ++ffe_lv); */
+				} else {
+					dev_err(hdmi->dev, "lts3: ffe level out of range\n");
+					ret = LTSL;
+				}
+			} else {
+				if (hdmi->tmds_char_rate) {
+					value = (ln3 << 16) | (ln2 << 12) | (ln1 << 8) |
+						(ln0 << 4) | 0xf;
+
+					dw_hdmi_qp_set_ltp(hdmi, value, hdmi->flt_no_timeout);
+				} else {
+					dev_err(hdmi->dev, "lts3: hdmi dclk is disabled, set ltp failed\n");
+					ret = LTSL;
+				}
+			}
+
+			/* Clear FLT_UPDATE flag */
+			drm_scdc_writeb(hdmi->bridge.ddc, SCDC_UPDATE_0, val);
+		}
+
+		if (ret)
+			break;
+	}
+
+	if (!ret) {
+		ret = LTSL;
+		dev_err(hdmi->dev, "lts3 time out, goto ltsl\n");
+	}
+
+	return ret;
+}
+
+/* Sink requests frl rate change, start training for a new rate. */
+static int dw_hdmi_qp_flt_lts4(struct dw_hdmi_qp *hdmi, unsigned long *rate)
+{
+	u8 scdc_rate = dw_hdmi_qp_frl_rate_to_scdc(*rate);
+	void *data = hdmi->phy.data;
+	unsigned long actual_rate;
+
+	/* Don't use frl rates below 32G */
+	if (scdc_rate == SCDC_FRL_RATE_8GBPS_4LANE) {
+		dev_err(hdmi->dev, "lts4: 32G limit reached, goto ltsl\n");
+		return LTSL;
+	}
+
+	/* Disable phy */
+	hdmi->phy.ops->disable(hdmi, hdmi->phy.data);
+
+	/* Set lower frl rate */
+	scdc_rate--;
+	actual_rate = dw_hdmi_qp_frl_scdc_to_rate(scdc_rate);
+	if (hdmi->phy.ops->force_link_rate) {
+		//TODO: handle error
+		hdmi->phy.ops->force_link_rate(hdmi, data, actual_rate);
+	}
+
+	/* Enable phy */
+	//TODO: previous_mode needed?!
+	/* hdmi->phy.ops->init(hdmi, hdmi->phy.data, &hdmi->previous_mode); */
+	hdmi->phy.ops->init(hdmi, hdmi->phy.data);
+
+	/* Set new rate */
+	*rate = actual_rate;
+	drm_scdc_writeb(hdmi->bridge.ddc, SCDC_CONFIG_1, (MAX_FFE_LEVEL << 4 | scdc_rate));
+	drm_scdc_writeb(hdmi->bridge.ddc, SCDC_UPDATE_0, SCDC_FLT_UPDATE);
+
+	dev_dbg(hdmi->dev, "lts4: goto lts3\n");
+	return LTS3;
+}
+
+/*
+ * Training passed, start sink polling to check if sink requests changing rate
+ * or exiting frl mode.
+ */
+static int dw_hdmi_qp_flt_ltsp(struct dw_hdmi_qp *hdmi)
+{
+	u8 val = 0;
+	int i = 4000;
+
+	/* Wait for frl start */
+	while (i--) {
+		if (dw_hdmi_qp_is_disabled(hdmi)) {
+			dev_dbg(hdmi->dev, "hdmi dclk is disabled, quit ltsp\n");
+			return LTSL;
+		}
+
+		/* Source should poll update flag every 2ms or less */
+		usleep_range(400, 500);
+
+		drm_scdc_readb(hdmi->bridge.ddc, SCDC_UPDATE_0, &val);
+
+		if (!(val & SCDC_CONFIG_0))
+			continue;
+
+		if (hdmi->tmds_char_rate) {
+			if (val & SCDC_FRL_START) {
+				dw_hdmi_qp_mod(hdmi, 0, AVP_DATAPATH_VIDEO_SWDISABLE, GLOBAL_SWDISABLE);
+				drm_scdc_writeb(hdmi->bridge.ddc, SCDC_UPDATE_0, SCDC_FRL_START);
+				dw_hdmi_qp_write(hdmi, 2, PKTSCHED_PKT_CONTROL0);
+				dw_hdmi_qp_mod(hdmi, PKTSCHED_GCP_TX_EN, PKTSCHED_GCP_TX_EN,
+					       PKTSCHED_PKT_EN);
+				dev_dbg(hdmi->dev, "flt success\n");
+				break;
+			} else if (val & SCDC_FLT_UPDATE) {
+				dw_hdmi_qp_mod(hdmi, AVP_DATAPATH_VIDEO_SWDISABLE,
+					       AVP_DATAPATH_VIDEO_SWDISABLE, GLOBAL_SWDISABLE);
+				drm_scdc_writeb(hdmi->bridge.ddc, SCDC_UPDATE_0, SCDC_FLT_UPDATE);
+				return LTS3;
+			}
+		} else {
+			dev_err(hdmi->dev, "frl start failed (hdmi dclk is disabled)\n");
+			return LTSL;
+		}
+	}
+
+	if (i < 0) {
+		dev_err(hdmi->dev, "frl start timed out (SCDC_UPDATE_0=0x%x)\n", val);
+		return LTSL;
+	}
+
+	/*
+	 * After flt success, source shall poll update_flag at least once
+	 * every 250ms.
+	 */
+	i = 5;
+	while (1) {
+		if (!hdmi->tmds_char_rate) {
+			dev_dbg(hdmi->dev, "hdmi disconnected, stop poll flt_update\n");
+			return LTSL;
+		}
+
+		if (!i) {
+			i = drm_scdc_readb(hdmi->bridge.ddc, SCDC_UPDATE_0, &val);
+			if (i) {
+				dev_dbg(hdmi->dev, "DDC communication failed, stop poll flt_update\n");
+				return LTSL;
+			}
+
+			if (val & SCDC_FLT_UPDATE) {
+				dw_hdmi_qp_write(hdmi, 1, PKTSCHED_PKT_CONTROL0);
+				dw_hdmi_qp_mod(hdmi, PKTSCHED_GCP_TX_EN, PKTSCHED_GCP_TX_EN,
+					       PKTSCHED_PKT_EN);
+				msleep(50);
+				dw_hdmi_qp_mod(hdmi, AVP_DATAPATH_VIDEO_SWDISABLE,
+					       AVP_DATAPATH_VIDEO_SWDISABLE, GLOBAL_SWDISABLE);
+				drm_scdc_writeb(hdmi->bridge.ddc, SCDC_UPDATE_0, SCDC_FLT_UPDATE);
+				return LTS2;
+			}
+
+			i = 5;
+		}
+
+		msleep(20);
+		i--;
+	}
+
+	return LTSL;
+}
+
+/* Exit frl mode, i.e. for training failures or hdmi disabled. */
+static int dw_hdmi_qp_flt_ltsl(struct dw_hdmi_qp *hdmi)
+{
+	/* if (hdmi->frl_switch) */
+	/* 	return -EINVAL; */
+
+	if (!dw_hdmi_qp_is_disabled(hdmi)) {
+		drm_scdc_writeb(hdmi->bridge.ddc, SCDC_CONFIG_1, 0);
+		drm_scdc_writeb(hdmi->bridge.ddc, SCDC_UPDATE_0, SCDC_FLT_UPDATE);
+	}
+
+	return -EINVAL;
+}
+
+static void dw_hdmi_qp_flt_work(struct work_struct *work)
+{
+	struct dw_hdmi_qp *hdmi = container_of(work, struct dw_hdmi_qp, flt_work);
+	const struct dw_hdmi_qp_link_config *link_cfg;
+	unsigned long frl_rate;
+	int state = LTS1;
+
+	link_cfg = hdmi->phy.ops->get_link_cfg(hdmi, hdmi->phy.data);
+	frl_rate = link_cfg->frl_lanes * link_cfg->frl_rate_per_lane;
+
+	dev_dbg(hdmi->dev, "%s tmds_rate=%llu frl_rate=%lu\n", __func__,
+		hdmi->tmds_char_rate, frl_rate);
+
+	/* if (hdmi->frl_switch) */
+	/* 	return; */
+
+	while (1) {
+		switch (state) {
+		case LTS1:
+			state = dw_hdmi_qp_flt_lts1(hdmi);
+			break;
+		case LTS2:
+			state = dw_hdmi_qp_flt_lts2(hdmi, frl_rate);
+			break;
+		case LTS3:
+			state = dw_hdmi_qp_flt_lts3(hdmi, frl_rate);
+			break;
+		case LTS4:
+			state = dw_hdmi_qp_flt_lts4(hdmi, &frl_rate);
+			break;
+		case LTSP:
+			state = dw_hdmi_qp_flt_ltsp(hdmi);
+			break;
+		case LTSL:
+			state = dw_hdmi_qp_flt_ltsl(hdmi);
+			break;
+		default:
+			dev_err(hdmi->dev, "flt failed: state=%d\n", state);
+		}
+
+		if (state <= 0) {
+			dev_dbg(hdmi->dev, "%s stopped\n", __func__);
+			break;
+		}
+	}
+}
+
 static bool dw_hdmi_qp_supports_scrambling(struct drm_display_info *display)
 {
 	if (!display->is_hdmi)
@@ -896,7 +1391,6 @@ static void dw_hdmi_qp_bridge_atomic_enable(struct drm_bridge *bridge,
 	struct drm_connector_state *conn_state;
