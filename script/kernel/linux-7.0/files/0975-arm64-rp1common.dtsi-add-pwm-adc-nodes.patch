Patch from MiniMyth2 project

Developed-by: Piotr Oniszczuk <piotr.oniszczuk@gmail.com>
Signed-off-by: Piotr Oniszczuk <piotr.oniszczuk@gmail.com>



diff --speed-large-files --no-dereference --minimal -Naur linux-7.0-rc1/arch/arm64/boot/dts/broadcom/rp1-common.dtsi linux-7.0-rc1/arch/arm64/boot/dts/broadcom/rp1-common.dtsi
--- linux-7.0-rc1/arch/arm64/boot/dts/broadcom/rp1-common.dtsi	2026-02-22 22:18:59.000000000 +0100
+++ linux-7.0-rc1/arch/arm64/boot/dts/broadcom/rp1-common.dtsi	2026-03-04 12:22:04.776919171 +0100
@@ -11,6 +11,14 @@
 	#address-cells = <2>;
 	#size-cells = <2>;
 
+	rp1_vdd_3v3: rp1_vdd_3v3 {
+		compatible = "regulator-fixed";
+		regulator-name = "vdd-3v3";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		regulator-always-on;
+	};
+
 	rp1_clocks: clocks@40018000 {
 		compatible = "raspberrypi,rp1-clocks";
 		reg = <0x00 0x40018000 0x0 0x10038>;
@@ -83,4 +91,34 @@
 		snps,tx-thr-num-pkt = /bits/ 8 <2>;
 		status = "disabled";
 	};
+
+	rp1_pwm0: pwm@98000 {
+		compatible = "raspberrypi,rp1-pwm";
+		reg = <0x00 0x40098000  0x0 0x100>;
+		#pwm-cells = <3>;
+		clocks = <&rp1_clocks RP1_CLK_PWM0>;
+		assigned-clocks = <&rp1_clocks RP1_CLK_PWM0>;
+		assigned-clock-rates = <50000000>;
+		status = "disabled";
+	};
+
+	rp1_pwm1: pwm@9c000 {
+		compatible = "raspberrypi,rp1-pwm";
+		reg = <0x00 0x4009c000  0x0 0x100>;
+		#pwm-cells = <3>;
+		clocks = <&rp1_clocks RP1_CLK_PWM1>;
+		assigned-clocks = <&rp1_clocks RP1_CLK_PWM1>;
+		assigned-clock-rates = <50000000>;
+		status = "disabled";
+	};
+
+	rp1_adc: adc@c8000 {
+		compatible = "raspberrypi,rp1-adc";
+		reg = <0x00 0x400c8000 0x0 0x4000>;
+		clocks = <&rp1_clocks RP1_CLK_ADC>;
+		clock-names = "adcclk";
+		#clock-cells = <0>;
+		vref-supply = <&rp1_vdd_3v3>;
+		status = "disabled";
+	};
 };
--

MiniMyth2

