From 72c3d9e79d79a669497772b25d291cac131d79bf Mon Sep 17 00:00:00 2001
From: Justin Suess <utilityemal77@gmail.com>
Date: Mon, 29 Jun 2026 17:35:30 -0400
Subject: [PATCH 06/13] media: cedrus: add A523 (sun55i) variant

Add support for the A523/H728 (sun55iw3) video engine. It shares the
H264/H265/MPEG2 register layout with the H6/D1 family, so the per-frame
programming matches cedrus 1:1; the VE module clock runs at 432 MHz like
the D1.

Unlike older SoCs the A523 has no dedicated VE SRAM region to remap via
the system-control block: the VE does physical DMA from the CMA pool with
the IOMMU in bypass. Add a quirk_no_sram flag so cedrus_hw_probe() skips
sunxi_sram_claim() (which would otherwise fail with -ENOENT), and document
the new allwinner,sun55i-a523-video-engine compatible.

This is untested ... no idea if it actually works.
---
 .../allwinner,sun4i-a10-video-engine.yaml     |  1 +
 drivers/staging/media/sunxi/cedrus/cedrus.c   | 20 +++++++++++++++++++
 drivers/staging/media/sunxi/cedrus/cedrus.h   |  7 +++++++
 .../staging/media/sunxi/cedrus/cedrus_hw.c    | 10 ++++++----
 4 files changed, 34 insertions(+), 4 deletions(-)

diff --git a/Documentation/devicetree/bindings/media/allwinner,sun4i-a10-video-engine.yaml b/Documentation/devicetree/bindings/media/allwinner,sun4i-a10-video-engine.yaml
index 01f2afa023f0..05ecc664e9d5 100644
--- a/Documentation/devicetree/bindings/media/allwinner,sun4i-a10-video-engine.yaml
+++ b/Documentation/devicetree/bindings/media/allwinner,sun4i-a10-video-engine.yaml
@@ -24,6 +24,7 @@ properties:
       - allwinner,sun50i-a64-video-engine
       - allwinner,sun50i-h5-video-engine
       - allwinner,sun50i-h6-video-engine
+      - allwinner,sun55i-a523-video-engine
 
   reg:
     maxItems: 1
diff --git a/drivers/staging/media/sunxi/cedrus/cedrus.c b/drivers/staging/media/sunxi/cedrus/cedrus.c
index bbd186b8035b..bb72e96ab6fe 100644
--- a/drivers/staging/media/sunxi/cedrus/cedrus.c
+++ b/drivers/staging/media/sunxi/cedrus/cedrus.c
@@ -651,6 +651,22 @@ static const struct cedrus_variant sun50i_h6_cedrus_variant = {
 	.mod_rate	= 600000000,
 };
 
+/*
+ * A523 (sun55iw3) shares the H264/H265/MPEG2 register layout with the
+ * H6/D1 family; the per-frame register programming matches cedrus 1:1
+ * (see RE notes). VE module clock parent runs at 432 MHz like the D1.
+ * Start minimal: 8-bit H264/H265/MPEG2 only. VP8 and 10-bit HEVC not
+ * yet validated on this SoC.
+ */
+static const struct cedrus_variant sun55i_a523_cedrus_variant = {
+	.capabilities	= CEDRUS_CAPABILITY_UNTILED |
+			  CEDRUS_CAPABILITY_MPEG2_DEC |
+			  CEDRUS_CAPABILITY_H264_DEC |
+			  CEDRUS_CAPABILITY_H265_DEC,
+	.mod_rate	= 432000000,
+	.quirk_no_sram	= true,
+};
+
 static const struct of_device_id cedrus_dt_match[] = {
 	{
 		.compatible = "allwinner,sun4i-a10-video-engine",
@@ -696,6 +712,10 @@ static const struct of_device_id cedrus_dt_match[] = {
 		.compatible = "allwinner,sun50i-h6-video-engine",
 		.data = &sun50i_h6_cedrus_variant,
 	},
+	{
+		.compatible = "allwinner,sun55i-a523-video-engine",
+		.data = &sun55i_a523_cedrus_variant,
+	},
 	{ /* sentinel */ }
 };
 MODULE_DEVICE_TABLE(of, cedrus_dt_match);
diff --git a/drivers/staging/media/sunxi/cedrus/cedrus.h b/drivers/staging/media/sunxi/cedrus/cedrus.h
index c4b1217c14b6..a176000b9f56 100644
--- a/drivers/staging/media/sunxi/cedrus/cedrus.h
+++ b/drivers/staging/media/sunxi/cedrus/cedrus.h
@@ -175,6 +175,13 @@ struct cedrus_dec_ops {
 struct cedrus_variant {
 	unsigned int	capabilities;
 	unsigned int	mod_rate;
+	/*
+	 * Newer SoCs (e.g. A523/sun55iw3) have no dedicated VE SRAM region to
+	 * remap via the system-control block; the VE does physical DMA from
+	 * the CMA pool with the IOMMU in bypass. Skip sunxi_sram_claim() for
+	 * those, which would otherwise fail with -ENOENT (no allwinner,sram).
+	 */
+	bool		quirk_no_sram;
 };
 
 struct cedrus_dev {
diff --git a/drivers/staging/media/sunxi/cedrus/cedrus_hw.c b/drivers/staging/media/sunxi/cedrus/cedrus_hw.c
index 444fb53878d1..083f7da8121f 100644
--- a/drivers/staging/media/sunxi/cedrus/cedrus_hw.c
+++ b/drivers/staging/media/sunxi/cedrus/cedrus_hw.c
@@ -273,11 +273,13 @@ int cedrus_hw_probe(struct cedrus_dev *dev)
 		return ret;
 	}
 
-	ret = sunxi_sram_claim(dev->dev);
-	if (ret) {
-		dev_err(dev->dev, "Failed to claim SRAM\n");
+	if (!variant->quirk_no_sram) {
+		ret = sunxi_sram_claim(dev->dev);
+		if (ret) {
+			dev_err(dev->dev, "Failed to claim SRAM\n");
 
-		goto err_mem;
+			goto err_mem;
+		}
 	}
 
 	dev->ahb_clk = devm_clk_get(dev->dev, "ahb");
