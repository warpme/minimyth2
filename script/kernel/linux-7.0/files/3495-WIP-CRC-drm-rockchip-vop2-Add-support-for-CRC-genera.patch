+static void vop2_crc_setup(struct drm_crtc *crtc, struct drm_atomic_state *state)
+{
+	struct rockchip_crtc_state *vcstate = to_rockchip_crtc_state(crtc->state);
+	struct vop2_video_port *vp = to_vop2_video_port(crtc);
+	u32 val = vop2_vp_read(vp, RK3568_VP_POST_SCL_CTRL);
+
+	if (vcstate->crc_source == ROCKCHIP_DRM_CRC_SOURCE_CRTC) {
+		struct drm_crtc_state *old_crtc_state = drm_atomic_get_old_crtc_state(state, crtc);
+		struct rockchip_crtc_state *old_vcstate = to_rockchip_crtc_state(old_crtc_state);
+
+		if (vcstate->crc_source != old_vcstate->crc_source) {
+			spin_lock_irq(&crtc->crc.lock);
+			vp->crc_crtc_skip_count = 0;
+			spin_unlock_irq(&crtc->crc.lock);
+		}
+
+		val |= RK3568_VP_POST_SCL_CTRL__CRC_EN;
+	} else {
+		val &= ~RK3568_VP_POST_SCL_CTRL__CRC_EN;
+	}
 
-	*dsp_ctrl |= FIELD_PREP(RK3568_VP_DSP_CTRL__DITHER_DOWN_SEL,
-				DITHER_DOWN_ALLEGRO);
+	vop2_vp_write(vp, RK3568_VP_POST_SCL_CTRL, val);
 }
 
