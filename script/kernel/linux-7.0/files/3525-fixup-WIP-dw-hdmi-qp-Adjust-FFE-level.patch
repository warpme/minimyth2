From 4a739e858a90eb351b6d9b03cf20188c378061d5 Mon Sep 17 00:00:00 2001
From: Cristian Ciocaltea <cristian.ciocaltea@collabora.com>
Date: Wed, 18 Mar 2026 13:41:20 +0200
Subject: [PATCH] fixup! [WIP] dw-hdmi-qp: Adjust FFE level

---
 drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c | 11 +++++++++--
 1 file changed, 9 insertions(+), 2 deletions(-)

diff --git a/drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c b/drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c
index d3a7a2779cea..590ee1793609 100644
--- a/drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c
+++ b/drivers/gpu/drm/bridge/synopsys/dw-hdmi-qp.c
@@ -986,10 +986,10 @@ static int dw_hdmi_qp_frl_lts3(struct dw_hdmi_qp *hdmi)
 		}
 
 		if (val & SCDC_FLT_UPDATE) {
-			//TODO: handle only 3 active lanes
 			u8 status, ln0, ln1, ln2, ln3;
 			u32 flt_cfg;
 
+			//TODO: SCDC helpers to manage Ln(x)_LTP_req regs
 			ret = drm_scdc_readb(hdmi->bridge.ddc, SCDC_STATUS_FLAGS_1, &status);
 			if (ret) {
 				dev_err(hdmi->dev, "lts3: SCDC read failed\n");
@@ -1041,7 +1041,6 @@ static int dw_hdmi_qp_frl_lts3(struct dw_hdmi_qp *hdmi)
 				if (!hdmi->flt_no_timeout && flt_cfg == 0x3333f)
 					flt_cfg = dw_hdmi_qp_read(hdmi, FLT_CONFIG1);
 
-				//TODO: ELSE IF Ln(x)_LTP_req register = (1 through 8)
 				dw_hdmi_qp_write(hdmi, flt_cfg, FLT_CONFIG1);
 			}
 
@@ -1087,6 +1086,12 @@ static int dw_hdmi_qp_frl_lts4(struct dw_hdmi_qp *hdmi)
 
 	dev_dbg(hdmi->dev, "lts4: switching to %ux%u\n", try_rate_per_lane, try_lanes);
 
+	ret = drm_scdc_writeb(hdmi->bridge.ddc, SCDC_UPDATE_0, SCDC_FLT_UPDATE);
+	if (ret) {
+		dev_err(hdmi->dev, "ltsp: SCDC write failed\n");
+		return LTSL;
+	}
+
 	/* Disable phy */
 	hdmi->phy.ops->disable(hdmi, hdmi->phy.data);
 
@@ -1256,6 +1261,8 @@ static int dw_hdmi_qp_frl_ltsl(struct dw_hdmi_qp *hdmi)
 		drm_scdc_writeb(hdmi->bridge.ddc, SCDC_UPDATE_0, SCDC_FLT_UPDATE);
 	}
 
+	dw_hdmi_qp_mod(hdmi, 0, AVP_DATAPATH_VIDEO_SWDISABLE, GLOBAL_SWDISABLE);
+
 	return LTSU;
 }
 
