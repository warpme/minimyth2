diff --speed-large-files --no-dereference --minimal -Naur linux-7.1.1/arch/arm64/boot/dts/broadcom/bcm2712.dtsi linux-7.1.1/arch/arm64/boot/dts/broadcom/bcm2712.dtsi
--- linux-7.1.1/arch/arm64/boot/dts/broadcom/bcm2712.dtsi	2026-06-22 18:34:16.425276783 +0200
+++ linux-7.1.1/arch/arm64/boot/dts/broadcom/bcm2712.dtsi	2026-06-22 18:25:14.872437077 +0200
@@ -779,8 +779,25 @@
 
 			power-domains = <&pm BCM2835_POWER_DOMAIN_GRAFX_V3D>;
 			resets = <&pm BCM2835_RESET_V3D>;
+			clocks = <&firmware_clocks 5>;
+			clocks-names = "v3d";
 			interrupts = <GIC_SPI 250 IRQ_TYPE_LEVEL_HIGH>,
 				     <GIC_SPI 249 IRQ_TYPE_LEVEL_HIGH>;
+			status = "okay";
+		};
+
+		rpivid: codec@800000 {
+			compatible = "raspberrypi,rpivid-vid-decoder";
+			reg = <0x10 0x00800000  0x0 0x10000>, /* HEVC */
+			      <0x10 0x00840000  0x0 0x1000>;  /* INTC */
+			reg-names = "hevc","intc";
+
+			interrupts = <GIC_SPI 98 IRQ_TYPE_LEVEL_HIGH>;
+
+			clocks = <&firmware_clocks 11>;
+			clock-names = "hevc";
+			//iommus = <&iommu2>;
+			status = "okay";
 		};
 	};
 
