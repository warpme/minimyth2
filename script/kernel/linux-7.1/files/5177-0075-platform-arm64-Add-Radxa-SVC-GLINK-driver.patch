+	seq_printf(s, "bad_msg_count: %lld\n", atomic64_read(&svc->bad_msg_count));
+	seq_printf(s, "dropped_msg_count: %lld\n", atomic64_read(&svc->dropped_msg_count));
+	seq_printf(s, "pending: %u\n", pending);
+	seq_printf(s, "pending_seq: %u\n", pending_seq);
+
+	return 0;
