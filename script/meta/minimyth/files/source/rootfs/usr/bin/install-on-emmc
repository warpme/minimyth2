#!/bin/sh

# Script works following commands:
#
#  install: when called with 'install' command
#    If selected target is UFS:
#    1.partition UFS strorage with 4 GPT partitions layout
#    2.copy SD card ROOT content to 3rd partition
#    3.copy SD card BOOT content to subdir /boot on 3rd partition
#    4.write bootloader to UFS (SoC speciffic to sda and to boot0 sdb/boot1 sdc devices)
#    5.update device in 'root=' and path in 'LINUX' and 'FDT' in extlinux.conf on UFS /boot/extlinux/extlinux.conf

#    If selected target is eMMC:
#    1.partition eMMC strorage with 3 MBR partitions layout
#    2.copy SD card BOOT content to 2nd partition
#    3.copy SD card ROOT content to 3rd partition
#    4.write bootloader to USB (SoC speciffic loc)
#    5.update device in 'root=' in extlinux.conf on eMMC <boot_part>/extlinux/extlinux.conf

#    If selected target is USB/NVME:
#    1.partition USB/NVME strorage with 3 MBR partitions layout
#    2.copy SD card BOOT content to 2nd partition
#    3.copy SD card ROOT content to 3rd partition
#    5.update device in 'root=' in extlinux.conf on SDcard/eMMC <boot_part>/extlinux/extlinux.conf

#
#  erase: when called with 'erase' command:
#    1. Erase eMMC/UFS by writing zero to first 'erase_areas_size' MBytes of eMMC/UFS/USB
#    2. Erase bootloader by writing zeros to boot0[1] partitions (eMMC) or sdb[c] disks (UFS/USB)
#

#
#  erasespi: when called with 'erasespi' command:
#    1. Erase mtd by calling 'flash_erase /dev/mtd0 0 0' - if mtdinfo reports mtd device is avaliable
#

#  bootloader: when called with 'bootloader' command:
#    1. Installs bootloader from SD card </bootloader> dir to boot0[1] partitions (eMMC) or sdb[c] disks (UFS)
#       If SD card has no </bootloader> dir, script creates such dir, dumps bootloader
#       from SD card to this dir then installs this dumped bootloader to eMMC/UFS.
#       Next script updates rootfs device number in extlinux.conf to eMMC 2nd part (eMMC) or sda2 part (UFS)
#

# area at target device begininng filled with zeros to make it erased. In MBytes.
erase_areas_size=1024

# script log file
log_file="/var/log/install-on-emmc.log"

#-----------------------------










































ver=7.0

command=$1

working_dir="/mnt/.install-on-emmc"

boot_src="${working_dir}/src-BOOT"
root_src="${working_dir}/src-ROOT"
boot_dst="${working_dir}/dst-BOOT"
root_dst="${working_dir}/dst-ROOT"

trap "_exit_" 2 3 9 15

_exit_() {
    echo "Script exited/aborted !"
    echo "Doing cleanups ..."
    clean_working_env
}

log() {
    echo >&2 "`date '+%H:%M:%S'`: $*" >> ${log_file}
}

msg() {
    log "$*"
    echo " "
    echo "==> $*"
}

error() {
    log "$*"
    echo "$*"
    echo "Please provide content of ${log_file} to developer ..."
    echo "Now exiting ..."
    exit 1
}

do_cmd() {
    log "Executing $*"
    #for partprobe stop checking for errors...
    if [[ "$*" =~ "partprobe" ]] ; then
        $* 2>>${log_file}
    else
        $* 2>>${log_file}
        if [ $? -ne 0 ] ; then
            error "Executing $* failed ..."
        fi
    fi
}

confirm() {

    echo " "
    echo "Please confirm $1 by pressing 'y'"
    echo " "
    echo "or press Enter (or any other key) to exit ..."
    echo " "

    read sel

    if [ x$sel = "xy" ] || [ x$sel = "xY" ] ; then
        return
    else
        _exit_

        echo " "
        echo "Exiting stript (by user no-confirm)"
        echo " "
        exit 0
    fi
}

clean_working_env() {
    umount_all_partitions
    rmdir -p ${src-BOOT} ${src-ROOT} ${dst-BOOT} ${dst-ROOT}
}

part_prefix() {
    if [[ ${1} =~ "mmcblk" ]] || [[ ${1} =~ "nvme" ]] ; then
        echo "p"
    else
        echo""
    fi
}

mount_partition() {
    # first param: dev e.g. mmcblk1
    # second param: part no e.g. 1, 2, 3
    # thirt param: dir to mount

    local dev=$1
    local part_num=$2
    local dir=$3

    if [ x$(mount -v | grep -c ${dir}) = "x0" ]; then
        msg "Mounting ${dev},part${part_num} at [${dir}] ..."
        local prefix=$(part_prefix ${dev})
        mkdir -p ${dir}
        mount ${dev}${prefix}${part_num} ${dir}
    else
        msg "${dev},part${part_num} already mounted on [${dir}] ..."
    fi
}

umount_partition() {
    local part=$1
    if [ "$(mount -v | grep -c ${part})" = "0" ]; then
        msg "Partition ${part} is not mounted ..."
        return 0
    else
        while [ "$(mount -v | grep -c ${part})" != "0" ]; do
            msg "Unmounting [${part}] ..."
            umount -q ${part}
            if [ "$(mount -v | grep -c ${part})" = "0" ]; then
                msg "Partition ${part} unmounted ..."
                break
            fi
            sleep 1
        done
    fi
}

partition_2part_mbr_then_format() {

    local disk=$1
    local prefix

    prefix=$(part_prefix $1)

    umount_partition ${disk}${prefix}1
    umount_partition ${disk}${prefix}2

    msg "Partitioning ${disk} with 3 MBR partitions ..."

    sfdisk "${disk}" <<EOF
label: dos
unit: sectors

start=32768, size=262144,  type=c, bootable, name="BOOT"
             size=8388608, type=83,          name="ROOT"
             size=4194304, type=82,          name="SWAP"
EOF

    msg "Partprobing ${disk} ..."
    partprobe ${disk}

    msg "Formating partition 1 (FAT32) ..."
    mkfs.vfat -F 32 -n BOOT ${disk}${prefix}1

    msg "Formating partition 2 (EXT2) ..."
    mkfs.ext2 -L ROOT ${disk}${prefix}2

    msg "Formating partition  3 (SWAP) ..."
    mkswap -L SWAP ${disk}${prefix}3

    msg "Formated ${disk} layout ..."
    lsblk ${disk}
}

partition_3part_gpt_then_format() {

    local disk=$1
    local prefix

    prefix=$(part_prefix ${disk})

    umount_partition ${disk}${prefix}1
    umount_partition ${disk}${prefix}2
    umount_partition ${disk}${prefix}3

    msg "Partitioning ${disk} with 4 GPT partitions ..."

    sfdisk "${disk}" <<EOF
label: gpt
label-id: 9b83ec43-54d0-41f2-9ac9-1ae79ef084fc
unit: sectors

start=32768, size=262144,  type=0FC63DAF-8483-4772-8E79-3D69D8477DE4, name="CONFIG"
             size=1048576, type=C12A7328-F81F-11D2-BA4B-00A0C93EC93B, name="EFI"
             size=8388608, type=0FC63DAF-8483-4772-8E79-3D69D8477DE4, name="ROOTFS"
             size=4194304, type=0657FD6D-A4AB-43C4-84E5-0933C84B4F4F, name="SWAP"
EOF

    msg "Partprobing ${disk} ..."
    partprobe ${disk}

    msg "Formating partition 1 (EXT2) ..."
    mkfs.ext2 -L Config ${disk}${prefix}1

    msg "Formating partition 2 (FAT32) ..."
    mkfs.vfat -F 32 -n EFI ${disk}${prefix}2

    msg "Formating partition 3 (EXT2) ..."
    mkfs.ext2 -L ROOT ${disk}${prefix}3

    msg "Formating partition  4 (SWAP) ..."
    mkswap -L SWAP ${disk}${prefix}4

    msg "Formated ${disk} layout ..."
    lsblk ${disk}
}

partition_1part_gpt_then_format() {

    local disk=$1
    local prefix

    prefix=$(part_prefix ${disk})

    umount_partition ${disk}${prefix}1

    msg "Partitioning ${disk} with 2 GPT partitions ..."

    fdisk "${disk}" <<EOF
label: gpt
label-id: 9b83ec43-54d0-41f2-9ac9-1ae79ef084fc
unit: sectors

start=32768, size=8388608, type=0FC63DAF-8483-4772-8E79-3D69D8477DE4, name="ROOT"
             size=4194304, type=0657FD6D-A4AB-43C4-84E5-0933C84B4F4F, name="SWAP"
EOF

    msg "Partprobing ${disk} ..."
    partprobe ${disk}

    msg "Formating partition 1 (EXT2) ..."
    mkfs.ext2 -L ROOT ${disk}${prefix}1

    msg "Formating partition  2 (SWAP) ..."
    mkswap -L SWAP ${disk}${prefix}2

    msg "Formated ${disk} layout ..."
    lsblk ${disk}
}

is_booted_from() {
    if [ "${boot_dev}" = "${1}" ] ; then
        if [ "${skip_check_is_booted_from}" = "yes" ] ; then
           return 1
        else
           return 0
        fi
    else
        return 1
    fi
}

what_platform() {

    if [ ! -e /sys/firmware/devicetree/base/compatible ] ; then
        echo "No [/sys/firmware/devicetree/base/compatible] sysfs dir to identify Your platfrom ..."
        echo "Exiting!"
        echo " "
        exit 1
    fi

    platform=$(tr -d '\0' < /sys/firmware/devicetree/base/compatible 2>/dev/null)
    log "platform string: ${platform}"
    echo "Ooo...you are running ${platform}"

    if [[ ${platform} =~ "allwinner" ]] ; then
        echo "Allwinner detected...Good!"
        platform_type="allwinner"

    elif [[ "${platform}" =~ "rk3328" ]] ; then
        echo "Rockchip 3328 detected..Good!"
        platform_type="rk3328"

    elif [[ "${platform}" =~ "rk3399" ]] ; then
        echo "Rockchip 3399 detected...Good!"
        platform_type="rk3399"

    elif [[ "${platform}" =~ "rk3528" ]] ; then
        echo "Rockchip 3528 detected..Good!"
        platform_type="rk3528"

    elif [[ "${platform}" =~ "sbc-with-5-partitions-layout" ]] ; then
        echo "Rockchip 3566/3568 (alt part.scheme) detected...Good!"
        platform_type="rk3568alt"

    elif [[ "${platform}" =~ "rk356" ]] ; then
        echo "Rockchip 3566/3568 detected...Good!"
        platform_type="rk3568"

    elif [[ "${platform}" =~ "rk3576" ]] ; then
        echo "Rockchip 3576 detected...Good!"
        platform_type="rk3576"

    elif [[ "${platform}" =~ "rk3588" ]] ; then
        echo "Rockchip 3588 detected...Good!"
        platform_type="rk3588"

    elif [[ "${platform}" =~ "amlogic" ]] ; then
        echo "Rpi detected... Bad... as it is unsupported!"
        platform_type="unsupported"

    elif [[ "${platform}" =~ "raspberrypi" ]] ; then
        echo "Rpi detected... Bad... as it is unsupported!"
        platform_type="unsupported"

    else
        echo "Unknown platform ..."
        platform_type="unsupported"
    fi
}

mount_source_partitions() {
    mount_partition /dev/${source_dev} 1 ${boot_src}
    mount_partition /dev/${source_dev} 2 ${root_src}
}

umount_all_partitions() {
    umount_partition ${boot_src}
    umount_partition ${root_src}
    umount_partition ${boot_dst}
    umount_partition ${root_dst}
}

copy_rootfs_use_rsync() {
    local source_dir="${1}"
    local target_dir="${2}"

    rsync -a -x -v -A -X \
    --exclude='/dev/' \
    --exclude='/proc/' \
    --exclude='/sys/' \
    --exclude='/tmp/' \
    --exclude='/run/' \
    --exclude='/mnt/' \
    --exclude='/media/*' \
    --exclude='/lost+found' \
    "${source_dir}" "${target_dir}"
}

copy_rootfs_use_cp() {
    local source_dir="${1}"
    local target_dir="${2}"

    if [ -e ${source_dir}/rootfs-ro ] ; then
        msg "copying rootfs from [${source_dir}] to [${target_dir}] in MiniMyth2 variant ..."
        cp -af ${source_dir}/* ${target_dir}/
    else
        msg "copying rootfs from [${source_dir}] to [${target_dir}] in MiniArch variant ..."
        cp -af ${source_dir}/bin* ${target_dir}/
        #boot
        #dev
        cp -af ${source_dir}/etc* ${target_dir}/
        cp -af ${source_dir}/home* ${target_dir}/
        cp -af ${source_dir}/lib* ${target_dir}/
        #mnt
        cp -af ${source_dir}/opt* ${target_dir}/
        #proc
        cp -af ${source_dir}/root* ${target_dir}/
        #run
        cp -af ${source_dir}/sbin* ${target_dir}/
        cp -af ${source_dir}/srv* ${target_dir}/
        #sys
        #tmp
        cp -af ${source_dir}/usr* ${target_dir}/
        cp -af ${source_dir}/var* ${target_dir}/
    fi
}

copy_sdcard_to_1part_gpt_disk() {

    mount_source_partitions

    mount_partition /dev/${target_dev} 1 ${root_dst}

    msg "Copying root data to target disk ..."
    #cp -af ${root_src}/* ${root_dst}/
    copy_rootfs_use_cp ${root_src} ${root_dst}

    msg "Copying boot data to target disk ..."
    mkdir -p ${root_dst}/boot
    cp -af ${boot_src}/* ${root_dst}/boot/
}

copy_sdcard_to_2part_mbr_disk() {

    mount_source_partitions

    mount_partition /dev/${target_dev} 1 ${boot_dst}
    mount_partition /dev/${target_dev} 2 ${root_dst}

    msg "Copying boot data to target disk ..."
    #cp -af ${boot_src}/* ${boot_dst}/
    copy_rootfs_use_cp ${root_src} ${root_dst}

    msg "Copying root data to target disk ..."
    cp -af ${root_src}/* ${root_dst}/
}

copy_sdcard_to_3part_gpt_disk() {

    mount_source_partitions

    mount_partition /dev/${target_dev} 3 ${root_dst}

    msg "Copying root data to disk ..."
    #cp -af ${root_src}/* ${root_dst}/
    copy_rootfs_use_cp ${root_src} ${root_dst}

    msg "Copying boot data to target disk ..."
    mkdir -p ${root_dst}/boot
    cp -af ${boot_src}/* ${root_dst}/boot/
}

update_extlinux_conf() {

    local dev=$2
    local part_num=$3
    local prefix=$(part_prefix ${dev})

    msg "Updating root= in extlinux.conf on [${1}] to ${dev}${prefix}${part_num} ..."
    sed -e "s|mmcblk[0-9]p[0-9]|${dev}${prefix}${part_num}|g" -i ${1}/extlinux/extlinux.conf
    sed -e "s|sd[a-z][0-9]|${dev}${prefix}${part_num}|g" -i ${1}/extlinux/extlinux.conf
}

erase_target() {

    dev=${1}

    msg "Erasing ${dev} ..."
    dd if=/dev/zero of=/dev/${dev} bs=1M count=${erase_areas_size} conv=fsync
}

erase_bootloader() {

    msg "Erasing bootloader ..."
    dd if=/dev/zero of=/tmp/file_with_zeros count=2048 conv=fsync

    write_target_bootX 0 "/tmp/file_with_zeros"
    write_target_bootX 1 "/tmp/file_with_zeros"

    rm -f /tmp/file_with_zeros

    sync
}

write_target_bootX() {

    # 1 param: bootX id
    # 2 param: blob to write
    #hack for UFS. On UFS devices, boot0 and boot1 are just next disks (sdb, sdc)
    if [ $1 = "0" ] ; then
        ufs_boot_part="sdb"
    fi
    if [ $1 = "1" ] ; then
        ufs_boot_part="sdc"
    fi

    if [ -e /sys/block/${target_dev}boot$1 ] ; then

        log "Executing echo 0 > /sys/block/${target_dev}boot$1/force_ro"
        echo 0 > /sys/block/${target_dev}boot$1/force_ro

        write_target=/dev/${target_dev}boot$1

    elif [ -e /sys/block/${ufs_boot_part} ] ; then

        write_target=/dev/${ufs_boot_part}

    else
        msg "  no eMMC ${target_dev}boot$1 part nor UFS /dev/sdb[c] found. Skiping ..."
        return 1
    fi

    log "Zeroing ${write_target} ..."
    dd if=/dev/zero of=${write_target} count=2048 conv=fsync

    log "Writing $2 to ${write_target} ..."
    dd if=$2 of=${write_target} conv=fsync
}

write_bootloader_to_target_rockchip() {

    idbloader_blob="/boot/bootloader/idbloader.img"
    uboot_blob="/boot/bootloader/u-boot.itb"

    if [ -e ${idbloader_blob} ] ; then
        msg "Will use idbloader from [/boot/bootloader/] ..."
    else
        msg "No idbloader in [/boot/bootloader]. Will copy from ${source_dev} ..."
        mkdir -p /boot/bootloader/
        dd if=/dev/${source_dev} of=${idbloader_blob} count=4031 skip=64
    fi

    if [ -e ${uboot_blob} ] ; then
        msg "Will use u-boot from [/boot/bootloader/] ..."
    else
        msg "No u-boot in [/boot/bootloader]. Will copy from ${source_dev} ..."
        mkdir -p /boot/bootloader/
        dd if=/dev/${source_dev} of=${uboot_blob} count=8191 skip=16384
    fi

    msg "Writing idbloader.img to boot0 ..."
    write_target_bootX 0 ${idbloader_blob}
    msg "Writing idbloader.img to boot1 ..."
    write_target_bootX 1 ${idbloader_blob}

    msg "Installing idbloader ..."
    dd if=${idbloader_blob} of=/dev/${target_dev} seek=64 conv=notrunc

    msg "Installing u-boot ..."
    dd if=${uboot_blob} of=/dev/${target_dev} seek=16384 conv=notrunc

    sync
}

write4096_bootloader_to_target() {

    idbloader_blob="/boot/bootloader/idbloader.img"
    uboot_blob="/boot/bootloader/u-boot.itb"

    if [ -e ${idbloader_blob} ] ; then
        msg "Will use idbloader from [/boot/bootloader/] ..."
    else
        msg "No idbloader in [/boot/bootloader]. Will copy from ${source_dev} ..."
        mkdir -p /boot/bootloader/
        dd if=/dev/${source_dev} of=${idbloader_blob} bs=4k skip=8 count=256
    fi

    if [ -e ${uboot_blob} ] ; then
        msg "Will use u-boot from [/boot/bootloader/] ..."
    else
        msg "No u-boot in [/boot/bootloader]. Will copy from ${source_dev} ..."
        mkdir -p /boot/bootloader/
        dd if=/dev/${source_dev} of=${uboot_blob} bs=4k skip=2048 count=512
    fi

    msg "Writing idbloader.img to boot0 ..."
    write_target_bootX 0 ${idbloader_blob}
    msg "Writing idbloader.img to boot1 ..."
    write_target_bootX 1 ${idbloader_blob}

    msg "Installing idbloader ..."
    dd if=${idbloader_blob} of=/dev/${target_dev} bs=4k seek=8 conv=notrunc

    msg "Installing u-boot ..."
    dd if=${uboot_blob} of=/dev/${target_dev} bs=4k seek=2048 conv=notrunc

    sync
}

write_bootloader_to_target_allwinner() {

    uboot_blob="/boot/bootloader/u-boot-sunxi-with-spl.bin"

    if [ -e ${uboot_blob} ] ; then
        msg "Will use u-boot from [/boot/bootloader/] ..."
    else
        msg "No u-boot in [/boot/bootloader]. Will copy from ${source_dev} ..."
        mkdir -p /boot/bootloader/
        dd if=/dev/${source_dev} of=${uboot_blob} count=4096 skip=16
    fi

    msg "Writing u-boot-sunxi-with-spl.bin to boot0 ..."
    write_target_bootX 0 ${uboot_blob}
    msg "Writing u-boot-sunxi-with-spl.bin to boot1 ..."
    write_target_bootX 1 ${uboot_blob}

    msg "Installing u-boot ..."
    dd if=${uboot_blob} of=/dev/${target_dev} seek=16 conv=notrunc

    sync
}

write_bootloader_to_target() {

    if [ x$platform_type = "xallwinner" ] ; then
        write_bootloader_to_target_allwinner

    elif [ x$platform_type = "xrk3328" ] ; then
        # this is for rockchip 3328
        write_bootloader_to_target_rockchip

    elif [ x$platform_type = "xrk3399" ] ; then
        # this is for rockchip 3399
        write_bootloader_to_target_rockchip

    elif [ x$platform_type = "xrk3528" ] ; then
        # this is for rockchip 3528
        write_bootloader_to_target_rockchip

    elif [ x$platform_type = "xrk3568" ] ; then
        # this is for rockchip 356x
        write_bootloader_to_target_rockchip

    elif [ x$platform_type = "xrk3576" ] ; then
        # this is for rockchip 3576
        write_bootloader_to_target_rockchip

    elif [ x$platform_type = "xrk3588" ] ; then
        # this is for rockchip 3588
        write_bootloader_to_target_rockchip

    else
        # this is for usupported
        msg "write_bootloader_to_target: unknown platform ..."
    fi
}

is_present() {
    if [ "${1}" != "N/A" ] ;  then
        return 0
    else
        return 1
    fi
}

is_present_and_not_booted_from() {
    if is_present ${1} && ! is_booted_from ${1} ; then
        return 0
    else
        return 1
    fi
}

check_presence_and_select_target() {
    target_dev=""
    target_dev_name="N/A"

    if [ ${devices_in_system} -lt 2 ] ; then
        #single device case
            if is_present_and_not_booted_from ${emmc_dev} ; then
                target_dev=${emmc_dev}
                target_dev_name="eMMC"
            elif is_present_and_not_booted_from ${ufs_dev} ; then
                target_dev=${ufs_dev}
                target_dev_name="UFS"
            elif is_present_and_not_booted_from ${usb_dev} ; then
                target_dev=${usb_dev}
                target_dev_name="USB"
            elif is_present_and_not_booted_from ${nvme_dev} ; then
                target_dev=${nvme_dev}
                target_dev_name="NVME"
            else
                echo " "
                echo "No suitable target to install found!"
                echo "Exiting ..."
                echo " "
                exit 1
            fi
        echo "==> Found target device: ${target_dev_name} (${target_dev})"
        echo " "
    else
        #more than 1 device. selection needed
        echo " " 
        echo "Multiple target candidates identified."
        echo "Please select target to install:"
        echo " "
        if is_present_and_not_booted_from ${emmc_dev} ; then
            echo "(e): eMMC module"
        fi
        if is_present_and_not_booted_from ${ufs_dev} ; then
            echo "(f): UFS module"
        fi
        if is_present_and_not_booted_from ${usb_dev} ; then
            echo "(u): USB key"
        fi
        if is_present_and_not_booted_from ${nvme_dev} ; then
            echo "(n): NVME disk"
        fi

        read sel

        if  [ "${sel}" = "e" ] ; then
            target_dev=${emmc_dev}
            target_dev_name="eMMC"
        elif [ "${sel}" = "f" ] ; then
            target_dev=${ufs_dev}
            target_dev_name="UFS"
        elif [ "${sel}" = "u" ] ; then
            target_dev=${usb_dev}
            target_dev_name="USB"
        elif [ "${sel}" = "n" ] ; then
            target_dev=${nvme_dev}
            target_dev_name="NVME"
        else
            echo " "
            echo "Wrong selection! Exiting ..."
            echo " "
            exit 1
        fi
        echo "==> Selectd target device: ${target_dev_name} (${target_dev})"
        echo " "
    fi
}

check_presence_and_select_source() {
    source_dev=""
    source_dev_name="N/A"
    if is_present ${sdcard_dev} && is_present ${emmc_dev} ; then
        #more than 1 device. selection needed
        echo " " 
        echo "Multiple source candidates identified."
        echo "Please select source to install from:"
        echo " "

        if is_present ${sdcard_dev} ; then
            echo "(s): SD card"
        fi
        if is_present ${emmc_dev} ; then
            echo "(e): eMMC module"
        fi

        read sel

        if  [ "${sel}" = "e" ] ; then
            source_dev=${emmc_dev}
            source_dev_name="eMMC"
        elif [ "${sel}" = "s" ] ; then
            source_dev=${sdcard_dev}
            source_dev_name="SDcard"
        else
            echo " "
            echo "Wrong selection! Exiting ..."
            echo " "
            exit 1
        fi

        echo "==> Selectd source device: ${source_dev_name} (${source_dev})"
        echo " "
    else
        #single device
        if is_present ${sdcard_dev} ; then
            source_dev=${sdcard_dev}
            if is_booted_from ${sdcard_dev} ; then 
                source_dev_name="SDcard (booted from)"
            else
                source_dev_name="SDcard"
            fi
        elif is_present ${emmc_dev} ; then
            source_dev=${emmc_dev}
            if is_booted_from ${sdcard_dev} ; then 
                source_dev_name="eMMC (booted from)"
            else
                source_dev_name="eMMC"
            fi
        else
            echo " "
            echo "No SDcard nor eMMC as source found!"
            echo "To install to UFS/USB or NVME sctipt requires system on SDcard or eMMC as source."
            echo "Exiting ..."
            echo " "
            exit 1
        fi

        echo "==> Found source device: ${source_dev_name} (${source_dev})"
        echo " "

    fi
}

boot_dev=$(mount | grep -e '/initrd\s' | awk '{print $1}' | sed 's/\/dev\///g' | sed 's/[0123456789]$//g' | sed 's/p//g' )
if [ x"${boot_dev}" = "x" ]; then
    boot_dev=$(mount | grep -e 'on\s/\s' | awk '{print $1}' | sed 's/\/dev\///g' | sed 's/[0123456789]$//g' | sed 's/p//g' )
fi

spi_dev="N/A"
spi_devices=$(mtdinfo | grep Count | sed -e 's/[^0-9]//g')
if [ x$spi_devices = "x1" ] ; then
    spi_dev=$(mtdinfo | grep Present | sed -e 's/.*:\s*//g')
elif [ $spi_devices gt= "1" ] ; then
    echo "Your system has more than 1 spi devide. This is unsupported by this script ..."
fi

devices_in_system=0

sdcard_dev="N/A"
for TYPE in /sys/class/block/mmcblk*/device/type; do
    if grep -q "SD" "${TYPE}" 2>/dev/null ; then
        sdcard_dev="$(echo "${TYPE}" | awk -F/ '{print $5}')"
        devices_in_system=$((${devices_in_system} + 1))
        break
    fi
done

emmc_dev="N/A"
for TYPE in /sys/class/block/mmcblk*/device/type; do
    if grep -q "MMC" "${TYPE}" 2>/dev/null ; then
        emmc_dev="$(echo "${TYPE}" | awk -F/ '{print $5}')"
        devices_in_system=$((${devices_in_system} + 1))
        break
    fi
done

ufs_dev="N/A"
usb_dev="N/A"
for device in /sys/class/block/sd*/device/type; do
    device_path=$(readlink -f $device)
    if [[ "$device_path" == *"usb"* ]]; then
        if [ x${usb_dev} = "xN/A" ] ; then
            usb_dev=$(echo ${device} | cut -d'/' -f5)
            devices_in_system=$((${devices_in_system} + 1))
        fi
    elif [[ "$device_path" == *"ufs"* ]]; then
        if [ x${ufs_dev} = "xN/A" ] ; then
            ufs_dev=$(echo ${device} | cut -d'/' -f5)
            devices_in_system=$((${devices_in_system} + 1))
        fi
    elif [[ "$device_path" == *"nvme"* ]]; then
        if [ x${nvme_dev} = "xN/A" ] ; then
            nvme_dev=$(echo ${device} | cut -d'/' -f5)
            devices_in_system=$((${devices_in_system} + 1))
        fi
    fi
done

nvme_dev="N/A"
for device in /sys/class/block/nvme*/device/state; do
    device_path=$(readlink -f $device)
    if [[ "$device_path" == *"nvme"* ]]; then
        if [ x${nvme_dev} = "xN/A" ] ; then
            nvme_dev=$(echo ${device} | cut -d'/' -f5)
            devices_in_system=$((${devices_in_system} + 1))
        fi
    fi
done

echo " "
echo "--- MiniMyth2 to eMMC/UFS/USB/NVME installer v$ver (c)Piotr Oniszczuk ---"
echo " "

what_platform
# exit for anything (amlogic, rpi) as unsupported (yet)
if [ x$platform_type = "xunsupported" ] ; then
    echo " "
    echo "Unsupported (yet) platform! Exiting ..."
    echo " "
    exit 1
fi

boot_dev_name="Unknown"
if [[ ${boot_dev} =~ ${sdcard_dev} ]] ; then
    boot_dev_name="SD card"
fi
if [[ ${boot_dev} =~ ${emmc_dev} ]] ; then
    boot_dev_name="eMMC module"
fi
if [[ ${boot_dev} =~ ${ufs_dev} ]] ; then
    boot_dev_name="UFS module"
fi
if [[ ${boot_dev} =~ ${usb_dev} ]] ; then
    boot_dev_name="USB key"
fi
if [[ ${boot_dev} =~ ${nvme_dev} ]] ; then
    boot_dev_name="NVME disk"
fi

echo " "
echo "Platform             : ${platform}"
echo "Board/device         : ${platform_type}"
echo " " 
echo "SDcard device        : ${sdcard_dev}"
echo "eMMC device          : ${emmc_dev}"
echo "UFS device           : ${ufs_dev}"
echo "USB device           : ${usb_dev}"
echo "NVME device          : ${nvme_dev}"
echo "Devices in system    : ${devices_in_system}"
echo "SPI device           : ${spi_dev}"
echo "System booted from   : ${boot_dev_name} (${boot_dev})"

if [ x"${boot_dev}" = "x" ]; then
    echo " "
    echo "Can't determine boot device! Exiting ..."
    echo " "
    exit 1
fi


if [ "${command}" = "erase" ] ; then

    skip_check_is_booted_from="yes"
    check_presence_and_select_target
    skip_check_is_booted_from="no"

    clean_working_env

    echo " "
    echo "erasing ${target_dev_name} (${target_dev}) ..."

    confirm "Please, confirm to erase"
    confirm "ARE YOU SURE to erase ${target_dev} content?"

    erase_target ${target_dev}

    if is_present ${sdcard_dev} ; then

        erase_bootloader

        # changing back root= to SDcard device
        echo "Restoring root= in exlinux.conf back to ${sdcard_dev},part2 ..."
        umount_partition ${boot_src}
        mount_partition /dev/${sdcard_dev} 1 ${boot_src}
        update_extlinux_conf ${boot_src} ${sdcard_dev} 2
        umount_partition ${boot_src}
    fi

    if is_present ${emmc_dev} ; then

        erase_bootloader

        # changing back root= to eMMC device
        echo "Restoring root= in exlinux.conf back to ${emmc_dev},part2 ..."
        umount_partition ${boot_src}
        mount_partition /dev/${emmc_dev} 1 ${boot_src}
        update_extlinux_conf ${boot_src} ${emmc_dev} 2
        umount_partition ${boot_src}
    fi

    sync

    echo " "
    echo "Done ..."
    echo " "
    exit 0

elif [ "${command}" = "erasespi" ] ; then

    if [ x"${spi_dev}" = "xN/A" ] ; then
        echo "It looks Your system don't have any SPI device ..."
        echo "Script will exit now!"
        echo " " 
        exit 0
    fi

    echo " "
    echo "erasing ${spi_dev} ..."

    confirm "to erase SPI"
    confirm "ARE YOU SURE to erase ${spi_dev} content?"

    flash_erase /dev/${spi_dev} 0 0

    sync

    echo " "
    echo "Done ..."
    echo " "
    exit 0

elif [ "${command}" = "bootloader" ] ; then

    check_presence_and_select_target

    check_presence_and_select_source

    if [ ${target_dev} != ${emmc_dev} ] ; then
        echo "Writing bootloader is supported only for eMMC target ..."
        echo "Current target is ${target_dev_name} (${target_dev})"
        echo " "
        echo "Exiting!"
        echo " "
        exit 1
    fi

    confirm "to install/update bootloader on ${target_dev_name} (${target_dev})"

    write_bootloader_to_target

    sync

    echo " "
    echo "Done ..."
    echo " "
    exit 0

elif [ "${command}" = "install" ] ; then

    check_presence_and_select_target

    check_presence_and_select_source

    clean_working_env

    confirm "you have working bootolader on SPI or SDCard or eMMC - if You are installing to UFS, USB or NVME\nThis is required due SoC BootROM limitations\nSo confirm You have working bootloader on device SPI or SDCard or eMMC"

    confirm "ARE YOU SURE to DESTROY ALL content on ${target_dev_name} (${target_dev}) device?"

    if [ "${target_dev}" = "${usb_dev}" ] || [ "${target_dev}" = "${nvme_dev}" ] || [ "${target_dev}" = "${emmc_dev}" ] ; then

        partition_2part_mbr_then_format /dev/${target_dev}

        msg "Copying ${storage_usage}MB to ${target_dev_name} (${target_dev})..."
        copy_sdcard_to_2part_mbr_disk
        msg "Copying to ${target_dev_name} done ..."

        if [ "${target_dev}" = "${usb_dev}" ] || [ "${target_dev}" = "${nvme_dev}" ]; then
            # for USB and NVME modify root=  on boot device (which is SDcard or eMMC)
            update_extlinux_conf ${boot_src} ${target_dev} 2
        else
            # target is eMMC
            update_extlinux_conf ${boot_dst} ${target_dev} 2

            msg "Writing bootloader to eMMC ..."
            write_bootloader_to_target
        fi

    elif [ "${target_dev}" = "${ufs_dev}" ] ; then

        partition_3part_gpt_then_format /dev/${target_dev}

        msg "Copying ${storage_usage}MB to ${target_dev_name} (${target_dev})..."
        copy_sdcard_to_3part_gpt_disk
        msg "Copying to ${target_dev_name} done ..."

        update_extlinux_conf ${boot_src} ${target_dev} 2
        update_extlinux_conf ${root_dst}/boot ${target_dev} 3

        sed -e "s|Image|boot/Image|g" -i ${root_dst}/boot/extlinux/extlinux.conf
        sed -e "s|dtbs|boot/dtbs|g" -i ${root_dst}/boot/extlinux/extlinux.conf

    else

        msg "Unsupported/unknown target. Script will exit without any action ..."
        echo " "
        exit 1
    fi

    sync

    umount_all_partitions

    echo " "
    echo "It looks system was successfuly installed on ${target_dev_name} (${target_dev}) :-)"
    echo "You can now poweroff and poweron again. System should boot from ${target_dev_name} ..."
    echo "So...happy booting :-)"
    echo " "
    exit 0

else
    echo " "
    echo "Run script with command: erase|erasespi|bootloader|install"
    echo " "

    exit 0
fi

exit 0
