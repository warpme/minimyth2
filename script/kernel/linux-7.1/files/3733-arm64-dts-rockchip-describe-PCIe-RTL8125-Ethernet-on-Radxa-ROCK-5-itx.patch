diff --speed-large-files --no-dereference --minimal -Naur linux-4549871118cf616eecdd2d939f78e3b9e1dddc48/arch/arm64/boot/dts/rockchip/rk3588-rock-5-itx.dts linux-4549871118cf616eecdd2d939f78e3b9e1dddc48/arch/arm64/boot/dts/rockchip/rk3588-rock-5-itx.dts
--- linux-4549871118cf616eecdd2d939f78e3b9e1dddc48/arch/arm64/boot/dts/rockchip/rk3588-rock-5-itx.dts	2026-06-09 14:43:12.928775919 +0200
+++ linux-4549871118cf616eecdd2d939f78e3b9e1dddc48/arch/arm64/boot/dts/rockchip/rk3588-rock-5-itx.dts	2026-06-09 14:48:52.274075234 +0200
@@ -24,6 +24,8 @@
 		mmc0 = &sdmmc;
 		mmc1 = &sdhci;
 		mmc2 = &sdio;
+		ethernet0 = &rtl_eth0;
+		ethernet1 = &rtl_eth1;
 	};
 
 	chosen {
@@ -668,6 +670,20 @@
 	reset-gpios = <&gpio4 RK_PA2 GPIO_ACTIVE_HIGH>;
 	vpcie3v3-supply = <&vcc3v3_lan>;
 	status = "okay";
+
+	pcie@0,0 {
+		reg = <0x200000 0 0 0 0>;
+		#address-cells = <3>;
+		#size-cells = <2>;
+		ranges;
+		device_type = "pci";
+		bus-range = <0x20 0x2f>;
+
+		rtl_eth0: ethernet@0,0 {
+			compatible = "pci10ec,8125";
+			reg = <0x210000 0 0 0 0>;
+		};
+	};
 };
 
 /* RTL8125B_2 */
@@ -677,6 +693,20 @@
 	reset-gpios = <&gpio3 RK_PB0 GPIO_ACTIVE_HIGH>;
 	vpcie3v3-supply = <&vcc3v3_lan_phy2>;
 	status = "okay";
+
+	pcie@0,0 {
+		reg = <0x400000 0 0 0 0>;
+		#address-cells = <3>;
+		#size-cells = <2>;
+		ranges;
+		device_type = "pci";
+		bus-range = <0x40 0x4f>;
+
+		rtl_eth1: ethernet@0,0 {
+			compatible = "pci10ec,8125";
+			reg = <0x410000 0 0 0 0>;
+		};
+	};
 };
 
 &pcie30phy {
