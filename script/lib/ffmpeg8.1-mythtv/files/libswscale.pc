prefix=/usr
exec_prefix=${prefix}
libdir=/usr/lib
includedir=/usr/include

Name: libswscale
Description: FFmpeg image rescaling library
Version: 9.5.100
Requires: 
Requires.private: libavutil >= 60.26.100
Conflicts:
Libs: -L${libdir}  -lswscale 
Libs.private: -lm -latomic -lglslang -lMachineIndependent -lGenericCodeGen -lSPIRV -lSPIRV-Tools-opt -lSPIRV-Tools -lstdc++ -lm -pthread
Cflags: -I${includedir}
