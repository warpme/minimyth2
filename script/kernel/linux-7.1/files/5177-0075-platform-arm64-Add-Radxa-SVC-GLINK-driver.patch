+static int radxa_svc_tsens_all_show(struct seq_file *s, void *unused)
+{
+	struct radxa_svc_glink *svc = s->private;
+	struct radxa_svc_tsens_all_resp *resp;
+	u32 num_sensors;
+	u64 valid_mask;
+	size_t header_len = offsetof(struct radxa_svc_tsens_all_resp, temp_deci_c);
+	size_t expected_len;
+	size_t len;
+	int ret;
+	u32 i;
+
+	len = header_len + RADXA_SVC_TSENS_MAX_SENSORS * sizeof(__le32);
+	resp = kzalloc(len, GFP_KERNEL);
+	if (!resp)
+		return -ENOMEM;
+
+	ret = radxa_svc_request(svc, RADXA_SVC_OP_TSENS_GET_ALL, NULL, 0,
+				resp, &len);
+	if (ret) {
+		seq_printf(s, "error: %d\n", ret);
+		goto out_free;
+	}
+
+	if (len < header_len) {
+		seq_puts(s, "error: short tsens all response\n");
+		goto out_free;
+	}
+
+	num_sensors = le32_to_cpu(resp->num_sensors);
+	valid_mask = le64_to_cpu(resp->valid_mask);
+	if (num_sensors > RADXA_SVC_TSENS_MAX_SENSORS) {
+		seq_printf(s, "error: invalid num_sensors %u\n", num_sensors);
+		goto out_free;
+	}
+
+	expected_len = header_len + num_sensors * sizeof(__le32);
+	if (len < expected_len) {
+		seq_printf(s, "error: short tsens all response: %zu < %zu\n",
+			   len, expected_len);
+		goto out_free;
+	}
+
+	seq_printf(s, "num_sensors: %u\n", num_sensors);
+	seq_printf(s, "valid_mask: 0x%016llx\n", (unsigned long long)valid_mask);
+	seq_puts(s, "sensor valid temp_deci_c temp_c\n");
+
+	for (i = 0; i < num_sensors; i++) {
+		s32 temp_deci_c = (s32)le32_to_cpu(resp->temp_deci_c[i]);
+		bool valid = valid_mask & BIT_ULL(i);
+
+		seq_printf(s, "%u %u %d ", i, valid ? 1 : 0, temp_deci_c);
+		if (valid)
+			radxa_svc_print_deci_c(s, temp_deci_c);
+		else
+			seq_puts(s, "n/a");
+		seq_putc(s, '\n');
+	}
+
+out_free:
+	kfree(resp);
+	return 0;
+}
